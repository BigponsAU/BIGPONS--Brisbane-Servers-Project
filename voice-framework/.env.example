PORT=3001
NODE_ENV=development

# Comma-separated browser Origins allowed to call /api with credentials.
# Local unified dev: include http://localhost:3000 (Astro site).
# Production: add https://yourname.github.io and your real domain.
ALLOWED_ORIGINS=http://localhost:3000

# Optional: allow any https://*.github.io Origin (GitHub Pages). Prefer explicit ALLOWED_ORIGINS when possible.
# ALLOW_GITHUB_PAGES=1

# Behind Render / nginx — trust X-Forwarded-For (set in Docker/Render by default in DEPLOYMENT.md).
# TRUST_PROXY=1

# Dashboard authentication (required for resource lifecycle actions)
ADMIN_EMAIL=admin@brisbaneservers.com
ADMIN_PASSWORD=admin123

# Change in production
JWT_SECRET=change-this-secret-in-production
