{
  "name": "voice-framework",
  "version": "1.0.0",
  "description": "NLP framework for capturing, analyzing, and generating text in the Brisbane Servers design system voice",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:force": "tsc --build --force",
    "build:clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && npm run build",
    "build:dashboard": "node scripts/build-dashboard.js",
    "build:dashboard:prod": "node scripts/build-dashboard.js --obfuscate",
    "build:production": "npm run build && npm run build:dashboard:prod",
    "verify": "node verify-build.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:examples": "ts-node examples/usage-examples.ts",
    "analyze": "ts-node -e \"import('./analyzers/tone-analyzer').then(m => console.log('Analyzer loaded'))\"",
    "dashboard": "tsx dashboard/server.ts",
    "docker:build": "docker build -f Dockerfile -t voice-framework-dashboard .",
    "start": "npm run dashboard",
    "website-to-profile": "tsx website-to-profile.ts"
  },
  "keywords": [
    "nlp",
    "voice",
    "tone",
    "text-generation",
    "text-analysis",
    "voice-matching"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.2",
    "express-validator": "^7.0.1",
    "mime-types": "^2.1.35",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "javascript-obfuscator": "^4.1.1",
    "ts-node": "^10.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
