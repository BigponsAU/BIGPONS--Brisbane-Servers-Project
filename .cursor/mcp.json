{
    "mcpServers":  {
                       "cloudflare-api":  {
                                              "command":  "npx",
                                              "args":  [
                                                           "-y",
                                                           "mcp-remote@latest",
                                                           "https://mcp.cloudflare.com/mcp",
                                                           "3334",
                                                           "--auth-timeout",
                                                           "300",
                                                           "--debug"
                                                       ]
                                          },
                       "cloudflare-docs":  {
                                               "url":  "https://docs.mcp.cloudflare.com/mcp"
                                           },
                       "render":  {
                                      "command":  "powershell",
                                      "args":  [
                                                   "-NoProfile",
                                                   "-ExecutionPolicy",
                                                   "Bypass",
                                                   "-File",
                                                   "${workspaceFolder}/website-brisbaneservers.com/scripts/mcp-render.ps1"
                                               ]
                                  }
                   }
}
