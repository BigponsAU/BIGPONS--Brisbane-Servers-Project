---
import BaseLayout from '../../../../src/layouts/BaseLayout.astro';
import Header from '../../../../src/components/Header.astro';
import Footer from '../../../../src/components/Footer.astro';
import Breadcrumbs from '../../../../src/components/Breadcrumbs.astro';
import InquiryForm from '../../../../src/components/InquiryForm.astro';
import { resolvePublicApiUrl } from '../../../../src/lib/api-config';

const publicApiBaseUrl = resolvePublicApiUrl('');
---

<BaseLayout
  title="Resource Detail - Brisbane Servers"
  description="Detailed resource content served from the hybrid API."
>
  <Header currentPath="/resources/item" />

  <main>
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Resources', href: '/resources' },
      { label: 'Resource detail' }
    ]} />

    <section class="section">
      <div class="container">
        <div id="resource-detail-status" class="resource-status" aria-live="polite">
          Loading resource…
        </div>

        <article id="resource-detail-article" class="resource-detail" hidden>
          <header class="resource-header">
            <p id="resource-kicker" class="resource-kicker"></p>
            <h1 id="resource-title"></h1>
            <p id="resource-description" class="resource-description"></p>
          </header>

          <div id="resource-meta" class="resource-meta"></div>
          <div id="resource-content" class="resource-content"></div>
          <p class="resource-back-link">
            <a id="resource-topic-link" class="btn btn-secondary" href="/resources">Back to resources</a>
          </p>
        </article>
      </div>
    </section>

    <InquiryForm
      title="Need clarity on this resource?"
      subtitle="Bring your context and we can translate the guidance into a practical next step."
    />
  </main>

  <Footer />
</BaseLayout>

<script define:vars={{ apiBaseUrl: publicApiBaseUrl }}>
  const statusEl = document.getElementById('resource-detail-status');
  const articleEl = document.getElementById('resource-detail-article');
  const titleEl = document.getElementById('resource-title');
  const kickerEl = document.getElementById('resource-kicker');
  const descriptionEl = document.getElementById('resource-description');
  const metaEl = document.getElementById('resource-meta');
  const contentEl = document.getElementById('resource-content');
  const topicLinkEl = document.getElementById('resource-topic-link');

  async function loadResource() {
    const params = new URLSearchParams(window.location.search);
    const resourceId = params.get('id');

    if (!resourceId) {
      if (statusEl) {
        statusEl.textContent = 'Missing resource id. Return to the resources index and choose an item.';
      }
      return;
    }

    try {
      const response = await fetch(`${apiBaseUrl}/resources/public?id=${encodeURIComponent(resourceId)}`, {
        headers: { Accept: 'application/json' }
      });

      if (!response.ok) {
        throw new Error('Resource not found');
      }

      const data = await response.json();
      const resource = data?.resource;
      if (!resource) {
        throw new Error('Resource not found');
      }

      document.title = `${resource.title} - Resources - Brisbane Servers`;

      if (titleEl) titleEl.textContent = resource.title;
      if (kickerEl) kickerEl.textContent = `${resource.industry} / ${resource.topic}`;
      if (descriptionEl) descriptionEl.textContent = resource.description || '';

      if (metaEl) {
        const metaParts = [];
        if (resource.generatedAt) {
          metaParts.push(`Published ${new Date(resource.generatedAt).toLocaleDateString()}`);
        }
        if (resource.metadata?.voiceScore != null) {
          metaParts.push(`${Math.round(resource.metadata.voiceScore * 100)}% voice match`);
        }
        metaEl.textContent = metaParts.join(' • ');
      }

      if (contentEl) {
        contentEl.textContent = resource.content || '';
      }

      if (topicLinkEl) {
        topicLinkEl.href = `/resources/${resource.industry}/${resource.topic}`;
        topicLinkEl.textContent = `Back to ${resource.topic}`;
      }

      if (statusEl) {
        statusEl.hidden = true;
      }
      if (articleEl) {
        articleEl.hidden = false;
      }
    } catch (error) {
      if (statusEl) {
        statusEl.textContent = error instanceof Error ? error.message : 'Unable to load this resource right now.';
      }
    }
  }

  loadResource();
</script>

<style>
  .resource-status {
    padding: var(--space-lg);
    border: 1px solid var(--border-light);
    border-radius: var(--border-radius);
    background: var(--surface-elevated);
    color: var(--text-secondary);
  }

  .resource-detail {
    display: grid;
    gap: var(--space-xl);
  }

  .resource-header {
    display: grid;
    gap: var(--space-sm);
  }

  .resource-kicker {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }

  .resource-description,
  .resource-meta {
    color: var(--text-secondary);
  }

  .resource-content {
    white-space: pre-wrap;
    line-height: 1.8;
    padding: var(--space-xl);
    background: var(--surface-elevated);
    border-radius: var(--border-radius);
    border: 1px solid var(--border-light);
  }

  .resource-back-link {
    margin-bottom: 0;
  }
</style>
