---
import { sitePath } from '../../src/lib/site-path';

const home = sitePath('/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Page not found — Brisbane Servers</title>
    <meta http-equiv="refresh" content={`0;url=${home}`} />
    <link rel="canonical" href={home} />
  </head>
  <body>
    <p>
      That URL is not on this site. <a href={home}>Go to Brisbane Servers</a>.
    </p>
  </body>
</html>
