---
export const prerender = true;

import SiteShell from '~/layouts/SiteShell.astro';
import Hero from '~/components/Hero.astro';
import Card from '~/components/Card.astro';
import CardGrid from '~/components/CardGrid.astro';
import SectionIntro from '~/components/SectionIntro.astro';
import SectionConstellationLayer from '~/components/SectionConstellationLayer.astro';
import MarketingPageBands from '~/components/MarketingPageBands.astro';
import SiteLink from '~/components/SiteLink.astro';
import ContributeHowItWorks from '~/components/ContributeHowItWorks.astro';
import ContributeGetStartedAuth from '~/components/ContributeGetStartedAuth.astro';
import { valueProposition } from '~/data/value-proposition';
import { resolvePublicApiUrl, resolvePublicSitePath } from '~/lib/api-config';
import '../styles/contribute-page.css';
import '../styles/portal-dashboard.css';

const currentPath = '/contribute';
const publicApiBaseUrl = resolvePublicApiUrl('');
const accountPath = resolvePublicSitePath('/account/');
const resourcesPath = resolvePublicSitePath('/resources/');
const googleOAuthHref = `${publicApiBaseUrl.replace(/\/+$/, '')}/auth/oauth/google/start`;
const { sections } = valueProposition.contribute;
---

<SiteShell
  title="Contribute"
  description={valueProposition.contribute.description}
  currentPath={currentPath}
  pageId="contribute"
  valueProfile="utility"
  zoomProfile="focused"
  density="compact"
  mainClass="main-phi-chassis"
>
  <Hero
    eyebrow="BIGPONS · Community programme"
    title="Contribute to industry resources"
    subtitle="Add field-tested context to our industry hubs. Submissions are reviewed, scored against our voice profile, and published with clear attribution to strengthen decision support across the ecosystem."
    scrollTargetId="#contribute-how-it-works"
    scrollLabel="How to contribute"
  />

  <MarketingPageBands class="marketing-page-bands--constellation-spine">
    <section class="section section-tartan-accent section-home-band--surface phi-line-symmetrical">
      <SectionConstellationLayer variant="partnership" semanticKey="contribute-programme" tier="whisper" placement="top-right" />
      <div class="bg-pattern-phi-grid bg-pattern-subtle"></div>
      <div class="phi-lateral-horizontal"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.programme.eyebrow}
          title={sections.programme.title}
          byline={sections.programme.byline}
        />
        <CardGrid columns={3} style="margin-top: var(--space-2xl);">
          <Card
            title="Why contribute"
            description="Your real-world experience helps other businesses. We combine your input with our voice framework so published guidance stays accurate, clear, and useful."
            icon="fas fa-users"
          />
          <Card
            title="Side-by-side publishing"
            description="Your submission and the curated community note appear together on topic pages, allowing readers to compare contributor context with reviewed guidance."
            icon="fas fa-columns"
          />
          <Card
            title="Moderation before live"
            description="Moderators review and adjust content before publication so quality, safety, and voice consistency remain intact."
            icon="fas fa-shield-alt"
          />
        </CardGrid>
      </div>
    </section>

    <section class="section section-tartan-accent section-home-band--primary-light">
      <SectionConstellationLayer variant="partnership" semanticKey="contribute-pipeline" tier="whisper" placement="top-left" />
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-line-vertical"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.pipeline.eyebrow}
          title={sections.pipeline.title}
          byline={sections.pipeline.byline}
        />
        <div class="contribute-blocks" style="margin-top: var(--space-2xl);">
          <div class="contribute-block">
            <h3>Your submission (A)</h3>
            <p>Your field context, constraints, and recommendations based on firsthand experience.</p>
          </div>
          <div class="contribute-block">
            <h3>Voice profile check</h3>
            <p>
              Our system compares your text to the{' '}
              <SiteLink href="/account#portal-voice-framework">portal voice framework</SiteLink> — context,
              evidence, and action in each section.
            </p>
          </div>
          <div class="contribute-block">
            <h3>Community note (B/C)</h3>
            <p>Where needed, a corrected or expanded version is prepared and displayed beside your submission on the topic page.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-tartan-accent section-home-band--surface">
      <SectionConstellationLayer variant="partnership" semanticKey="contribute-benefits" tier="whisper" placement="bottom-right" />
      <div class="bg-pattern-phi-radial bg-pattern-subtle"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.benefits.eyebrow}
          title={sections.benefits.title}
          byline={sections.benefits.byline}
        />
        <CardGrid columns={3} style="margin-top: var(--space-2xl);">
          <Card
            title="Tokens"
            description="High-quality contributions earn tokens in a single ledger, with planned use for server runtime, discounts, and future programme benefits."
            icon="fas fa-coins"
          />
          <Card
            title="Visibility"
            description="Your contribution and the reviewed community note appear on the topic page with clear attribution."
            icon="fas fa-eye"
          />
          <Card
            title="Account workspace"
            description="Sign in to view submissions, token balance, saved work, and history, while browsing remains public."
            icon="fas fa-user-circle"
          />
        </CardGrid>
      </div>
    </section>

    <section
      id="contribute-how-it-works"
      class="section section-tartan-accent section-home-band--primary-light"
    >
      <SectionConstellationLayer variant="partnership" semanticKey="contribute-how" tier="whisper" placement="top-left" />
      <div class="container">
        <ContributeHowItWorks variant="full" />
      </div>
    </section>

    <section
      id="contribute-get-started"
      class="section section-tartan-accent section-home-band--surface contribute-cta account-workspace-shell contribute-auth-shell"
    >
      <SectionConstellationLayer variant="partnership" semanticKey="contribute-cta" tier="whisper" placement="bottom-right" />
      <div class="container contribute-get-started-inner">
        <div id="contribute-get-started-intro">
          <SectionIntro
            eyebrow="New contributors"
            title="Create your contributor account"
            byline="Only if you are new — same login as /account. Submit from topic guides under Resources, not on this page."
          />
        </div>

        <ContributeGetStartedAuth
          accountPath={accountPath}
          resourcesPath={resourcesPath}
          googleOAuthHref={googleOAuthHref}
        />
        <div
          id="contribute-boot"
          hidden
          data-api-base-url={publicApiBaseUrl}
          data-account-path={accountPath}
          data-resources-path={resourcesPath}
          data-google-oauth-href={googleOAuthHref}
        ></div>
      </div>
    </section>
  </MarketingPageBands>
</SiteShell>

<script>
  import { bootContributePage } from '../scripts/contribute-page.ts';

  function bootContributeFromDom(): void {
    const root = document.getElementById('contribute-boot');
    const dataset = root?.dataset ?? {};
    bootContributePage({
      apiBaseUrl: (dataset.apiBaseUrl ?? '').replace(/\/+$/, ''),
      accountPath: dataset.accountPath ?? '/account/',
      resourcesPath: dataset.resourcesPath ?? '/resources/',
      googleOAuthHref: dataset.googleOauthHref ?? '',
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootContributeFromDom, { once: true });
  } else {
    bootContributeFromDom();
  }
</script>
