---
export const prerender = true;

import '../styles/legal-pages.css';
import SiteShell from '../layouts/SiteShell.astro';
import PageHero from '../components/PageHero.astro';
import MarketingPageBands from '../components/MarketingPageBands.astro';
import SiteLink from '../components/SiteLink.astro';
import { getPageDescriptor } from '../lib/page-descriptors';

const currentPath = '/terms-of-service';
const pageDescriptor = getPageDescriptor(currentPath);
---

<SiteShell
  title="Terms of service"
  description="Terms of use for the Brisbane Servers website, account workspace, and related tools — a BIGPONS technology project."
  currentPath={currentPath}
  pageId={pageDescriptor.pageId}
  shellVariant={pageDescriptor.shellVariant}
  valueProfile={pageDescriptor.valueProfile}
  zoomProfile={pageDescriptor.zoomProfile}
  density={pageDescriptor.density}
  mainClass="main-phi-chassis"
>
  <PageHero
    eyebrow="Legal"
    title="Terms of Service"
    lead="Last updated: March 2026. By using this website, you agree to these terms. If you do not agree, please do not use the site. This summary is general information and not a substitute for independent legal advice."
  />

    <MarketingPageBands>
    <section class="section section--continuation section-tartan-accent section-home-band--surface phi-line-symmetrical">
      <div class="container phi-measure-prose">

        <h2 class="h3 legal-h2">Use of the site</h2>
        <p class="text-content">
          You may use the public website for lawful purposes and in ways that do not damage, disable, or impair the service or others' access. We may suspend or restrict access where required to protect security, integrity, or legal compliance.
        </p>

        <h2 class="h3 legal-h2">Information and disclaimers</h2>
        <p class="text-content">
          Content on this site is provided for general information. It is not professional, financial, or technical advice for your specific circumstances. Business and technology decisions should be validated with appropriately qualified advisers.
        </p>

        <h2 class="h3 legal-h2">Accounts and workspace access</h2>
        <p class="text-content">
          Access to account workspace features and related tools may require registration. You are responsible for protecting credentials and for activity under your account. We may change, suspend, or withdraw features to maintain security and service quality.
        </p>

        <h2 class="h3 legal-h2">Intellectual property</h2>
        <p class="text-content">
          Materials on this site (including branding, text, graphics, and software) are owned by Brisbane Servers / BIGPONS or relevant licensors and are protected by law. Unless we provide express permission, do not copy, scrape, or redistribute content for commercial use.
        </p>

        <h2 class="h3 legal-h2">Limitation of liability</h2>
        <p class="text-content">
          To the maximum extent permitted under Australian law, we are not liable for indirect or consequential loss arising from site use. Where liability cannot be excluded, it is limited to resupply of the relevant service or payment of fees you paid for that service in the prior twelve months, if any.
        </p>

        <h2 class="h3 legal-h2">Governing law</h2>
        <p class="text-content">
          These terms are governed by the laws of Queensland, Australia. Courts in Queensland have non-exclusive jurisdiction.
        </p>

        <h2 class="h3 legal-h2">Changes</h2>
        <p class="text-content">
          We may update these terms from time to time. The "Last updated" date will change when revisions are made. Continued use of the site after changes constitutes acceptance of the revised terms.
        </p>

        <p class="text-content legal-nav">
          <SiteLink href="/privacy-policy">Privacy Policy</SiteLink>
          · <SiteLink href="/">Home</SiteLink>
        </p>
      </div>
    </section>
    </MarketingPageBands>
</SiteShell>
