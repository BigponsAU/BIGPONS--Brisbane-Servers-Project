                    <p><strong>Technicality:</strong> ${escapeHtml(profile.characteristics?.tone?.technicality || 'N/A')}</p>
                    <p><strong>Precision:</strong> ${escapeHtml(profile.characteristics?.tone?.precision || 'N/A')}</p>
