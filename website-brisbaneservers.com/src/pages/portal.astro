    try {
      // Use Astro API route for profiles (not Express dashboard)
      const isDev = import.meta.env.MODE === 'development';
      if (isDev) {
        console.log('[Portal] Fetching profiles from:', `${VOICE_API_URL}/profiles`);
      }
      
      const response = await fetch(`${VOICE_API_URL}/profiles`, {
        headers: {
          'Authorization': `Bearer ${authToken}`,
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        },
        credentials: 'include' // Include cookies for session auth
      });

      if (isDev) {
        console.log('[Portal] Profiles response status:', response.status);
