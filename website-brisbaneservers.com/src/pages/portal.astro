---
import SiteShell from '../layouts/SiteShell.astro';
import { industries } from '../data/industries';
import { resolvePublicApiUrl, resolvePublicSitePath } from '../lib/api-config';
import { portalVoiceFrameworkSummary, portalVoiceRules } from '../lib/portal-voice-framework';

const publicApiBaseUrl = resolvePublicApiUrl('');
const accountPath = resolvePublicSitePath('/account/');
const normalizedPathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isLegacyPortalRoute = normalizedPathname === '/portal';
const initialVerifyToken = Astro.url.searchParams.get('verify') ?? '';
const initialResetToken = Astro.url.searchParams.get('reset') ?? '';
---

<SiteShell 
  title="Account Workspace - Brisbane Servers"
  description="Secure account workspace for contributions, resources, and voice profile management"
  noindex={true}
  immediateRedirectUrl={isLegacyPortalRoute ? accountPath : undefined}
  currentPath="/account"
  pageId="account"
  shellVariant="portal"
  valueProfile="utility"
  zoomProfile="focused"
  density="compact"
  showFooter={false}
  mainClass="portal-shell"
>
    <div id="admin-portal" class="admin-portal">
      <!-- Login Screen -->
      <div id="login-screen" class="login-screen">
        <div class="login-container">
          <div class="login-grid">
            <div class="login-card">
              <h1>Account Workspace</h1>
              <p class="login-subtitle">Sign in to manage contributions, saved work, resources, and voice settings.</p>
              <p class="login-subtitle">{portalVoiceFrameworkSummary}</p>
              <p class="login-note">Browsing resources stays public. Use your account when you want to contribute, save progress, or review your workspace activity.</p>
              <div id="auth-status-banner" class="auth-status-banner" style="display: none;" role="status" aria-live="polite"></div>
              <form id="login-form" class="login-form" aria-label="Account sign-in form">
                <div class="form-group">
                  <label for="email">Email <span class="sr-only">(required)</span></label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    required 
                    autocomplete="email"
                    aria-required="true"
                    aria-describedby="email-error"
                  />
                  <span id="email-error" class="sr-only">Enter your account email address</span>
                </div>
                <div class="form-group">
                  <label for="password">Password <span class="sr-only">(required)</span></label>
                  <input 
                    type="password" 
                    id="password" 
                    name="password" 
                    required 
                    autocomplete="current-password"
                    aria-required="true"
                    aria-describedby="password-error"
                  />
                  <span id="password-error" class="sr-only">Enter your account password</span>
                </div>
                <button type="submit" class="btn btn-primary btn-block" aria-describedby="login-submit-hint">
                  Sign in
                </button>
                <span id="login-submit-hint" class="sr-only">Submit your credentials to access your account workspace</span>
                <div id="login-error" class="error-message" role="alert" aria-live="polite" aria-atomic="true"></div>
              </form>
              <form id="reset-password-form" class="login-form auth-help-form" aria-label="Reset password form" style="display: none;">
                <h3>Set a new password</h3>
                <div class="form-group">
                  <label for="reset-password">New password</label>
                  <input type="password" id="reset-password" name="password" required minlength="8" autocomplete="new-password" />
                </div>
                <button type="submit" class="btn btn-primary btn-block">Update password</button>
                <div id="reset-password-error" class="status-message" role="status" aria-live="polite"></div>
              </form>
            </div>
            <div class="login-card login-card--secondary">
              <h2>Create an account</h2>
              <p class="login-subtitle">Set up your workspace to contribute, track tokens, and keep your resources in one place.</p>
              <ul class="login-benefits">
                <li>Keep a history of submissions and accepted contributions.</li>
                <li>See your token balance and recent workspace activity.</li>
                <li>Return later to continue work without starting from scratch.</li>
              </ul>
              <form id="register-form" class="login-form" aria-label="Create account form">
                <div class="form-group">
                  <label for="register-email">Email <span class="sr-only">(required)</span></label>
                  <input
                    type="email"
                    id="register-email"
                    name="email"
                    required
                    autocomplete="email"
                    aria-required="true"
                  />
                </div>
                <div class="form-group">
                  <label for="register-password">Password <span class="sr-only">(required)</span></label>
                  <input
                    type="password"
                    id="register-password"
                    name="password"
                    required
                    minlength="8"
                    autocomplete="new-password"
                    aria-required="true"
                  />
                </div>
                <button type="submit" class="btn btn-secondary btn-block">Create account</button>
                <div id="register-error" class="error-message" role="alert" aria-live="polite" aria-atomic="true"></div>
              </form>
              <div class="auth-help-stack">
                <form id="resend-verification-form" class="login-form auth-help-form" aria-label="Resend verification email form">
                  <h3>Resend verification email</h3>
                  <div class="form-group">
                    <label for="resend-email">Email</label>
                    <input type="email" id="resend-email" name="email" required autocomplete="email" />
                  </div>
                  <button type="submit" class="btn btn-secondary btn-block">Send verification email</button>
                  <div id="resend-verification-error" class="status-message" role="status" aria-live="polite"></div>
                </form>
                <form id="forgot-password-form" class="login-form auth-help-form" aria-label="Forgot password form">
                  <h3>Forgot your password?</h3>
                  <div class="form-group">
                    <label for="forgot-email">Email</label>
                    <input type="email" id="forgot-email" name="email" required autocomplete="email" />
                  </div>
                  <button type="submit" class="btn btn-secondary btn-block">Send reset link</button>
                  <div id="forgot-password-error" class="status-message" role="status" aria-live="polite"></div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Admin Dashboard -->
      <div id="admin-dashboard" class="admin-dashboard" style="display: none;">
        <!-- Portal Layout: Sidebar + Header + Main Content -->
        <div class="portal-layout">
          <!-- Sidebar Navigation -->
          <aside id="portal-sidebar" class="portal-sidebar" role="navigation" aria-label="Account workspace navigation">
            <div class="sidebar-header">
              <div class="sidebar-header-content">
                <h2 class="sidebar-logo">Account Workspace</h2>
                <p class="sidebar-subtitle">Your contribution and content workspace</p>
              </div>
              <button id="sidebar-toggle" class="sidebar-toggle" aria-label="Toggle sidebar" aria-expanded="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </button>
            </div>
            <nav class="sidebar-nav" role="navigation">
              <div class="nav-section">
                <div class="nav-section-label">Main Navigation</div>
                <a href="#dashboard" class="sidebar-nav-item active" data-panel="dashboard" onclick="navigateToPanel('dashboard'); return false;" title="Dashboard Overview - View statistics and quick actions">
                  <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7"></rect>
                    <rect x="14" y="3" width="7" height="7"></rect>
                    <rect x="14" y="14" width="7" height="7"></rect>
                    <rect x="3" y="14" width="7" height="7"></rect>
                  </svg>
                  <div class="nav-item-content">
                    <span class="nav-label">Dashboard</span>
                    <span class="nav-description">Overview & quick actions</span>
                  </div>
                </a>
                <a href="#resources" class="sidebar-nav-item" data-panel="resources" onclick="navigateToPanel('resources'); return false;" title="Resources - Generate, upload, and manage content resources">
                  <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                  </svg>
                  <div class="nav-item-content">
                    <span class="nav-label">Resources</span>
                    <span class="nav-description">Content management</span>
                  </div>
                </a>
                <a href="#profiles" class="sidebar-nav-item" data-panel="profiles" data-min-role="editor" onclick="navigateToPanel('profiles'); return false;" title="Voice Profiles - Manage voice characteristics for content generation">
                  <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"></path>
                  </svg>
                  <div class="nav-item-content">
                    <span class="nav-label">Voice Profiles</span>
                    <span class="nav-description">Content voice settings</span>
                  </div>
                </a>
                <a href="#analytics" class="sidebar-nav-item" data-panel="analytics" data-min-role="editor" onclick="navigateToPanel('analytics'); return false;" title="Analytics - Track resource performance and statistics">
                  <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"></line>
                    <line x1="12" y1="20" x2="12" y2="4"></line>
                    <line x1="6" y1="20" x2="6" y2="14"></line>
                  </svg>
                  <div class="nav-item-content">
                    <span class="nav-label">Analytics</span>
                    <span class="nav-description">Performance metrics</span>
                  </div>
                </a>
              </div>
            </nav>
            <div class="sidebar-footer">
              <div class="sidebar-user">
                <span id="sidebar-user-info" class="user-info"></span>
              </div>
              <button id="sidebar-logout-btn" class="btn btn-secondary btn-sm btn-block">Logout</button>
            </div>
          </aside>

          <!-- Main Content Area -->
          <div class="portal-main">
            <!-- Top Header Bar -->
            <header class="portal-header">
              <div class="header-left">
                <button id="mobile-menu-toggle" class="mobile-menu-toggle" aria-label="Toggle menu">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                  </svg>
                </button>
                <div class="header-title-mobile">
                  <h1 style="margin: 0; font-size: var(--text-lg); font-weight: var(--font-weight-bold); color: var(--portal-text-primary);">Account Workspace</h1>
                </div>
                <div class="header-search">
                  <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="M21 21l-4.35-4.35"></path>
                  </svg>
                  <input type="text" id="global-search" placeholder="Search resources, profiles... (Ctrl+K)" aria-label="Global search" />
                </div>
              </div>
              <div class="header-right">
                <button id="header-info-trigger" class="btn btn-secondary btn-sm" onclick="toggleInfoCard()" aria-label="Toggle information card">
                  <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="16" x2="12" y2="12"></line>
                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                  </svg>
                  Info
                </button>
                <span id="user-info" class="user-info"></span>
                <button id="logout-btn" class="btn btn-secondary btn-sm">Logout</button>
              </div>
            </header>

            <!-- Portal Panels Container -->
            <div class="portal-panels">
              <!-- Dashboard Overview Panel (Default Landing Page) -->
              <div id="dashboard-panel" class="portal-panel active" role="main" aria-label="Dashboard overview">
                <div class="admin-content">
                  <section class="admin-section" aria-labelledby="dashboard-heading">
                    <div class="section-header">
                      <div>
                        <h2 id="dashboard-heading">Workspace Overview</h2>
                        <p class="section-subtitle">Manage your contributions, resources, voice profiles, and activity from one signed-in workspace. Use the sidebar to move between the parts that matter to you.</p>
                      </div>
                      <button id="refresh-dashboard" class="btn btn-secondary btn-sm" onclick="loadDashboardData()" aria-label="Refresh dashboard">
                        <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="23 4 23 10 17 10"></polyline>
                          <polyline points="1 20 1 14 7 14"></polyline>
                          <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                        </svg>
                        Refresh
                      </button>
                    </div>

                    <!-- Stats Grid -->
                    <div class="dashboard-stats-grid">
                      <div class="stat-card" id="dashboard-stat-total">
                        <div class="stat-icon">
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                          </svg>
                        </div>
                        <div class="stat-content">
                          <h3>Total Resources</h3>
                          <p class="stat-value" id="dashboard-total-resources">-</p>
                          <p class="stat-description">All content items</p>
                        </div>
                      </div>
                      <div class="stat-card" id="dashboard-stat-published">
                        <div class="stat-icon">
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        </div>
                        <div class="stat-content">
                          <h3>Published</h3>
                          <p class="stat-value" id="dashboard-published">-</p>
                          <p class="stat-description">Live content</p>
                        </div>
                      </div>
                      <div class="stat-card" id="dashboard-stat-drafts">
                        <div class="stat-icon">
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                          </svg>
                        </div>
                        <div class="stat-content">
                          <h3>Drafts</h3>
                          <p class="stat-value" id="dashboard-drafts">-</p>
                          <p class="stat-description">In progress</p>
                        </div>
                      </div>
                      <div class="stat-card" id="dashboard-stat-voice">
                        <div class="stat-icon">
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <circle cx="12" cy="12" r="3"></circle>
                          </svg>
                        </div>
                        <div class="stat-content">
                          <h3>Avg Voice Score</h3>
                          <p class="stat-value" id="dashboard-avg-score">-</p>
                          <p class="stat-description">Quality metric</p>
                        </div>
                      </div>
                    </div>

                    <div class="client-insights" aria-live="polite">
                      <div class="client-token-card">
                        <h3>Your contribution tokens</h3>
                        <p class="client-token-balance">
                          <span id="client-token-balance">0</span>
                          <span class="client-token-label">tokens</span>
                        </p>
                        <p class="client-token-help">
                          Tokens reflect accepted contributions and may be used for rewards in future.
                        </p>
                      </div>
                      <div class="client-contributions-card">
                        <h3>Your recent contributions</h3>
                        <ul id="client-contributions-list" class="client-contributions-list">
                          <li class="empty-state">
                            No contributions yet. Share context from a topic page to get started.
                          </li>
                        </ul>
                      </div>
                      <div class="client-contributions-card">
                        <h3>Security</h3>
                        <p class="client-token-help">Revoke all active sessions if you signed in on another machine or want to force a fresh sign-in everywhere.</p>
                        <button id="revoke-all-sessions-btn" class="btn btn-secondary btn-sm">Sign out all sessions</button>
                        <p id="revoke-all-sessions-status" class="status-message" role="status" aria-live="polite"></p>
                      </div>
                    </div>

                    <!-- Portal Purpose Guide -->
                    <div class="portal-purpose-guide">
                      <div class="purpose-card">
                        <div class="purpose-icon">
                          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                          </svg>
                        </div>
                        <div class="purpose-content">
                          <h3>What this workspace is for</h3>
                          <p>Your account workspace gives you a personal place inside Brisbane Servers. Here you can:</p>
                          <ul>
                            <li><strong>Use starter blocks:</strong> Begin with proven templates and adapt them to your business context</li>
                            <li><strong>Create and upload resources:</strong> Build new content or bring in existing material for review</li>
                            <li><strong>Track contributions:</strong> See recent submissions, token balance, and workspace activity in one place</li>
                            <li><strong>Manage voice profiles:</strong> Keep generated content aligned with the tone you want to use</li>
                            <li><strong>Review analytics:</strong> Check performance and voice alignment over time</li>
                          </ul>
                          <h4>Voice framework (delivery strategy)</h4>
                          <ul>
                            {portalVoiceRules.map((rule) => (
                              <li><strong>{rule.title}:</strong> {rule.description}</li>
                            ))}
                          </ul>
                          <p class="purpose-tip"><strong>Tip:</strong> Public browsing stays open on the main site. Sign in here when you want to contribute, save work, or manage your own workspace. Use the sidebar to switch sections, and press <kbd>Ctrl+K</kbd> (or <kbd>Cmd+K</kbd> on Mac) to search.</p>
                        </div>
                      </div>
                    </div>

                    <!-- Starter Blocks Section -->
                    <div class="dashboard-starter-blocks">
                      <div class="starter-blocks-header">
                        <div>
                          <h3>Starter Blocks</h3>
                          <p class="starter-blocks-description">Pre-built resource templates you can customize for your business. Click any block to create your own version.</p>
                        </div>
                        <button id="refresh-starter-blocks" class="btn btn-secondary btn-sm" onclick="loadStarterBlocks()" aria-label="Refresh starter blocks">
                          <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="23 4 23 10 17 10"></polyline>
                            <polyline points="1 20 1 14 7 14"></polyline>
                            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                          </svg>
                          Refresh
                        </button>
                      </div>
                      <div id="starter-blocks-grid" class="starter-blocks-grid">
                        <div class="starter-blocks-loading">Loading starter blocks...</div>
                      </div>
                    </div>

                    <!-- Quick Actions -->
                    <div class="dashboard-quick-actions">
                      <h3>Quick Actions</h3>
                      <div class="quick-actions-grid">
                        <button class="quick-action-card" onclick="navigateToPanel('resources'); setTimeout(() => document.getElementById('generate-resource-heading')?.scrollIntoView({ behavior: 'smooth' }), 100);">
                          <svg class="quick-action-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                          </svg>
                          <span class="quick-action-label">Generate Resource</span>
                        </button>
                        <button class="quick-action-card" onclick="navigateToPanel('resources'); setTimeout(() => document.getElementById('upload-resource-heading')?.scrollIntoView({ behavior: 'smooth' }), 100);">
                          <svg class="quick-action-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="17 8 12 3 7 8"></polyline>
                            <line x1="12" y1="3" x2="12" y2="15"></line>
                          </svg>
                          <span class="quick-action-label">Upload Resource</span>
                        </button>
                        <button class="quick-action-card" data-min-role="editor" onclick="navigateToPanel('profiles');">
                          <svg class="quick-action-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"></path>
                          </svg>
                          <span class="quick-action-label">Manage Profiles</span>
                        </button>
                        <button class="quick-action-card" data-min-role="editor" onclick="navigateToPanel('analytics');">
                          <svg class="quick-action-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="20" x2="18" y2="10"></line>
                            <line x1="12" y1="20" x2="12" y2="4"></line>
                            <line x1="6" y1="20" x2="6" y2="14"></line>
                          </svg>
                          <span class="quick-action-label">View Analytics</span>
                        </button>
                      </div>
                    </div>

                    <!-- Recent Activity -->
                    <div class="dashboard-recent-activity">
                      <h3>Recent Activity</h3>
                      <div id="recent-activity-list" class="activity-list">
                        <div class="activity-loading">Loading recent activity...</div>
                      </div>
                    </div>

                    <!-- Resource Preview -->
                    <div class="dashboard-resource-preview">
                      <div class="preview-header">
                        <h3>My Resources</h3>
                        <a href="#" onclick="navigateToPanel('resources'); return false;" class="preview-link">View All →</a>
                      </div>
                      <div id="recent-resources-preview" class="resources-preview-grid">
                        <div class="preview-loading">Loading resources...</div>
                      </div>
                    </div>
                  </section>
                </div>
              </div>

              <!-- Resources Panel -->
              <div id="resources-panel" class="portal-panel" role="main" aria-label="Resources management" style="display: none;">
                <div class="admin-content">

        <!-- Phi-Trailing Tartan Railing Information Card -->
        <div id="info-card" class="info-card" role="dialog" aria-labelledby="info-card-title" aria-hidden="true">
          <!-- Rail Guide (visible only when railed) -->
          <div class="info-card-rail" id="info-card-rail">
            <div class="rail-line rail-line-primary"></div>
            <div class="rail-line rail-line-secondary"></div>
            <div class="rail-line rail-line-tertiary"></div>
            <div class="rail-indicator"></div>
          </div>
          
          <!-- Tartan Overlay (covers content initially) -->
          <div class="info-card-tartan-overlay" id="info-card-tartan-overlay"></div>
          
          <!-- Card Content -->
          <div class="info-card-content">
