---
import SiteShell from '../layouts/SiteShell.astro';
import AccountSignIn from '../components/account/AccountSignIn.astro';
import AccountApiBanner from '../components/account/AccountApiBanner.astro';
import AccountWorkspaceShell from '../components/account/AccountWorkspaceShell.astro';
import AccountOverviewPanel from '../components/account/AccountOverviewPanel.astro';
import AccountResourcesPanel from '../components/account/AccountResourcesPanel.astro';
import AccountProfilesPanel from '../components/account/AccountProfilesPanel.astro';
import AccountAnalyticsPanel from '../components/account/AccountAnalyticsPanel.astro';
import AccountGrowthPanel from '../components/account/AccountGrowthPanel.astro';
import AccountModerationPanel from '../components/account/AccountModerationPanel.astro';
import AccountSiteReviewPanel from '../components/account/AccountSiteReviewPanel.astro';
import AccountResourceModals from '../components/account/AccountResourceModals.astro';
import { accountWorkspace } from '../data/account-workspace';
import { resolvePublicApiUrl, resolvePublicSitePath } from '../lib/api-config';
import '../styles/portal-workspace.css';
import '../styles/portal-dashboard.css';

const publicApiBaseUrl = resolvePublicApiUrl('');
const accountPath = resolvePublicSitePath('/account/');
const normalizedPathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isLegacyPortalRoute = normalizedPathname === '/portal';
const initialVerifyToken = Astro.url.searchParams.get('verify') ?? '';
const initialResetToken = Astro.url.searchParams.get('reset') ?? '';
---

<SiteShell
  title={`Sign in · ${accountWorkspace.productName}`}
  description="Secure account workspace for contributions, resources, and voice profile management"
  noindex={true}
  immediateRedirectUrl={isLegacyPortalRoute ? accountPath : undefined}
  currentPath="/account"
  pageId="account"
  shellVariant="marketing"
  valueProfile="utility"
  zoomProfile="focused"
  density="comfortable"
  showFooter={true}
  mainClass="main-phi-chassis account-workspace-shell"
>
  <div id="admin-portal" class="admin-portal account-workspace-root">
    <AccountSignIn />
    <AccountApiBanner />
    <AccountWorkspaceShell>
      <AccountOverviewPanel />
      <AccountResourcesPanel />
      <AccountProfilesPanel />
      <AccountAnalyticsPanel />
      <AccountGrowthPanel />
      <AccountModerationPanel />
      <AccountSiteReviewPanel />
    </AccountWorkspaceShell>
    <AccountResourceModals />
    <div id="notification-container" class="notification-container" aria-live="polite" aria-atomic="true"></div>
  </div>
</SiteShell>

<script define:vars={{ publicApiBaseUrl, accountPath, initialVerifyToken, initialResetToken }}>
  import { bootAccountWorkspace } from '../scripts/account-workspace-app.ts';
  bootAccountWorkspace({ publicApiBaseUrl, accountPath, initialVerifyToken, initialResetToken });
</script>

<script type="module">
  import { bootAccountWorkspaceExtensions } from '../scripts/account-workspace-boot.ts';
  bootAccountWorkspaceExtensions();
</script>
