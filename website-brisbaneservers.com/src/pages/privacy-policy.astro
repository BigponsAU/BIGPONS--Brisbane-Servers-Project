---
import '../styles/legal-pages.css';
import SiteShell from '../layouts/SiteShell.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import MarketingPageBands from '../components/MarketingPageBands.astro';
import { getPageDescriptor } from '../lib/page-descriptors';

const currentPath = '/privacy-policy';
const pageDescriptor = getPageDescriptor(currentPath);
const breadcrumbsTrail = [
  { label: 'Home', href: '/' },
  { label: 'Privacy Policy' },
];
---

<SiteShell
  title="Privacy Policy - Brisbane Servers"
  description="Privacy practices for the Brisbane Servers website and account workspace — cookies, analytics, retention, and your choices. BIGPONS technology project."
  currentPath={currentPath}
  breadcrumbs={breadcrumbsTrail}
  pageId={pageDescriptor.pageId}
  shellVariant={pageDescriptor.shellVariant}
  valueProfile={pageDescriptor.valueProfile}
  zoomProfile={pageDescriptor.zoomProfile}
  density={pageDescriptor.density}
  mainClass="main-phi-chassis"
>
  <PageHero
    eyebrow="Legal"
    title="Privacy Policy"
    lead="Last updated: March 2026. Brisbane Servers is operated as part of BIGPONS (ABN 93 297 393 962). This page summarises how we approach privacy on this site; it is not personal legal advice."
  />
  <Breadcrumbs items={breadcrumbsTrail} />

    <MarketingPageBands>
    <section class="section section--continuation section-tartan-accent section-home-band--surface phi-line-symmetrical">
      <div class="container phi-measure-prose">

        <h2 class="h3 legal-h2">Information we may collect</h2>
        <p class="text-content">
          Depending on how you use the site or your account workspace, we may process information you provide (for example, when you submit a form or create an account), technical data such as IP address and browser type, and usage data to keep the service secure and reliable.
        </p>

        <h2 class="h3 legal-h2">Cookies and similar technologies</h2>
        <p class="text-content">
          We use cookies and local storage where needed for essential site operation, remembering preferences (such as cookie consent), and understanding aggregate traffic. You can control cookies through your browser settings and through the cookie banner when it appears.
        </p>

        <h2 class="h3 legal-h2">Third parties</h2>
        <p class="text-content">
          Some features may rely on trusted third-party services (for example, hosting or analytics). Those providers process data under their own terms and privacy policies, in addition to the practices described here.
        </p>

        <h2 class="h3 legal-h2">Retention and security</h2>
        <p class="text-content">
          We retain information only as long as needed for the purposes described, legal obligations, or dispute resolution. We apply reasonable technical and organisational measures to protect data; no online service can guarantee absolute security.
        </p>

        <h2 class="h3 legal-h2">Your choices</h2>
        <p class="text-content">
          Where applicable, you may request access to or correction of personal information we hold, or raise a concern by contacting us using the details on the site. For Australian Privacy Principles queries, we will respond in line with applicable law.
        </p>

        <h2 class="h3 legal-h2">Contact</h2>
        <p class="text-content">
          Questions about this policy: <a href="mailto:support@brisbaneservers.com">support@brisbaneservers.com</a>
        </p>

        <p class="text-content legal-nav">
          <a href="/terms-of-service">Terms of Service</a>
          · <a href="/">Home</a>
        </p>
      </div>
    </section>
    </MarketingPageBands>
</SiteShell>
