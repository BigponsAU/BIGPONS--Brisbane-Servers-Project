---
export const prerender = true;

import '../styles/legal-pages.css';
import SiteShell from '../layouts/SiteShell.astro';
import PageHero from '../components/PageHero.astro';
import MarketingPageBands from '../components/MarketingPageBands.astro';
import SiteLink from '../components/SiteLink.astro';
import { getPageDescriptor } from '../lib/page-descriptors';

const currentPath = '/privacy-policy';
const pageDescriptor = getPageDescriptor(currentPath);
---

<SiteShell
  title="Privacy policy"
  description="Privacy practices for the Brisbane Servers website and account workspace — cookies, analytics, retention, and your choices. BIGPONS technology project."
  currentPath={currentPath}
  pageId={pageDescriptor.pageId}
  shellVariant={pageDescriptor.shellVariant}
  valueProfile={pageDescriptor.valueProfile}
  zoomProfile={pageDescriptor.zoomProfile}
  density={pageDescriptor.density}
  mainClass="main-phi-chassis"
>
  <PageHero
    eyebrow="Legal"
    title="Privacy Policy"
    lead="Last updated: March 2026. Brisbane Servers is operated by BIGPONS (ABN 93 297 393 962). This page summarises how we handle privacy across this website and related services. It is general information, not legal advice."
  />

    <MarketingPageBands>
    <section class="section section--continuation section-tartan-accent section-home-band--surface phi-line-symmetrical">
      <div class="container phi-measure-prose">

        <h2 class="h3 legal-h2">Information we may collect</h2>
        <p class="text-content">
          Depending on how you use this site or your account workspace, we may process information you provide (for example, via forms or account registration), technical data such as IP address and browser type, and usage data used to keep services secure and reliable.
        </p>

        <h2 class="h3 legal-h2">Cookies and similar technologies</h2>
        <p class="text-content">
          We use cookies and local storage for essential operation, preference management (including cookie consent), and aggregate traffic insights. You can manage cookies in your browser settings and through the cookie banner when shown.
        </p>

        <h2 class="h3 legal-h2">Third parties</h2>
        <p class="text-content">
          Some functionality relies on trusted third-party services (for example, hosting and analytics). Those providers process data under their own terms and privacy policies, alongside the practices summarised here.
        </p>

        <h2 class="h3 legal-h2">Retention and security</h2>
        <p class="text-content">
          We retain information only for as long as required for the purposes described, legal obligations, or dispute resolution. We apply reasonable technical and organisational safeguards, noting that no online service can guarantee absolute security.
        </p>

        <h2 class="h3 legal-h2">Your choices</h2>
        <p class="text-content">
          Where applicable, you may request access to or correction of personal information we hold, or raise concerns using the contact details on this site. For Australian Privacy Principles enquiries, we respond in accordance with applicable law.
        </p>

        <h2 class="h3 legal-h2">Contact</h2>
        <p class="text-content">
          Questions about this policy: <a href="mailto:support@brisbaneservers.com">support@brisbaneservers.com</a>
        </p>

        <p class="text-content legal-nav">
          <SiteLink href="/terms-of-service">Terms of Service</SiteLink>
          · <SiteLink href="/">Home</SiteLink>
        </p>
      </div>
    </section>
    </MarketingPageBands>
</SiteShell>
