---
export const prerender = true;

import '../styles/legal-pages.css';
import SiteShell from '../layouts/SiteShell.astro';
import LegalDocumentLayout from '../components/legal/LegalDocumentLayout.astro';
import LegalSection from '../components/legal/LegalSection.astro';
import { getPageDescriptor } from '../lib/page-descriptors';

const currentPath = '/privacy-policy';
const pageDescriptor = getPageDescriptor(currentPath);

const toc = [
  { id: 'collection', number: 1, title: 'What we collect' },
  { id: 'how-we-collect', number: 2, title: 'How we collect' },
  { id: 'why-we-use', number: 3, title: 'Why we use data' },
  { id: 'disclosure', number: 4, title: 'Disclosure' },
  { id: 'security-retention', number: 5, title: 'Security & retention' },
  { id: 'your-rights', number: 6, title: 'Your rights' },
  { id: 'cookies', number: 7, title: 'Cookies & tracking' },
];
---

<SiteShell
  title="Privacy policy"
  description="How BIGPONS collects, uses, and protects personal information for brisbaneservers.com and the account workspace — Australian Privacy Principles, cookies, retention, and your rights."
  currentPath={currentPath}
  pageId={pageDescriptor.pageId}
  shellVariant={pageDescriptor.shellVariant}
  valueProfile={pageDescriptor.valueProfile}
  zoomProfile={pageDescriptor.zoomProfile}
  density={pageDescriptor.density}
  mainClass="main-phi-chassis"
>
  <LegalDocumentLayout
    eyebrow="Legal · BIGPONS"
    title="Privacy Policy"
    lead="BIGPONS respects your privacy and is committed to protecting personal information when you use brisbaneservers.com and the associated account workspace."
    lastUpdated="June 2026"
    framework="Privacy Act 1988 (Cth) · APPs"
    operatorNote="BIGPONS · ABN 93 297 393 962"
    toc={toc}
    relatedHref="/terms-of-service"
    relatedTitle="Terms of Service"
    relatedDescription="Eligibility, acceptable use, user content, AI features, and platform agreements."
  >
    <LegalSection id="collection" number={1} title="What Personal Information We Collect">
      <ul class="legal-list">
        <li><strong>Account information:</strong> name, email address, password (hashed), organisation details, role (client/editor/admin), contact phone.</li>
        <li><strong>Usage &amp; technical data:</strong> IP address, browser/device information, login timestamps, navigation within the workspace, feature usage (resources created, voice profiles used, analytics viewed).</li>
        <li><strong>User-generated content:</strong> documents uploaded for OCR/rewrite, text/paste content, voice profile data (corpus, rings, matrix, recordings if any), resource metadata and content you create or contribute.</li>
        <li><strong>Analytics &amp; performance data:</strong> corpus statistics, suggestion interactions, pipeline configuration choices (non-identifying where possible).</li>
        <li><strong>Moderation &amp; admin data:</strong> flags, review notes, and actions taken on content (for users with appropriate roles).</li>
      </ul>
    </LegalSection>

    <LegalSection id="how-we-collect" number={2} title="How We Collect Personal Information">
      <p class="text-content">
        Directly from you when you create an account, sign in (email, Google, passkeys), upload content, create resources or voice profiles, or contact us. Automatically through cookies, server logs, and platform analytics when you use the site and workspace. From third-party sign-in providers (Google, passkey providers) with your consent.
      </p>
    </LegalSection>

    <LegalSection id="why-we-use" number={3} title="Why We Collect and Use Personal Information">
      <p class="text-content">
        To provide and improve the account workspace and Local Data Pipeline Solutions; to authenticate users and enforce role-based access; to enable core features (resource management, voice studio, OCR, analytics, moderation); to communicate with you about your account, updates, or support; to maintain platform security, prevent abuse, and comply with legal obligations; to analyse usage for product improvement and to support our recurring revenue and infrastructure scaling plans; and to meet grant, tender, or regulatory reporting requirements where applicable.
      </p>
    </LegalSection>

    <LegalSection id="disclosure" number={4} title="Disclosure of Personal Information">
      <p class="text-content">
        We may disclose personal information to: service providers who help us operate the platform (hosting, analytics, email delivery) under confidentiality obligations; moderators or admins within BIGPONS for content review and platform governance; law enforcement or regulators where required by law; and in connection with a business transition (e.g. Pty Ltd incorporation) with appropriate protections. We do not sell personal information. Some processing occurs via Cloudflare (edge infrastructure) — overseas disclosure is limited to what is necessary for service delivery and subject to APP 8 requirements.
      </p>
    </LegalSection>

    <LegalSection id="security-retention" number={5} title="Data Security &amp; Retention">
      <p class="text-content">
        We take reasonable steps to protect personal information from misuse, interference, loss, unauthorised access, modification or disclosure. This includes encryption in transit, access controls, role-based permissions, and secure coding practices. We retain personal information only as long as necessary for the purposes described or as required by law. You may request deletion of your account and associated data (subject to legal or legitimate business retention needs, e.g. moderation records).
      </p>
    </LegalSection>

    <LegalSection id="your-rights" number={6} title="Your Rights &amp; Access">
      <p class="text-content">
        You may request access to, or correction of, your personal information held by us. You may also complain about a breach of the APPs. Contact us at <a href="mailto:bigpons@brisbaneservers.com">bigpons@brisbaneservers.com</a> or <a href="tel:+61490478864">0490 478 864</a>. If you are not satisfied with our response, you may complain to the Office of the Australian Information Commissioner (OAIC) at <a href="https://www.oaic.gov.au" rel="noopener noreferrer">www.oaic.gov.au</a>.
      </p>
    </LegalSection>

    <LegalSection id="cookies" number={7} title="Cookies &amp; Tracking">
      <p class="text-content">
        We use essential cookies for authentication, session management, and security. We may use analytics cookies to understand usage patterns and improve the platform. You can control non-essential cookies through your browser settings, though this may affect functionality.
      </p>
    </LegalSection>
  </LegalDocumentLayout>
</SiteShell>
