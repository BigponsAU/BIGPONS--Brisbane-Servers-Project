---
export const prerender = true;

import SiteShell from '~/layouts/SiteShell.astro';
import InquiryForm from '~/components/InquiryForm.astro';
import { getPageDescriptor } from '~/lib/page-descriptors';
import { sitePath } from '~/lib/site-path';

const currentPath = '/resources/item';
const pageDescriptor = getPageDescriptor(currentPath);
---

<SiteShell
  title="Resource detail"
  description="Browse Brisbane Servers industry resources or open a published resource from its topic page."
  noindex={true}
  currentPath={currentPath}
  pageId={pageDescriptor.pageId}
  shellVariant={pageDescriptor.shellVariant}
  valueProfile={pageDescriptor.valueProfile}
  zoomProfile={pageDescriptor.zoomProfile}
  density={pageDescriptor.density}
  mainClass="main-phi-chassis"
>
  <section class="section">
    <div class="container">
      <div id="resource-detail-status" class="resource-detail-status">
        Redirecting to the published resource…
      </div>
      <p>
        If you are not redirected, <a href={sitePath('/resources')}>browse all resources</a>.
      </p>
    </div>
  </section>

  <InquiryForm
    title="Discuss this resource"
    subtitle="Share your industry context and objectives. We clarify practical implications, constraints, and next steps."
  />
</SiteShell>

<script>
  const params = new URLSearchParams(window.location.search);
  const resourceId = params.get('id');
  if (resourceId) {
    const target = `${window.location.pathname.replace(/\/?$/, '')}/${encodeURIComponent(resourceId)}`;
    window.location.replace(target);
  } else {
    const statusEl = document.getElementById('resource-detail-status');
    if (statusEl) {
      statusEl.textContent = 'No resource id was provided.';
      statusEl.setAttribute('data-error', 'true');
    }
  }
</script>

<style>
  .resource-detail-status {
    padding: var(--space-lg);
    border: 1px solid var(--border-light);
    border-radius: var(--border-radius);
    background: var(--surface-elevated);
    color: var(--text-secondary);
    margin-bottom: var(--space-md);
  }

  .resource-detail-status[data-error='true'] {
    border-color: var(--border-accent);
    color: var(--primary-dark);
  }
</style>
