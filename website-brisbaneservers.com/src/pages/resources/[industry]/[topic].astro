---
import SiteShell from '~/layouts/SiteShell.astro';
import Hero from '~/components/Hero.astro';
import InquiryForm from '~/components/InquiryForm.astro';
import SemanticText from '~/components/SemanticText.astro';
import MarketingPageBands from '~/components/MarketingPageBands.astro';
import TopicGuideArticle from '~/components/TopicGuideArticle.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import { getIndustryBySlug, getTopicBySlug, industries } from '~/data/industries';
import { getTopicGuide, isSubstantiveApiResource } from '~/data/topic-guides';
import { topicHeroTitle, topicHeroSubtitle, topicOpportunityCards } from '~/data/resource-hub-copy';
import { valueProposition } from '~/data/value-proposition';
import { resolvePublicApiUrl } from '~/lib/api-config';
import { topicGuidePageTitle, topicGuideSeo } from '~/lib/content-seo';
import { sitePath } from '~/lib/site-path';
import { getPublishedResourcesForPage } from '~/lib/public-published-resources';
import '~/styles/topic-guide.css';

export async function getStaticPaths() {
  const paths: Array<{ params: { industry: string; topic: string } }> = [];

  industries.forEach((industry) => {
    industry.topics.forEach((topic) => {
      paths.push({
        params: {
          industry: industry.slug,
          topic: topic.slug,
        },
      });
    });
  });

  return paths;
}

const { industry: industrySlug, topic: topicSlug } = Astro.params;
const industry = getIndustryBySlug(industrySlug!);
const topic = getTopicBySlug(industrySlug!, topicSlug!);

if (!industry || !topic) {
  return Astro.redirect('/resources');
}

const publicApiBaseUrl = resolvePublicApiUrl('');
const publishedResources = await getPublishedResourcesForPage({
  industry: industrySlug!,
  topic: topicSlug!,
});
const apiSupplements = publishedResources.filter(isSubstantiveApiResource);

const currentPath = `/resources/${industrySlug}/${topicSlug}`;
const topicGuide = getTopicGuide(industrySlug!, topicSlug!);
const opportunityCards = topicOpportunityCards(topic, industry);
const industryHubHref = sitePath(`/resources/${industry.slug}`);
const siteOrigin = (Astro.site ?? new URL('https://brisbaneservers.com')).origin;
const topicHeadline = topicHeroTitle(topic, industry);
const { structuredData, breadcrumbs: breadcrumbItems } = topicGuideSeo(
  industry,
  topic,
  topicHeadline,
  siteOrigin,
  import.meta.env.BASE_URL,
);
---

<SiteShell
  title={topicGuidePageTitle(topic, industry)}
  description={topic.description}
  ogType="article"
  structuredData={structuredData}
  currentPath={currentPath}
  pageId="resource-topic"
  valueProfile="evidence"
  zoomProfile="focused"
  mainClass="main-phi-chassis"
>
  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    class="hero--guide-lead"
    eyebrow={`${valueProposition.resources.topicEyebrow} · ${industry.name}`}
    title={topicHeroTitle(topic, industry)}
    subtitle={topicGuide?.proposition ?? topicHeroSubtitle(topic, industry)}
    ctaText="Read guide"
    ctaHref="#topic-content"
    secondaryCtaText={`${industry.name} hub`}
    secondaryCtaHref={industryHubHref}
  />

    <MarketingPageBands class="marketing-page-bands--guide">
    <section
      id="topic-content"
      class="section section-tartan-accent topic-guide-page"
    >
      <div class="bg-pattern-phi-grid bg-pattern-soft"></div>
      <div class="phi-line-vertical phi-line-vertical-inv"></div>
      <div class="container container--guide-wide">
        {topicGuide ? (
          <TopicGuideArticle
            guide={topicGuide}
            industryName={industry.name}
            topicName={topic.name}
            opportunityCards={opportunityCards}
            hideLede={true}
          />
        ) : (
          <p class="section-description">
            <SemanticText text={topic.description} semanticLevel="normal" isChild={true} />
          </p>
        )}

        {apiSupplements.length > 0 && (
          <details class="topic-guide-supplement">
            <summary>
              <SemanticText text="Additional published notes" semanticLevel="high" isParent={true} />
            </summary>
            <div class="topic-guide-supplement__list">
              {apiSupplements.map((resource) => (
                <article class="topic-guide-supplement__item" id={`resource-${resource.id}`}>
                  <h3>{resource.title}</h3>
                  <p>{resource.description}</p>
                  <a href={sitePath(`/resources/item/${resource.id}`)} class="btn btn-secondary btn-sm">
                    Open full entry
                  </a>
                </article>
              ))}
            </div>
          </details>
        )}
      </div>
    </section>

    <div class="guide-page-tail">
      <div class="container container--guide-wide">
        <nav class="guide-page-tail__nav" aria-label="Guide navigation">
          <a href={industryHubHref} class="guide-page-tail__nav-link guide-page-tail__nav-link--back">
            ← {industry.name} hub
          </a>
          <span class="guide-page-tail__nav-sep" aria-hidden="true">·</span>
          <a href={sitePath('/resources')} class="guide-page-tail__nav-link">
            All resources
          </a>
        </nav>
      </div>

      <section class="guide-page-tail__community" aria-labelledby="guide-community-heading">
        <div class="container container--guide-wide">
          <details class="topic-guide-community__details">
            <summary class="topic-guide-community__summary" id="guide-community-heading">
              <SemanticText text="Community perspectives (optional)" semanticLevel="high" isParent={true} />
            </summary>
            <p class="guide-page-tail__community-lead">
              <SemanticText
                text="Operators who have lived this topic can add field context. Contributions are reviewed for accuracy."
                semanticLevel="normal"
                isChild={true}
              />
            </p>

            <div id="community-contribution-callout" class="community-contribution-callout">
              <p class="community-contribution-message">
                To contribute, <a href={sitePath('/account/')}>sign in to your account</a> (Google or email) to unlock the form below.
              </p>
              <a href={sitePath('/account/')} class="btn btn-primary btn-sm">Sign in</a>
            </div>

            <div id="community-contribution-form" class="community-contribution-form" data-visible="false">
              <h3>Share your perspective</h3>
              <form id="community-upload-form" action="javascript:void(0)" aria-label="Community contribution form">
                <div class="form-grid">
                  <label>
                    <span>Title (optional)</span>
                    <input type="text" name="title" placeholder={`Your angle on ${topic.name}`} />
                  </label>
                  <label class="full-width">
                    <span>Your experience or insights</span>
                    <textarea
                      name="content"
                      rows="5"
                      placeholder={`Practical details on ${topic.name} in ${industry.name} — constraints, costs, outcomes.`}
                      required></textarea>
                  </label>
                </div>
                <div class="form-actions">
                  <button type="submit" class="btn btn-secondary">Submit contribution</button>
                  <span id="community-upload-status" class="form-status" aria-live="polite"></span>
                </div>
              </form>
            </div>

            <div id="community-contributions-list" class="community-contributions-list" aria-live="polite"></div>
          </details>
        </div>
      </section>

      <InquiryForm
        id="inquiry-section"
        title={`Discuss ${topic.name}`}
        subtitle={`Share your ${industry.name} context and goals. ${valueProposition.inquiry.subtitle}`}
        defaultIndustry={industry.name}
      />
    </div>
  </MarketingPageBands>
</SiteShell>

<style>
  .topic-guide-supplement {
    margin-top: var(--space-2xl);
    padding: var(--space-lg);
    border: 1px dashed var(--border-subtle);
    border-radius: var(--border-radius);
    background: var(--surface-subtle);
  }

  .topic-guide-supplement summary {
    cursor: pointer;
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .topic-guide-supplement__list {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .topic-guide-supplement__item h3 {
    margin: 0 0 var(--space-xs);
    font-size: var(--text-base);
  }

  .topic-guide-supplement__item p {
    margin: 0 0 var(--space-md);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .form-grid {
    display: grid;
    gap: var(--space-md);
  }

  .form-grid label {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    font-size: var(--text-sm);
  }

  .form-actions {
    margin-top: var(--space-md);
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .form-status {
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }
</style>

<script define:vars={{ apiBaseUrl: publicApiBaseUrl, industrySlug, topicSlug }}>
  if (typeof window !== 'undefined') {
    const industry = industrySlug;
    const topic = topicSlug;

    const contributionFormContainer = document.getElementById('community-contribution-form');
    const callout = document.getElementById('community-contribution-callout');
    const statusEl = document.getElementById('community-upload-status');
    const listEl = document.getElementById('community-contributions-list');

    async function checkAuthAndToggleForm() {
      try {
        const res = await fetch(`${apiBaseUrl}/auth/me`, {
          credentials: 'include',
          headers: { Accept: 'application/json' }
        });
        if (!res.ok) {
          contributionFormContainer?.setAttribute('data-visible', 'false');
          return;
        }
        const data = await res.json();
        if (data?.user && contributionFormContainer && callout) {
          contributionFormContainer.setAttribute('data-visible', 'true');
          callout.style.display = 'none';
        }
      } catch {
        /* ignore */
      }
    }

    async function loadCommunityPairs() {
      if (!listEl) return;
      listEl.innerHTML = '<p class="form-status">Loading…</p>';
      try {
        const res = await fetch(
          `${apiBaseUrl}/community/by-topic?industry=${encodeURIComponent(industry)}&topic=${encodeURIComponent(topic)}`
        );
        if (!res.ok) {
          listEl.innerHTML = '';
          return;
        }
        const data = await res.json();
        const items = data?.items || [];
        if (!items.length) {
          listEl.innerHTML = '<p class="form-status">No published contributions yet.</p>';
          return;
        }
        listEl.innerHTML = '';
        items.forEach((pair) => {
          const el = document.createElement('article');
          el.className = 'topic-guide-supplement__item';
          el.innerHTML = `<p>${pair.contribution.payload.contentSnippet || pair.resource.description || ''}</p>`;
          listEl.appendChild(el);
        });
      } catch {
        listEl.innerHTML = '';
      }
    }

    const form = document.getElementById('community-upload-form');
    if (form && statusEl) {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        statusEl.textContent = 'Submitting…';
        const formData = new FormData(form);
        const payload = {
          title: formData.get('title') || undefined,
          content: formData.get('content'),
          industry,
          topic,
        };
        try {
          const res = await fetch(`${apiBaseUrl}/resources/community-upload`, {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (res.ok && data.success) {
            statusEl.textContent = 'Thank you — recorded for review.';
            form.reset();
            loadCommunityPairs();
          } else {
            statusEl.textContent = data.error || 'Unable to submit.';
          }
        } catch {
          statusEl.textContent = 'Network error.';
        }
      });
    }

    checkAuthAndToggleForm();
    loadCommunityPairs();
  }
</script>
