---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import Hero from '~/components/Hero.astro';
import Card from '~/components/Card.astro';
import CardGrid from '~/components/CardGrid.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import InquiryForm from '~/components/InquiryForm.astro';
import SemanticText from '~/components/SemanticText.astro';
import { getIndustryBySlug, getTopicBySlug, industries } from '~/data/industries';
import { getInternalFetchOrigin } from '~/lib/server-origin';

export async function getStaticPaths() {
  const paths: Array<{ params: { industry: string; topic: string } }> = [];
  
  industries.forEach((industry) => {
    industry.topics.forEach((topic) => {
      paths.push({
        params: {
          industry: industry.slug,
          topic: topic.slug
        }
      });
    });
  });
  
  return paths;
}

const { industry: industrySlug, topic: topicSlug } = Astro.params;
const industry = getIndustryBySlug(industrySlug!);
const topic = getTopicBySlug(industrySlug!, topicSlug!);

if (!industry || !topic) {
  return Astro.redirect('/resources');
}

// Fetch published resources from API (using Astro API routes)
const API_URL = '/api';
let publishedResources: any[] = [];

try {
  const baseUrl = getInternalFetchOrigin(Astro);
  const response = await fetch(`${baseUrl}${API_URL}/resources/public?industry=${industrySlug}&topic=${topicSlug}`, {
    headers: {
      'Accept': 'application/json'
    }
  });
  
  if (response.ok) {
    const data = await response.json();
    publishedResources = data.resources || [];
  } else {
    console.warn('[Resources] API returned non-OK status:', response.status);
  }
} catch (error) {
  // Silently fail - fallback to static content
  console.warn('[Resources] Could not fetch resources from API, using static content:', error);
}

const currentPath = `/resources/${industrySlug}/${topicSlug}`;
const hasGeneratedContent = publishedResources.length > 0;
const primaryResource = publishedResources[0] || null;

// Community contributions for this topic are loaded client-side via API.
---

<BaseLayout 
  title={`${topic.name} - ${industry.name} Resources - Brisbane Servers`}
  description={topic.description}
>
  <Header currentPath={currentPath} />
  
  <main>
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Resources', href: '/resources' },
      { label: industry.name, href: `/resources/${industry.slug}` },
      { label: topic.name }
    ]} />
    
    <Hero 
      title={topic.name}
      subtitle={topic.description}
    />

    <!-- Comprehensive block usage: phi-line-vertical, phi-lateral-angular-2, bg-pattern-angular -->
    <section class="section">
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-line-vertical"></div>
      <div class="phi-lateral-angular-2"></div>
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="Overview" semanticLevel="high" isParent={true} />
        </h2>
        
        {hasGeneratedContent && primaryResource ? (
          <>
            <div class="section-description" style="white-space: pre-wrap; line-height: 1.8;">
              <SemanticText text={primaryResource.content} semanticLevel="normal" isChild={true} />
            </div>
            {primaryResource.metadata?.voiceScore && (
              <div style="margin-top: var(--space-lg); padding: var(--space-md); background: var(--surface-elevated); border-radius: var(--border-radius); border-left: 4px solid var(--primary-color);">
                <p style="margin: 0; font-size: var(--text-sm); color: var(--text-secondary);">
                  <strong>Voice Consistency:</strong> {Math.round(primaryResource.metadata.voiceScore * 100)}% match with Brisbane Servers voice profile
                </p>
              </div>
            )}
            <div style="margin-top: var(--space-lg);">
              <a href={`/resources/item/${primaryResource.id}`} class="btn btn-secondary">
                View Full Resource →
              </a>
            </div>
          </>
        ) : (
          <p class="section-description">
            <SemanticText text={topic.description} semanticLevel="normal" isChild={true} />
          </p>
        )}
        
        <CardGrid style="margin-top: var(--space-2xl);">
          <Card
            title="Key Considerations"
            description="Understanding your business context, size, and constraints helps identify solutions that actually work. We assess your reality and recommend what makes sense for your situation."
          />
          
          <Card
            title="Implementation Approach"
            description="Phased implementation, grant-assisted when available, tailored to your value framework. Not one-size-fits-all—genuine customization."
          />
        </CardGrid>
        
        {publishedResources.length > 1 && (
          <>
            <h2 class="section-title" style="margin-top: var(--space-4xl);">
              <SemanticText text="Additional Resources" semanticLevel="high" isParent={true} />
            </h2>
            <div class="resources-list">
              {publishedResources.slice(1).map((resource) => (
                <div class="resource-item" id={`resource-${resource.id}`}>
                  <details class="resource-details">
                    <summary class="resource-summary">
                      <div class="resource-header">
                        <h3 class="resource-title">{resource.title}</h3>
                        {resource.metadata?.voiceScore && (
                          <span class="voice-score-badge" title="Voice Match Score">
                            {Math.round(resource.metadata.voiceScore * 100)}% match
                          </span>
                        )}
                      </div>
                      <p class="resource-description">{resource.description}</p>
                    </summary>
                    <div class="resource-content">
                      <div style="white-space: pre-wrap; line-height: 1.8; margin-top: var(--space-lg);">
                        <SemanticText text={resource.content} semanticLevel="normal" isChild={true} />
                      </div>
                      {resource.metadata?.voiceScore && (
                        <div style="margin-top: var(--space-lg); padding: var(--space-md); background: var(--surface-elevated); border-radius: var(--border-radius); border-left: 4px solid var(--primary-color);">
                          <p style="margin: 0; font-size: var(--text-sm); color: var(--text-secondary);">
                            <strong>Voice Consistency:</strong> {Math.round(resource.metadata.voiceScore * 100)}% match with Brisbane Servers voice profile
                          </p>
                        </div>
                      )}
                      <div style="margin-top: var(--space-lg);">
                        <a href={`/resources/item/${resource.id}`} class="btn btn-secondary btn-sm">
                          View Full Resource →
                        </a>
                      </div>
                    </div>
                  </details>
                </div>
              ))}
            </div>
          </>
        )}
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="Community Contributions" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText
            text="Clients and community members can add their experience and context here. Our voice framework helps align contributions with accurate, helpful information."
            semanticLevel="normal"
            isChild={true}
          />
        </p>

        <div id="community-contribution-callout" class="community-contribution-callout">
          <p class="community-contribution-message">
            To contribute your perspective on this topic, register or log in. You can
            <a href="/contribute">create an account or sign in</a> to unlock the contribution form here and earn tokens.
          </p>
          <a href="/contribute" class="btn btn-primary btn-sm">Register or log in</a>
        </div>

        <div id="community-contribution-form" class="community-contribution-form" data-visible="false">
          <h3>Share your perspective</h3>
          <form id="community-upload-form">
            <div class="form-grid">
              <label>
                <span>Title (optional)</span>
                <input type="text" name="title" placeholder={`Your angle on ${topic.name}`} />
              </label>
              <label class="full-width">
                <span>Your experience or insights</span>
                <textarea
                  name="content"
                  rows="5"
                  placeholder={`Describe your experience with ${topic.name} in ${industry.name}. Practical details are especially helpful.`}
                  required
                ></textarea>
              </label>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-secondary">Submit contribution</button>
              <span id="community-upload-status" class="form-status" aria-live="polite"></span>
            </div>
          </form>
        </div>

        <div id="community-contributions-list" class="community-contributions-list" aria-live="polite">
          <!-- Filled client-side from /api/community/by-topic -->
        </div>
      </div>
    </section>

    <InquiryForm 
      title={`Questions about ${topic.name}?`}
      subtitle={`We're experts in ${industry.name} technology—informal questions welcome.`}
      defaultIndustry={industry.name}
    />
  </main>

  <Footer />
</BaseLayout>

<style>
  .resources-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }

  .resource-item {
    background: var(--surface-elevated);
    border-radius: var(--border-radius);
    border: var(--phi-line-width) solid var(--border-light);
    overflow: hidden;
    transition: var(--transition);
  }

  .resource-item:hover {
    box-shadow: var(--card-shadow-hover);
    border-color: var(--primary-color);
  }

  .resource-details {
    width: 100%;
  }

  .resource-summary {
    padding: var(--space-lg);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .resource-summary::-webkit-details-marker {
    display: none;
  }

  .resource-summary::marker {
    display: none;
  }

  .resource-summary::before {
    content: '▶';
    display: inline-block;
    margin-right: var(--space-sm);
    transition: transform 0.2s ease;
    color: var(--primary-color);
  }

  .resource-details[open] .resource-summary::before {
    transform: rotate(90deg);
  }

  .resource-header {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .resource-title {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    margin: 0;
    flex: 1;
  }

  .voice-score-badge {
    font-size: var(--text-sm);
    padding: var(--space-xs) var(--space-sm);
    background: var(--primary-light);
    color: var(--primary-dark);
    border-radius: var(--border-radius-sm);
    white-space: nowrap;
    font-weight: var(--font-weight-medium);
  }

  .resource-description {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin: 0;
    line-height: calc(1em * var(--phi));
  }

  .resource-content {
    padding: 0 var(--space-lg) var(--space-lg) var(--space-lg);
    border-top: var(--phi-line-width) solid var(--border-light);
    margin-top: var(--space-md);
    padding-top: var(--space-lg);
  }

  @media (max-width: 768px) {
    .resource-header {
      flex-direction: column;
      align-items: start;
    }

    .voice-score-badge {
      align-self: flex-start;
    }
  }

  .community-contribution-callout {
    margin-top: var(--space-2xl);
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    border: 1px dashed var(--border-subtle);
    background: var(--surface-subtle);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
  }

  .community-contribution-message {
    margin: 0;
    flex: 1;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .community-contribution-form {
    margin-top: var(--space-2xl);
    padding: var(--space-xl);
    border-radius: var(--border-radius);
    border: 1px solid var(--border-light);
    background: var(--surface-elevated);
    display: none;
  }

  .community-contribution-form[data-visible="true"] {
    display: block;
  }

  .community-contribution-form h3 {
    margin-top: 0;
    margin-bottom: var(--space-md);
  }

  .community-contributions-list {
    margin-top: var(--space-2xl);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-lg);
  }

  .community-contribution-pair {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-md);
    border-radius: var(--border-radius);
    border: 1px solid var(--border-subtle);
    background: var(--surface-elevated);
    padding: var(--space-lg);
  }

  .community-card {
    border-radius: var(--border-radius);
    padding: var(--space-md);
    background: var(--surface-subtle);
  }

  .community-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .community-card-title {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
  }

  .community-badge {
    font-size: var(--text-xs);
    padding: 2px 6px;
    border-radius: 999px;
    background: var(--primary-light);
    color: var(--primary-dark);
    white-space: nowrap;
  }

  .community-card-body {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    white-space: pre-wrap;
  }

  .form-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-md);
  }

  .form-grid label {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    font-size: var(--text-sm);
  }

  .form-grid .full-width {
    grid-column: 1 / -1;
  }

  .form-actions {
    margin-top: var(--space-md);
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .form-status {
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }
</style>

<script>
  if (typeof window !== 'undefined') {
    const industry = {industrySlug};
    const topic = {topicSlug};

    const contributionFormContainer = document.getElementById('community-contribution-form');
    const callout = document.getElementById('community-contribution-callout');
    const statusEl = document.getElementById('community-upload-status');
    const listEl = document.getElementById('community-contributions-list');

    async function checkAuthAndToggleForm() {
      try {
        const res = await fetch('/api/auth/me', { headers: { Accept: 'application/json' } });
        if (!res.ok) {
          if (contributionFormContainer) {
            contributionFormContainer.setAttribute('data-visible', 'false');
          }
          return;
        }
        const data = await res.json();
        if (data?.user && contributionFormContainer && callout) {
          contributionFormContainer.setAttribute('data-visible', 'true');
          callout.style.display = 'none';
        }
      } catch {
        // Ignore auth errors on public page
      }
    }

    async function loadCommunityPairs() {
      if (!listEl) return;
      listEl.innerHTML = '<p class="form-status">Loading community contributions…</p>';
      try {
        const res = await fetch(
          `/api/community/by-topic?industry=${encodeURIComponent(
            industry
          )}&topic=${encodeURIComponent(topic)}`
        );
        if (!res.ok) {
          listEl.innerHTML = '';
          return;
        }
        const data = await res.json();
        const items = data?.items || [];
        if (!items.length) {
          listEl.innerHTML =
            '<p class="form-status">No community contributions have been published for this topic yet.</p>';
          return;
        }

        listEl.innerHTML = '';
        items.forEach((pair: any) => {
          const wrapper = document.createElement('div');
          wrapper.className = 'community-contribution-pair';

          const originalCard = document.createElement('div');
          originalCard.className = 'community-card';
          originalCard.innerHTML = `
            <div class="community-card-header">
              <h4 class="community-card-title">Client submission</h4>
              <span class="community-badge">${pair.contribution.status}</span>
            </div>
            <div class="community-card-body">
              ${pair.contribution.payload.contentSnippet || ''}
            </div>
          `;

          const communityCard = document.createElement('div');
          communityCard.className = 'community-card';
          const vs = pair.resource.metadata?.voiceScore;
          const scoreText = typeof vs === 'number' ? `${Math.round(vs * 100)}% match` : '';
          communityCard.innerHTML = `
            <div class="community-card-header">
              <h4 class="community-card-title">Community note</h4>
              ${
                scoreText
                  ? `<span class="community-badge" title="Voice match score">${scoreText}</span>`
                  : ''
              }
            </div>
            <div class="community-card-body">
              ${pair.resource.description || ''}
            </div>
          `;

          wrapper.appendChild(originalCard);
          wrapper.appendChild(communityCard);
          listEl.appendChild(wrapper);
        });
      } catch {
        listEl.innerHTML = '';
      }
    }

    const form = document.getElementById('community-upload-form') as HTMLFormElement | null;
    if (form && statusEl) {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        statusEl.textContent = 'Submitting…';

        const formData = new FormData(form);
        const payload = {
          title: formData.get('title') || undefined,
          content: formData.get('content'),
          industry,
          topic
        };

        try {
          const res = await fetch('/api/resources/community-upload', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(payload)
          });
          const data = await res.json();
          if (res.ok && data.success) {
            statusEl.textContent =
              'Thank you – your contribution has been recorded and may appear here after review.';
            form.reset();
            loadCommunityPairs();
          } else {
            statusEl.textContent = data.error || 'Unable to submit contribution right now.';
          }
        } catch {
          statusEl.textContent = 'Network error while submitting contribution.';
        }
      });
    }

    checkAuthAndToggleForm();
    loadCommunityPairs();
  }
</script>
