---
// Published resources can now be pulled from the standalone API during prerender.
import SiteShell from '~/layouts/SiteShell.astro';
import Hero from '~/components/Hero.astro';
import Card from '~/components/Card.astro';
import CardGrid from '~/components/CardGrid.astro';
import InquiryForm from '~/components/InquiryForm.astro';
import SemanticText from '~/components/SemanticText.astro';
import { getIndustryBySlug, industries } from '~/data/industries';
import { resolveInternalApiUrl } from '~/lib/api-config';

export async function getStaticPaths() {
  return industries.map((industry) => ({
    params: { industry: industry.slug }
  }));
}

const { industry: industrySlug } = Astro.params;
const industry = getIndustryBySlug(industrySlug!);

if (!industry) {
  return Astro.redirect('/resources');
}

// Fetch published resources from the standalone API so the route can be prerendered.
const publicResourcesUrl = resolveInternalApiUrl(`/resources/public?industry=${encodeURIComponent(industrySlug!)}`);
let publishedResources: any[] = [];

try {
  const response = await fetch(publicResourcesUrl, {
    headers: {
      'Accept': 'application/json'
    }
  });
  
  if (response.ok) {
    const data = await response.json();
    publishedResources = data.resources || [];
  } else {
    console.warn('[Resources] API returned non-OK status:', response.status);
  }
} catch (error) {
  // Silently fail - resources section will be hidden if no resources
  console.warn('[Resources] Could not fetch resources from API:', error);
}

const currentPath = `/resources/${industrySlug}`;
---

<SiteShell 
  title={`${industry.name} Resources - Brisbane Servers`}
  description={industry.description}
  currentPath={currentPath}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Resources', href: '/resources' },
    { label: industry.name }
  ]}
  pageId="resource-industry"
  valueProfile="evidence"
  zoomProfile="focused"
>
    <Hero 
      title={`${industry.name} Technology Solutions`}
      subtitle={industry.description}
    />

    <!-- Comprehensive block usage: phi-line-vertical, phi-tangent, bg-pattern-phi-radial -->
    <section class="section">
      <div class="bg-pattern-phi-radial bg-pattern-subtle"></div>
      <div class="phi-line-vertical"></div>
      <div class="phi-tangent"></div>
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="Industry Context" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text={`${industry.name} businesses face unique challenges in technology adoption. Understanding your industry context helps identify solutions that actually work for your specific needs, constraints, and opportunities.`} semanticLevel="normal" isChild={true} />
        </p>
        
        {industry.topics.length > 0 && (
          <>
            <h2 class="section-title" style="margin-top: var(--space-4xl);">
              <SemanticText text="Topics & Solutions" semanticLevel="high" isParent={true} />
            </h2>
            <CardGrid>
              {industry.topics.map((topic) => (
                <Card
                  title={topic.name}
                  description={topic.description}
                  icon={topic.icon}
                  href={`/resources/${industry.slug}/${topic.slug}`}
                />
              ))}
            </CardGrid>
          </>
        )}

        {publishedResources.length > 0 && (
          <>
            <h2 class="section-title" style="margin-top: var(--space-4xl);">
              <SemanticText text="Published Resources" semanticLevel="high" isParent={true} />
            </h2>
            <p class="section-description">
              <SemanticText text="Explore our curated resources specific to ${industry.name} businesses. Each resource is validated for voice consistency and provides practical, actionable guidance." semanticLevel="normal" isChild={true} />
            </p>
            <CardGrid columns={2}>
              {publishedResources.map((resource) => (
                <Card
                  title={resource.title}
                  description={resource.description}
                  href={`/resources/item/?id=${resource.id}`}
                >
                  <div style="margin-top: var(--space-md); display: flex; gap: var(--space-sm); flex-wrap: wrap; align-items: center;">
                    <span style="font-size: var(--text-sm); color: var(--text-secondary);">
                      Topic: {resource.topic}
                    </span>
                    {resource.metadata?.voiceScore && (
                      <span style="font-size: var(--text-sm); padding: var(--space-xs) var(--space-sm); background: var(--primary-light); color: var(--primary-dark); border-radius: var(--border-radius-sm);">
                        {Math.round(resource.metadata.voiceScore * 100)}% voice match
                      </span>
                    )}
                  </div>
                </Card>
              ))}
            </CardGrid>
          </>
        )}
      </div>
    </section>

    <InquiryForm 
      title={`Questions about ${industry.name}? Need clarity on what's feasible?`}
      subtitle="We're experts in your industry—informal questions welcome."
      defaultIndustry={industry.name}
    />
</SiteShell>

