---
import SiteShell from '../layouts/SiteShell.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import InquiryForm from '../components/InquiryForm.astro';
import SemanticText from '../components/SemanticText.astro';
import MarketingPageBands from '../components/MarketingPageBands.astro';
import { valueProposition } from '../data/value-proposition';

const currentPath = '/about';
const breadcrumbsTrail = [
  { label: 'Home', href: '/' },
  { label: 'About' },
];
---

<SiteShell 
  title="About - Brisbane Servers"
  description={valueProposition.about.description}
  currentPath={currentPath}
  breadcrumbs={breadcrumbsTrail}
  pageId="about"
  valueProfile="foundation"
  zoomProfile="balanced"
  mainClass="main-phi-chassis"
>
    <Hero 
      eyebrow={valueProposition.brandEyebrow}
      title="About Brisbane Servers"
      subtitle={valueProposition.about.heroSubtitle}
    />
    <Breadcrumbs items={breadcrumbsTrail} />

    <MarketingPageBands>
    <section class="section section-tartan-accent section-home-band--surface">
      <div class="bg-pattern-phi-grid bg-pattern-subtle"></div>
      <div class="phi-lateral-horizontal"></div>
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="Our mission foundation" semanticLevel="high" isParent={true} />
        </h2>
        <CardGrid>
          <Card
            title="Access to Truth"
            description="Providing documented, evidence-based information about technology solutions. Presenting facts about what works, implementation considerations, and practical applications."
            icon="fas fa-lightbulb"
          />
          <Card
            title="Supporting Domestic Growth"
            description="Strengthening the Australian business ecosystem through real, applicable technology solutions. Better businesses, better economy."
            icon="fas fa-handshake"
          />
          <Card
            title="Brisbane Innovation Authority"
            description="Building Brisbane's reputation as a recognized hub for quality, innovation, and authority in technology."
            icon="fas fa-city"
          />
        </CardGrid>
      </div>
    </section>

    <section class="section section-tartan-accent philosophy-section" aria-labelledby="philosophy-heading">
      <div class="phi-line-vertical"></div>
      <div class="phi-tangent"></div>
      <div class="container">
        <h2 class="section-title" id="philosophy-heading">
          <SemanticText text="How we work with you" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="Clarity over theatre: information architecture, evidence, and language that help you approve scope, budget, and risk — not slides that age in a week." semanticLevel="normal" />
        </p>
        <CardGrid>
          <Card
            title="Facts as Foundation"
            description="We present reality-based information, not opinions or stances. Provable, documented, evidence-based. This is our authority."
          />
          <Card
            title="Openness to Dialogue"
            description="We invite corrections, questions, and requests. This strengthens our authority and improves our understanding."
          />
          <Card
            title="Tailored Solutions"
            description="We recognize that needs differ and solutions must be diverse. One-size-fits-all doesn't exist."
          />
          <Card
            title="Collaborative Approach"
            description="We work with you, not for you. Understanding your reality, your industry, your constraints."
          />
        </CardGrid>
        
        <!-- Anchor kept for backwards-compatible links; philosophy now operationalized in portal voice framework. -->
        <div id="additive-semantics" class="sr-only" aria-hidden="true"></div>
        
        <div
          id="corrections-welcome"
          class="evidence-section evidence-section--additive-plain wisdom-section evidence-section--philosophy-stack"
          aria-labelledby="corrections-welcome-heading"
        >
          <h3 class="semantic-heading" id="corrections-welcome-heading">
            <SemanticText text="Corrections Welcome" semanticLevel="high" isParent={true} />
          </h3>
          <div class="semantic-content semantic-content--tight">
            <p>
              <SemanticText text="If you find an error, have a question, or want to challenge something we've stated, we invite you to contact us. Openness to correction is not a courtesy—it's a reinforcement mechanism. Inviting challenge does not weaken our position—it proves our foundation is solid enough to bear weight." semanticLevel="normal" />
            </p>
          </div>
          <p>
            <strong>Contact:</strong> <a href="mailto:connect@brisbaneservers.com">connect@brisbaneservers.com</a>
          </p>
        </div>
      </div>
    </section>

    <section class="section section-tartan-accent section-home-band--primary-light">
      <div class="bg-pattern-phi-radial bg-pattern-subtle"></div>
      <div class="phi-lateral-angular-4"></div>
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="A BIGPONS Project" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="Brisbane Servers is operated by BIGPONS, contributing to our mission of providing genuine technological expertise to Australian businesses." semanticLevel="normal" isChild={true} />
        </p>
        <CardGrid>
          <Card
            title="BIGPONS ABN"
            description="ABN: 93 297 393 962<br>Registered Australian Business"
            icon="fas fa-certificate"
          />
          <Card
            title="Location"
            description="Brisbane, Queensland, Australia<br>Serving businesses across Australia"
            icon="fas fa-map-marker-alt"
          />
        </CardGrid>
      </div>
    </section>

    <section class="section section-tartan-accent section-home-band--surface">
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-line-vertical phi-line-vertical-inv"></div>
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="Why that matters for Australian SMEs" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="The market is loud; your runway is not. We narrow the field to what fits your industry, compliance posture, and budget — then help you ship and support it." semanticLevel="normal" isChild={true} />
        </p>
        <CardGrid>
          <Card
            title="Industry Understanding"
            description="We know what works in retail, healthcare, hospitality, manufacturing, and professional services. Not general solutions—industry-specific guidance."
          />
          <Card
            title="Grant & Incentive Awareness"
            description="We identify available grants, tax incentives, and subsidies specific to your industry and business purpose. Accessing what you qualify for."
          />
          <Card
            title="Reality-Based Recommendations"
            description="We assess your size, costs, and constraints to recommend what actually makes sense, not what's being sold to you."
          />
          <Card
            title="Time-Saving Focus"
            description="We do the learning, sifting, and discernment. You focus on your business. We identify automation opportunities for tedious tasks."
          />
        </CardGrid>
      </div>
    </section>

    <InquiryForm 
      title="Questions about who we are or what we do?"
      industryField={false}
    />
    </MarketingPageBands>
</SiteShell>

