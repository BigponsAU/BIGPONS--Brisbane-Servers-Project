---
import SiteShell from '../layouts/SiteShell.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import InquiryForm from '../components/InquiryForm.astro';
import SectionIntro from '../components/SectionIntro.astro';
import SectionConstellationLayer from '../components/SectionConstellationLayer.astro';
import SiteLink from '../components/SiteLink.astro';
import MarketingPageBands from '../components/MarketingPageBands.astro';
import SemanticText from '../components/SemanticText.astro';
import { valueProposition } from '../data/value-proposition';
import { portalVoiceRules } from '../lib/portal-voice-framework';
import { sitePath } from '../lib/site-path';
import '../styles/about-page.css';

const currentPath = '/about';
const { sections } = valueProposition.about;
---

<SiteShell
  title="About"
  description={valueProposition.about.description}
  currentPath={currentPath}
  pageId="about"
  valueProfile="foundation"
  zoomProfile="balanced"
  mainClass="main-phi-chassis"
>
  <Hero
    eyebrow={valueProposition.brandEyebrow}
    title="About Brisbane Servers"
    subtitle={valueProposition.about.heroSubtitle}
    secondaryCtaText={valueProposition.portalCtaLabel}
    secondaryCtaHref="/account#portal-voice-framework"
  />

  <MarketingPageBands class="marketing-page-bands--about marketing-page-bands--constellation-spine">
    <section class="section section-tartan-accent section-home-band--surface phi-line-symmetrical about-band about-band--mission">
      <SectionConstellationLayer variant="about" semanticKey="about-mission" tier="whisper" placement="top-right" />
      <div class="home-phase-indicator home-phase-indicator--strategy" aria-hidden="true"></div>
      <div class="bg-pattern-phi-grid bg-pattern-subtle"></div>
      <div class="phi-lateral-horizontal"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.mission.eyebrow}
          title={sections.mission.title}
          byline={sections.mission.byline}
        />
        <CardGrid columns={3} style="margin-top: var(--space-2xl);">
          <Card
            title="Access to truth"
            description="Documented, evidence-based guidance on technology solutions, including what works, implementation considerations, and practical applications."
            icon="fas fa-lightbulb"
          />
          <Card
            title="Supporting domestic growth"
            description="Strengthening the Australian business ecosystem through practical technology adoption and delivery."
            icon="fas fa-handshake"
          />
          <Card
            title="Brisbane innovation authority"
            description="Contributing to Brisbane's reputation as a centre for quality technology practice and innovation."
            icon="fas fa-city"
          />
        </CardGrid>
      </div>
    </section>

    <section
      class="section section-tartan-accent section-home-band--primary-light philosophy-section about-band about-band--philosophy"
      aria-labelledby="philosophy-heading"
    >
      <div class="home-phase-indicator home-phase-indicator--industry" aria-hidden="true"></div>
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-line-vertical"></div>
      <div class="phi-tangent"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.philosophy.eyebrow}
          title={sections.philosophy.title}
          byline={sections.philosophy.byline}
          titleId="philosophy-heading"
        />
        <CardGrid columns={2} style="margin-top: var(--space-2xl);">
          <Card
            title="Facts as foundation"
            description="Reality-based information over opinion, with documented evidence and clear reasoning behind recommendations."
          />
          <Card
            title="Openness to dialogue"
            description="We welcome corrections, questions, and requests because they improve quality and strengthen outcomes."
          />
          <Card
            title="Tailored solutions"
            description="Business needs differ, so solutions are tailored to context rather than forced into one-size-fits-all models."
          />
          <Card
            title="Collaborative approach"
            description="We work with you, not around you; your operating reality, industry, and constraints come first."
          />
        </CardGrid>
        <div id="additive-semantics" class="sr-only" aria-hidden="true"></div>
      </div>
    </section>

    <section
      id="corrections-welcome"
      class="section section-tartan-accent section-home-band--surface about-corrections-section about-band about-band--corrections"
      aria-labelledby="corrections-welcome-heading"
    >
      <SectionConstellationLayer
        variant="about"
        semanticKey="about-corrections-welcome"
        tier="whisper"
        placement="bottom-right"
      />
      <div class="container">
        <div class="about-corrections">
          <p class="about-corrections__eyebrow">Open dialogue</p>
          <h2 id="corrections-welcome-heading" class="about-corrections__title">
            <SemanticText text={valueProposition.about.correctionsTitle} semanticLevel="high" isParent={true} />
          </h2>
          <p class="about-corrections__lead">
            <SemanticText text={valueProposition.about.correctionsBody} semanticLevel="normal" />
          </p>
          <a class="btn btn-secondary about-corrections__cta" href={`mailto:${valueProposition.about.correctionsContact}`}>
            Email {valueProposition.about.correctionsContact}
          </a>
        </div>
      </div>
    </section>

    <section
      id="portal-voice-framework"
      class="section section-tartan-accent section-home-band--surface about-portal-voice-section about-band about-band--voice"
      aria-labelledby="portal-voice-heading"
    >
      <div class="home-phase-indicator home-phase-indicator--proof" aria-hidden="true"></div>
      <SectionConstellationLayer
        variant="about"
        semanticKey="about-portal-voice-framework"
        tier="whisper"
        placement="bottom-right"
      />
      <div class="bg-pattern-phi-radial bg-pattern-subtle"></div>
      <div class="phi-lateral-angular-4"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.portalVoice.eyebrow}
          title={sections.portalVoice.title}
          byline={sections.portalVoice.byline}
          titleId="portal-voice-heading"
        />
        <div class="about-portal-voice__rules">
          {
            portalVoiceRules.map((rule) => (
              <article class="about-portal-voice__rule">
                <h3>{rule.title}</h3>
                <p>{rule.description}</p>
              </article>
            ))
          }
        </div>
        <p class="about-portal-voice__cta">
          <a href={sitePath('/account#portal-voice-framework')} class="btn btn-primary">
            Open account workspace
          </a>
        </p>
      </div>
    </section>

    <section class="section section-tartan-accent section-home-band--primary-light about-band about-band--operator">
      <SectionConstellationLayer variant="about" semanticKey="about-bigpons" tier="whisper" placement="bottom-right" />
      <div class="home-phase-indicator home-phase-indicator--about" aria-hidden="true"></div>
      <div class="bg-pattern-phi-radial bg-pattern-subtle"></div>
      <div class="phi-lateral-angular-4"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.bigpons.eyebrow}
          title={sections.bigpons.title}
          byline={sections.bigpons.byline}
        />
        <CardGrid columns={2} style="margin-top: var(--space-2xl);">
          <Card
            title="BIGPONS ABN"
            description="ABN: 93 297 393 962 — registered Australian business."
            icon="fas fa-certificate"
          />
          <Card
            title="Location"
            description="Brisbane, Queensland, Australia — supporting businesses across Australia."
            icon="fas fa-map-marker-alt"
          />
        </CardGrid>
      </div>
    </section>

    <section class="section section-tartan-accent section-home-band--surface about-band about-band--sme">
      <SectionConstellationLayer variant="about" semanticKey="about-sme" tier="whisper" placement="bottom-left" />
      <div class="home-phase-indicator home-phase-indicator--contact" aria-hidden="true"></div>
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-line-vertical phi-line-vertical-inv"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.sme.eyebrow}
          title={sections.sme.title}
          byline={sections.sme.byline}
        />
        <CardGrid columns={2} style="margin-top: var(--space-2xl);">
          <Card
            title="Industry understanding"
            description="Retail, healthcare, hospitality, manufacturing, and professional services receive industry-specific guidance rather than generic solutions."
          />
          <Card
            title="Grant and incentive awareness"
            description="Grants, tax incentives, and subsidies are assessed against your industry and goals so you can pursue relevant support."
          />
          <Card
            title="Reality-based recommendations"
            description="We assess scale, cost, and constraints to recommend what makes sense for your business, not what is easiest to sell."
          />
          <Card
            title="Time-saving focus"
            description="We handle the research and filtering so your team can focus on operations, with automation applied where repetitive work can be reduced."
          />
        </CardGrid>
        <div class="about-next-steps">
          <p class="about-next-steps__copy">
            <SemanticText
              text="Explore why Brisbane 2032 demands deliberate network infrastructure, delivery patterns on Projects, industry hubs under Resources, or request a consultation when you are ready to scope work."
              semanticLevel="normal"
            />
          </p>
          <div class="about-next-steps__actions">
            <SiteLink href="/brisbane-2032#project-purpose" class="btn btn-secondary">Project purpose</SiteLink>
            <SiteLink href="/projects" class="btn btn-secondary">Projects</SiteLink>
            <SiteLink href="/resources" class="btn btn-secondary">Resources</SiteLink>
            <SiteLink href="/services#consultation" class="btn btn-primary">Book consultation</SiteLink>
          </div>
        </div>
      </div>
    </section>

    <InquiryForm industryField={false} />
  </MarketingPageBands>
</SiteShell>
