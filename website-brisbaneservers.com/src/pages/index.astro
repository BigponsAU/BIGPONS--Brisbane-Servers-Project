---
import SiteShell from '../layouts/SiteShell.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import SearchBar from '../components/SearchBar.astro';
import InquiryForm from '../components/InquiryForm.astro';
import SemanticText from '../components/SemanticText.astro';
import HomeInterconnectionRig from '../components/HomeInterconnectionRig.astro';
import SectionSatelliteConstellation from '../components/SectionSatelliteConstellation.astro';
import ClientSitesShowcase from '../components/ClientSitesShowcase.astro';
import { industries } from '../data/industries';
import { HOME_BAND_SEMANTIC_KEYS } from '../data/home-band-satellite-seeds';
import { valueProposition } from '../data/value-proposition';
import { safeArrayAccess, createFallback } from '../utils/error-handling';

const currentPath = '/';

// Safe access to industries with fallback
const safeIndustries = industries && Array.isArray(industries) ? industries : [];
const industriesFallback = createFallback([]);
const displayIndustries = industriesFallback(safeIndustries);
---

<SiteShell
  title={valueProposition.home.title}
  description={valueProposition.home.description}
  currentPath={currentPath}
  pageId="home"
  valueProfile="foundation"
  zoomProfile="immersive"
  density="airy"
  mainClass="main-home"
>
    <Hero 
      eyebrow={valueProposition.brandEyebrow}
      title={valueProposition.home.heroTitle}
      subtitle={valueProposition.home.heroSubtitle}
      ctaText="Explore solutions"
      ctaHref="#services-overview"
      secondaryCtaText="Open Portal Voice Framework"
      secondaryCtaHref="/account"
      scrollTargetId="#services-overview"
      scrollLabel="See how we work"
    />

    <!-- Unified home section shell + interconnection spine (visual layer; reusable rig pattern) -->
    <HomeInterconnectionRig>
    <div class="home-sections-shell">

    <!-- Services Overview Section -->
    <section id="services-overview" class="section section-tartan-accent home-band--strategy" data-interconnection-node data-interconnection-band="strategy">
      <div class="container">
        <SectionSatelliteConstellation variant="strategy" semanticKey={HOME_BAND_SEMANTIC_KEYS.strategy} />
        <div class="home-phase-indicator home-phase-indicator--strategy" aria-hidden="true"></div>
        <h2 class="section-title">
          <SemanticText text="Our core services" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text={valueProposition.home.coreServicesLead} semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={3}>
          <Card
            title="Web development & digital presence"
            description="High-performance sites, web applications, e-commerce, APIs, and SEO-minded performance work — built for clarity, speed, and conversion where that matters to you."
            icon="fas fa-globe"
            size="medium"
          />
          <Card
            title="Automation & custom development"
            description="Process automation, bespoke software, integrations, and AI-assisted workflows where they earn their keep — scoped in phases, grant-aware when programs apply."
            icon="fas fa-robot"
            size="medium"
          />
          <Card
            title="IT consulting & ongoing support"
            description="Strategy, assessments, security-minded reviews, infrastructure direction, and dependable support so your team is not carrying vendor noise alone."
            icon="fas fa-headset"
            size="medium"
          />
        </CardGrid>
      </div>
    </section>

    <!-- Industries Served Section -->
    <section class="section section-tartan-accent section-home-band--surface home-band--industry" data-interconnection-node data-interconnection-band="industry">
      <div class="container">
        <SectionSatelliteConstellation variant="industry" semanticKey={HOME_BAND_SEMANTIC_KEYS.industry} />
        <div class="home-phase-indicator home-phase-indicator--industry" aria-hidden="true"></div>
        <h2 class="section-title">
          <SemanticText text="Industry context" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="Regulations, incentives, and day-to-day constraints change by sector — retail, healthcare, hospitality, manufacturing, professional services — so recommendations stay tied to how you actually operate, not generic playbooks." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={4}>
          {displayIndustries.length > 0 ? (
            displayIndustries.map((industry) => (
              <Card
                title={industry?.name || 'Industry'}
                description={industry?.description || 'Learn more about our solutions for this industry.'}
                icon={industry?.icon || 'fas fa-industry'}
                href={industry?.slug ? `/resources/${industry.slug}` : '/resources'}
                actionLabel="View industry resources"
                size="small"
              />
            ))
          ) : (
            <Card
              title="Industries We Serve"
              description="We support multiple industries with practical technology direction, connected implementation guidance, and measurable improvement pathways."
              icon="fas fa-industry"
              href="/resources"
              actionLabel="Browse resources"
              size="medium"
            />
          )}
        </CardGrid>
        
        <div style="text-align: center; margin-top: var(--space-2xl);">
          <a href="/resources" class="btn btn-secondary">
            View All Resources
          </a>
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="section section-tartan-accent home-band--proof section--hero-wash" data-interconnection-node data-interconnection-band="proof">
      <div class="container">
        <SectionSatelliteConstellation variant="proof" semanticKey={HOME_BAND_SEMANTIC_KEYS.proof} />
        <div class="home-phase-indicator home-phase-indicator--proof" aria-hidden="true"></div>
        <h2 class="section-title">
          <SemanticText text="Why choose Brisbane Servers" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="A Brisbane-based consulting practice with a deliberately focused client portfolio — so each engagement gets senior attention, modern engineering practices, and documentation you can rely on when priorities shift." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={2}>
          <Card
            title="Innovation-first delivery"
            description="Solutions are designed for your context — not recycled templates — using current tooling where it reduces risk and cost, and boring technology where that is the responsible choice."
            icon="fas fa-industry"
            size="large"
            emphasis={true}
          />
          <Card
            title="Grants & incentives"
            description="We map digital transformation grants, tax incentives, and subsidies that match your industry and project shape, so funding opportunities are part of the plan from the start."
            icon="fas fa-dollar-sign"
            size="large"
          />
          <Card
            title="Reality-based recommendations"
            description="Budget, team capacity, compliance, and timeline are first-class inputs. You get what fits — not what a vendor catalogue insists you should buy."
            icon="fas fa-search"
            size="large"
          />
          <Card
            title="Your time protected"
            description="We absorb research, vendor comparison, and technical discernment so leadership can stay on operations while still making informed commitments."
            icon="fas fa-clock"
            size="large"
          />
        </CardGrid>
      </div>
    </section>

    <!-- Live sites: concrete proof immediately before contact (trust → conversation). -->
    <section
      id="client-sites"
      class="section section-tartan-accent section-home-band--surface home-band--clients"
      data-interconnection-node
      data-interconnection-band="clients"
    >
      <div class="container">
        <SectionSatelliteConstellation
          variant="solutions"
          semanticKey="client web presences live sites shipped preview portfolio growth"
        />
        <div class="home-phase-indicator home-phase-indicator--proof" aria-hidden="true"></div>
        <h2 class="section-title">
          <SemanticText text="Web presences we have shipped" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText
            text="Live sites and applications we have shipped for clients. The list is deliberately small for now: we only showcase work clients are happy to display, and we add entries as new public launches clear that bar."
            semanticLevel="normal"
            isChild={true}
          />
        </p>
        <ClientSitesShowcase />
      </div>
    </section>

    <!-- Contact Information Section -->
    <section class="section section-tartan-accent section-home-band--primary-light home-band--contact" data-interconnection-node data-interconnection-band="contact">
      <div class="container">
        <SectionSatelliteConstellation variant="contact" semanticKey={HOME_BAND_SEMANTIC_KEYS.contact} />
        <h2 class="section-title section-title--center">
          <SemanticText text="Ready to transform your business?" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description section-description--center">
          <SemanticText text="Professional consultations by appointment. Tell us what you are trying to achieve — we will map options, effort, and risks so you can decide with confidence." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={3}>
          <Card
            title="Phone"
            description="<strong>+61 490 478 864</strong><br>Available for consultations by appointment"
            icon="fas fa-phone"
            size="medium"
          />
          <Card
            title="Email"
            description="<strong>support@brisbaneservers.com</strong><br>For inquiries and support<br><strong>connect@brisbaneservers.com</strong><br>For general inquiries"
            icon="fas fa-envelope"
            size="medium"
          />
          <Card
            title="Location"
            description="<strong>Brisbane, Queensland</strong><br>Serving businesses across Australia<br>Physical and online consultations available"
            icon="fas fa-map-marker-alt"
            size="medium"
          />
        </CardGrid>
        
        <div style="text-align: center; margin-top: var(--space-2xl);">
          <a href="#inquiry-section" class="btn btn-primary">
            Start a Conversation
          </a>
        </div>
      </div>
    </section>

    <!-- Company Details Section -->
    <section class="section section-tartan-accent home-band--about" data-interconnection-node data-interconnection-band="about">
      <div class="container">
        <SectionSatelliteConstellation variant="about" semanticKey={HOME_BAND_SEMANTIC_KEYS.about} />
        <h2 class="section-title section-title--center">
          <SemanticText text="About Brisbane Servers" semanticLevel="high" isParent={true} />
        </h2>
        
        <CardGrid layout="grid" columns={2}>
          <Card
            title="BIGPONS Project"
            description="Brisbane Servers is operated by BIGPONS, contributing to our mission of providing genuine technological expertise to Australian businesses. ABN: 93 297 393 962"
            icon="fas fa-certificate"
            size="medium"
          />
          <Card
            title="Our Mission"
            description="Providing access to truth in technology for Australian businesses. Contributing to domestic growth and Brisbane's innovation authority through evidence-based solutions."
            icon="fas fa-bullseye"
            size="medium"
          />
        </CardGrid>
        
        <div style="text-align: center; margin-top: var(--space-xl);">
          <a href="/account" class="btn btn-secondary">
            Open Portal Voice Framework
          </a>
        </div>
      </div>
    </section>

    <!-- Challenge & Solutions Section (Original Content) -->
    <section class="section section-tartan-accent section-home-band--surface home-band--challenge" data-interconnection-node data-interconnection-band="challenge">
      <div class="container">
        <SectionSatelliteConstellation variant="challenge" semanticKey={HOME_BAND_SEMANTIC_KEYS.challenge} />
        <h2 class="section-title">
          <SemanticText text="The challenge Australian businesses face" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="Leaders are expected to modernise systems, harden security, and adopt AI — while running the day-to-day. Without a grounded partner, that noise turns into expensive mis-steps and stalled initiatives." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={3} progressive>
          <Card
            title="Resource Constraints"
            description="Running operations leaves limited time for research, feasibility checks, and vendor evaluation, so decision support must be focused."
            icon="fas fa-clock"
          />
          <Card
            title="Information Complexity"
            description="Competing tools, changing platforms, and conflicting vendor claims create noise. We isolate what fits your context and what does not."
            icon="fas fa-info-circle"
          />
          <Card
            title="Strategic Assessment"
            description="We evaluate your scale, budget, grants, and industry constraints to identify options that are both feasible and worthwhile."
            icon="fas fa-search"
          />
        </CardGrid>
        
        <div class="load-more-btn">
          <button data-expand-cards>Show More Examples</button>
        </div>
        
        <SearchBar />
      </div>
    </section>

    <!-- Proven Solutions Section -->
    <section class="section section-tartan-accent home-band--solutions section--hero-wash" data-interconnection-node data-interconnection-band="solutions">
      <div class="container">
        <SectionSatelliteConstellation variant="solutions" semanticKey={HOME_BAND_SEMANTIC_KEYS.solutions} />
        <h2 class="section-title">
          <SemanticText text="Proven solution patterns" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="Documented implementations, industry playbooks, and strategic guidance shaped to your context — so recommendations stay evidence-led and implementation-ready." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={2} progressive>
          <Card
            title="Industry Expertise"
            description='Guidance tailored to retail, healthcare, hospitality, manufacturing, and professional services, with practical starting points for each. <a href="/resources" class="evidence-citation">View resources</a>'
            icon="fas fa-industry"
            size="large"
          />
          <Card
            title="Financial Optimization"
            description='Direction on grants, subsidies, and tax incentives that can reduce implementation cost for your industry and goals. <a href="/projects" class="evidence-citation">View examples</a>'
            icon="fas fa-dollar-sign"
            size="large"
          />
          <Card
            title="Process Automation"
            description='Focused automation opportunities that reduce repetitive work and free capacity for higher-value tasks. <a href="/projects" class="evidence-citation">View case studies</a>'
            icon="fas fa-cogs"
            size="large"
          />
          <Card
            title="Value-Based Framework"
            description="Recommendations are grounded in business scale, budget, available grants, industry requirements, and measurable outcomes."
            icon="fas fa-chart-line"
            size="large"
          />
        </CardGrid>
        
        <div class="load-more-btn">
          <button data-expand-cards>Show More Solutions</button>
        </div>
      </div>
    </section>

    <!-- Strategic Partnership Section -->
    <section class="section section-tartan-accent section-home-band--surface home-band--partnership section--hero-wash" data-interconnection-node data-interconnection-band="partnership">
      <div class="container">
        <SectionSatelliteConstellation variant="partnership" semanticKey={HOME_BAND_SEMANTIC_KEYS.partnership} />
        <h2 class="section-title">
          <SemanticText text="Strategic technology partnership" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="We run the research, vendor comparison, and documentation burden so your team can approve direction quickly — with trade-offs, costs, and sequencing spelled out." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={2}>
          <Card
            title="Efficient Delivery"
            description="We run the analysis and preparation work; you focus on decisions. Outputs stay clear, actionable, and implementation-ready."
            size="medium"
          />
          <Card
            title="Australian Market Expertise"
            description="Brisbane-based, serving Australian businesses. Deep understanding of local market conditions, regulatory requirements, grant programs, and proven implementation strategies."
            size="medium"
          />
        </CardGrid>
      </div>
    </section>

      <div class="home-inquiry-interconnection home-band--inquiry" data-interconnection-node data-interconnection-band="inquiry">
        <InquiryForm id="inquiry-section" />
      </div>
    </div>
    <!-- /home-sections-shell -->
    </HomeInterconnectionRig>
  
</SiteShell>
