---
import SiteShell from '../layouts/SiteShell.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import SearchBar from '../components/SearchBar.astro';
import InquiryForm from '../components/InquiryForm.astro';
import SemanticText from '../components/SemanticText.astro';
import { industries } from '../data/industries';
import { safeArrayAccess, createFallback } from '../utils/error-handling';

const currentPath = '/';

// Safe access to industries with fallback
const safeIndustries = industries && Array.isArray(industries) ? industries : [];
const industriesFallback = createFallback([]);
const displayIndustries = industriesFallback(safeIndustries);
---

<SiteShell
  title="Brisbane Servers - Elite Technology Solutions"
  currentPath={currentPath}
  pageId="home"
  valueProfile="foundation"
  zoomProfile="immersive"
  density="airy"
  mainClass="main-home"
>
    <Hero 
      eyebrow="BIGPONS · Access to truth in technology"
      title="Enterprise Technology Solutions"
      subtitle="Evidence-based technology consulting for Australian businesses. Tailored insights, documented implementations, and industry-specific guidance that delivers measurable results."
      ctaText="Explore Solutions"
      ctaHref="#services-overview"
      secondaryCtaText="Our approach"
      secondaryCtaHref="/about#additive-semantics"
    />

    <!-- Joined backing: one continuous rail, trail, and tartan across all sections -->
    <div class="banach-joined-backing">
      <div class="banach-rail-continuous"></div>
      <div class="banach-trail-continuous"></div>
      <div class="banach-backing-tartan"></div>
      <!-- Overlay: tartan on top of sections to connect content (option 2) -->
      <div class="banach-overlay-tartan" aria-hidden="true"></div>

    <!-- Services Overview Section -->
    <section id="services-overview" class="section section-tartan-accent">
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="What We Offer" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="Comprehensive technology consulting services designed to help Australian businesses navigate complex technology decisions and implement solutions that deliver real value." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={3}>
          <Card
            title="Consultation & Analysis"
            description="In-depth conversations to understand your business, challenges, and goals. We assess your reality—size, costs, grants available, industry specifics—and identify what you need."
            icon="fas fa-comments"
            size="medium"
          />
          <Card
            title="Implementation & Development"
            description="Building and deploying solutions tailored to your value framework. Phased approach, grant-assisted when available. From web development to enterprise applications."
            icon="fas fa-rocket"
            size="medium"
          />
          <Card
            title="Ongoing Support"
            description="Access to expertise when you need it. Updates, adjustments, and guidance as your business evolves. Enterprise-grade support for your technology infrastructure."
            icon="fas fa-headset"
            size="medium"
          />
        </CardGrid>
      </div>
    </section>

    <!-- Industries Served Section -->
    <section class="section section-tartan-accent" style="background: var(--surface);">
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="Industries We Serve" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="Industry-specific technology solutions for Australian businesses. We understand the unique requirements, compliance needs, and proven strategies for your sector." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={4}>
          {displayIndustries.length > 0 ? (
            displayIndustries.map((industry) => (
              <Card
                title={industry?.name || 'Industry'}
                description={industry?.description || 'Learn more about our solutions for this industry.'}
                icon={industry?.icon || 'fas fa-industry'}
                href={industry?.slug ? `/resources/${industry.slug}` : '/resources'}
                size="small"
              />
            ))
          ) : (
            <Card
              title="Industries We Serve"
              description="We provide technology solutions across multiple industries. Please visit our resources page to learn more."
              icon="fas fa-industry"
              href="/resources"
              size="medium"
            />
          )}
        </CardGrid>
        
        <div style="text-align: center; margin-top: var(--space-2xl);">
          <a href="/resources" class="btn btn-secondary">
            View All Resources
          </a>
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="section section-tartan-accent">
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="Why Choose Brisbane Servers" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="Australian SMEs face unique challenges navigating an overwhelming tech landscape. We provide the clarity, expertise, and access you need to succeed." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={2}>
          <Card
            title="Industry Understanding"
            description="We know what works in retail, healthcare, hospitality, manufacturing, and professional services. Not general solutions—industry-specific guidance based on real implementations."
            icon="fas fa-industry"
            size="large"
            emphasis={true}
          />
          <Card
            title="Grant & Incentive Awareness"
            description="We identify available grants, tax incentives, and subsidies specific to your industry and business purpose. Accessing what you qualify for to reduce implementation costs."
            icon="fas fa-dollar-sign"
            size="large"
          />
          <Card
            title="Reality-Based Recommendations"
            description="We assess your size, costs, and constraints to recommend what actually makes sense, not what's being sold to you. Value-focused solutions that align with your business context."
            icon="fas fa-search"
            size="large"
          />
          <Card
            title="Time-Saving Focus"
            description="We do the learning, sifting, and discernment. You focus on your business. We identify automation opportunities for tedious tasks, freeing your time for high-value work."
            icon="fas fa-clock"
            size="large"
          />
        </CardGrid>
      </div>
    </section>

    <!-- Contact Information Section -->
    <section class="section section-tartan-accent" style="background: var(--primary-light);">
      <div class="container">
        <h2 class="section-title section-title--center">
          <SemanticText text="Get In Touch" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description section-description--center">
          <SemanticText text="Ready to discuss your technology needs? We're here to help Australian businesses navigate technology decisions and implement solutions that deliver value." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={3}>
          <Card
            title="Phone"
            description="<strong>+61 490 478 864</strong><br>Available for consultations by appointment"
            icon="fas fa-phone"
            size="medium"
          />
          <Card
            title="Email"
            description="<strong>support@brisbaneservers.com</strong><br>For inquiries and support<br><strong>connect@brisbaneservers.com</strong><br>For general inquiries"
            icon="fas fa-envelope"
            size="medium"
          />
          <Card
            title="Location"
            description="<strong>Brisbane, Queensland</strong><br>Serving businesses across Australia<br>Physical and online consultations available"
            icon="fas fa-map-marker-alt"
            size="medium"
          />
        </CardGrid>
        
        <div style="text-align: center; margin-top: var(--space-2xl);">
          <a href="#inquiry-section" class="btn btn-primary">
            Start a Conversation
          </a>
        </div>
      </div>
    </section>

    <!-- Company Details Section -->
    <section class="section section-tartan-accent">
      <div class="container">
        <h2 class="section-title section-title--center">
          <SemanticText text="About Brisbane Servers" semanticLevel="high" isParent={true} />
        </h2>
        
        <CardGrid layout="grid" columns={2}>
          <Card
            title="BIGPONS Project"
            description="Brisbane Servers is operated by BIGPONS, contributing to our mission of providing genuine technological expertise to Australian businesses. ABN: 93 297 393 962"
            icon="fas fa-certificate"
            size="medium"
          />
          <Card
            title="Our Mission"
            description="Providing access to truth in technology for Australian businesses. Contributing to domestic growth and Brisbane's innovation authority through evidence-based solutions."
            icon="fas fa-bullseye"
            size="medium"
          />
        </CardGrid>
        
        <div style="text-align: center; margin-top: var(--space-xl);">
          <a href="/about#additive-semantics" class="btn btn-secondary">
            Design philosophy &amp; about us
          </a>
        </div>
      </div>
    </section>

    <!-- Challenge & Solutions Section (Original Content) -->
    <section class="section section-tartan-accent" style="background: var(--surface);">
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="The Challenge Australian Businesses Face" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="Business leaders navigate complex technology decisions while managing daily operations. Limited time and resources require focused, evidence-based guidance that aligns with your specific business context, industry requirements, and strategic objectives." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={3} progressive>
          <Card
            title="Resource Constraints"
            description="Business operations demand focused attention. Limited capacity for comprehensive technology research, feasibility analysis, and vendor evaluation requires strategic prioritization."
            icon="fas fa-clock"
          />
          <Card
            title="Information Complexity"
            description="Multiple information sources, evolving technologies, and diverse vendor claims create complexity. Strategic evaluation determines what applies to your specific business context."
            icon="fas fa-info-circle"
          />
          <Card
            title="Strategic Assessment"
            description="We evaluate your business context—scale, budget, available grants, industry requirements—to identify solutions that align with your strategic objectives and operational constraints."
            icon="fas fa-search"
          />
        </CardGrid>
        
        <div class="load-more-btn">
          <button data-expand-cards>Show More</button>
        </div>
        
        <SearchBar />
      </div>
    </section>

    <!-- Proven Solutions Section -->
    <section class="section section-tartan-accent">
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="Proven Solutions for Your Business" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="Documented implementations, industry-specific insights, and strategic guidance tailored to your business context. Evidence-based recommendations that deliver measurable value." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={2} progressive>
          <Card
            title="Industry Expertise"
            description='Strategic guidance tailored to retail, healthcare, hospitality, manufacturing, and professional services. Proven solutions for your industry. <a href="/resources" class="evidence-citation">View resources</a>'
            icon="fas fa-industry"
            size="large"
          />
          <Card
            title="Financial Optimization"
            description='Strategic knowledge of digital transformation grants, business subsidies, and tax incentives aligned with your industry and business objectives. <a href="/projects" class="evidence-citation">View examples</a>'
            icon="fas fa-dollar-sign"
            size="large"
          />
          <Card
            title="Process Automation"
            description='Strategic identification of automation opportunities that enhance operational efficiency and enable focus on high-value activities. <a href="/projects" class="evidence-citation">View case studies</a>'
            icon="fas fa-cogs"
            size="large"
          />
          <Card
            title="Value-Based Framework"
            description="Strategic evaluation considers your business scale, budget constraints, available grants, industry requirements, and strategic objectives to deliver optimal recommendations."
            icon="fas fa-chart-line"
            size="large"
          />
        </CardGrid>
        
        <div class="load-more-btn">
          <button data-expand-cards>Show More</button>
        </div>
        
        <div class="evidence-section">
          <h3>
            <SemanticText text="Evidence" semanticLevel="high" isParent={true} />
          </h3>
          <ul class="evidence-list">
            <li><a href="/projects">Case studies with implementation details</a></li>
            <li><a href="/resources">Industry-specific resources with citations</a></li>
            <li><a href="/about#additive-semantics">Additive semantics &amp; our approach to evidence</a></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Strategic Partnership Section -->
    <section class="section section-tartan-accent" style="background: var(--surface);">
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="Strategic Technology Partnership" semanticLevel="high" isParent={true} />
        </h2>
        <p class="section-description">
          <SemanticText text="We understand the constraints of business leadership. Our research, evaluation, and documentation processes deliver actionable insights. Strategic guidance that respects your time and resources." semanticLevel="normal" isChild={true} />
        </p>
        
        <CardGrid layout="grid" columns={2}>
          <Card
            title="Efficient Delivery"
            description="We conduct research, evaluation, and analysis. You focus on strategic decisions. Information is structured for clarity: challenge → evidence → solution → implementation."
            size="medium"
          />
          <Card
            title="Australian Market Expertise"
            description="Brisbane-based, serving Australian businesses. Deep understanding of local market conditions, regulatory requirements, grant programs, and proven implementation strategies."
            size="medium"
          />
        </CardGrid>
      </div>
    </section>

      <InquiryForm id="inquiry-section" />
    </div>
    <!-- /banach-joined-backing (inquiry included for visual continuity) -->
  
</SiteShell>
