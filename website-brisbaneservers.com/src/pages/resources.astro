---
export const prerender = false;

import SiteShell from '../layouts/SiteShell.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import SearchBar from '../components/SearchBar.astro';
import IndustryFilters from '../components/IndustryFilters.astro';
import InquiryForm from '../components/InquiryForm.astro';
import SemanticText from '../components/SemanticText.astro';
import SectionIntro from '../components/SectionIntro.astro';
import MarketingPageBands from '../components/MarketingPageBands.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ProjectObjectivePanel from '../components/ProjectObjectivePanel.astro';
import SiteLink from '../components/SiteLink.astro';
import {
  brisbaneServersProjectObjective,
  projectPurposeNav,
} from '../data/brisbane-servers-project-objective';
import { industries } from '../data/industries';
import { valueProposition } from '../data/value-proposition';
import { resourcesHubSeo } from '../lib/content-seo';
import { resourceVoiceInterconnection } from '../lib/portal-voice-framework';
import { isSubstantiveApiResource } from '../data/topic-guides';
import { getPublishedResourcesForPage } from '../lib/public-published-resources';

const publishedResources = await getPublishedResourcesForPage();

const currentPath = '/resources';
const featuredResources = publishedResources.filter(isSubstantiveApiResource).slice(0, 6);
const siteOrigin = (Astro.site ?? new URL('https://brisbaneservers.com')).origin;
const { structuredData, breadcrumbs: breadcrumbItems } = resourcesHubSeo(
  industries,
  siteOrigin,
  import.meta.env.BASE_URL,
  valueProposition.resources.description,
);
---

<SiteShell 
  title="Resources"
  description={valueProposition.resources.description}
  ogType="article"
  structuredData={structuredData}
  currentPath={currentPath}
  pageId="resources"
  valueProfile="evidence"
  zoomProfile="focused"
  mainClass="main-phi-chassis"
>
    <Breadcrumbs items={breadcrumbItems} />

    <Hero 
      eyebrow={valueProposition.brandEyebrow}
      title={valueProposition.resources.heroTitle}
      subtitle={valueProposition.resources.heroSubtitle}
    />
    
    <MarketingPageBands>
    <section class="section section-tartan-accent section-home-band--surface" style="padding-top: 0;">
      <div class="container">
        <SearchBar />
      </div>
    </section>

    <!-- What Are Resources Section -->
    <section class="section section-tartan-accent section-home-band--primary-light phi-line-symmetrical">
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-line-vertical"></div>
      <div class="container">
        <SectionIntro
          eyebrow="Evidence-led guidance"
          title="How these resources help you decide"
          byline="Industry-specific guides reviewed for voice consistency, practical relevance, and evidence quality, aligned with how Brisbane Servers consults in practice."
        />
        <p class="section-description section-intro__byline" style="margin-top: calc(-1 * var(--space-md)); max-width: 62ch;">
          <SemanticText text={resourceVoiceInterconnection.headline} semanticLevel="normal" isChild={true} />
        </p>
        <p class="section-description section-intro__byline" style="margin-top: var(--space-md); max-width: 62ch;">
          <SemanticText text={projectPurposeNav.publicLead} semanticLevel="normal" isChild={true} />
        </p>
        <p class="resources-2032-bridge">
          <SemanticText text={valueProposition.projectObjective.implementationLead} semanticLevel="normal" />
          {' '}
          <SiteLink href={projectPurposeNav.programPage.href}>Brisbane 2032 program</SiteLink>
          {' '}
          documents the civic-scale side; this hub holds industry inference and BIGPONS-captured history for
          {' '}
          {brisbaneServersProjectObjective.inferenceProgram.temporalFrame.contemplation.toLowerCase()}.
        </p>
        
        <CardGrid columns={3} style="margin-top: var(--space-2xl);">
          <Card
            title="Inference, not assertion"
            description={valueProposition.voice.inferenceNotAssertion}
            icon="fas fa-check-circle"
          />
          <Card
            title="Industry context"
            description="Retail, healthcare, hospitality, professional services, and more — each hub links recommendations to regulations, incentives, and day-to-day operating reality."
            icon="fas fa-industry"
          />
          <Card
            title="Action-ready guidance"
            description={valueProposition.voice.actionablePrimary}
            icon="fas fa-book"
          />
        </CardGrid>
      </div>
    </section>

    <ProjectObjectivePanel sectionId="resources-project-objective" variant="compact" />

    {featuredResources.length > 0 && (
      <!-- Featured Resources Section -->
      <section class="section section-tartan-accent section-home-band--surface">
        <div class="bg-pattern-phi-grid bg-pattern-soft"></div>
        <div class="phi-line-vertical phi-line-vertical-inv"></div>
        <div class="container">
          <SectionIntro
            eyebrow="Recently published"
            title="Featured resources"
            byline="Recently published guides that connect operating context to feasible next steps, with scope and trade-offs visible before commitment."
          />
          <CardGrid columns={3}>
            {featuredResources.map((resource) => (
              <Card
                title={resource.title}
                description={resource.description}
                href={`/resources/${resource.industry}/${resource.topic}#resource-${resource.id}`}
                actionLabel="Read resource"
              >
                <div style="margin-top: var(--space-md); display: flex; gap: var(--space-sm); flex-wrap: wrap; align-items: center; font-size: var(--text-sm);">
                  <span style="color: var(--text-secondary);">
                    {resource.industry} • {resource.topic}
                  </span>
                  {resource.metadata?.voiceScore && (
                    <span style="padding: var(--space-xs) var(--space-sm); background: var(--primary-light); color: var(--primary-dark); border-radius: var(--border-radius-sm);">
                      {Math.round(resource.metadata.voiceScore * 100)}% match
                    </span>
                  )}
                </div>
              </Card>
            ))}
          </CardGrid>
        </div>
      </section>
    )}

    <!-- What each guide delivers -->
    <section class="section section-tartan-accent section-home-band--primary-light">
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-lateral-angular-2"></div>
      <div class="container">
        <SectionIntro
          eyebrow="Inside every topic guide"
          title="What you get from each guide"
          byline={valueProposition.voice.resourcefulDelivery}
        />
        <CardGrid columns={2} style="margin-top: var(--space-2xl);">
          <Card
            title="Context and constraints"
            description="Sector pressures, compliance obligations, and operating rhythm, so recommendations follow your business model rather than a generic catalogue."
            icon="fas fa-map-marker-alt"
          />
          <Card
            title="Evidence and trade-offs"
            description="Grants, integration cost, and sequencing clearly outlined, including what to defer when budget or capacity is constrained."
            icon="fas fa-balance-scale"
          />
          <Card
            title="Next actions"
            description="Practical next steps you can start immediately or incorporate into a scoped engagement with Brisbane Servers."
            icon="fas fa-arrow-right"
          />
          <Card
            title="Reviewed for consistency"
            description="Published guides are scored against our voice profile so tone stays evidence-led and implementation-ready; scores above 80% indicate strong alignment."
            icon="fas fa-check-circle"
          />
        </CardGrid>
      </div>
    </section>

    <!-- Layout A: Masonry-style grid with phi proportions -->
    <!-- Comprehensive block usage: phi-line-vertical, phi-line-vertical-inv, phi-lateral-angular-2, bg-pattern-phi-grid -->
    <section class="section section-tartan-accent section-home-band--surface">
      <div class="bg-pattern-phi-grid bg-pattern-soft"></div>
      <div class="phi-line-vertical phi-line-vertical-inv"></div>
      <div class="phi-lateral-angular-2"></div>
      <div class="container">
        <SectionIntro
          eyebrow="Industry hubs"
          title="Browse by industry"
          byline="Each industry hub highlights where technology earns its place across margin, compliance, and capacity, with guides combining context, evidence, and next actions."
        />
        
        <IndustryFilters />
        
        <CardGrid>
          {industries.map((industry) => (
            <Card
              title={industry.name}
              description={industry.description}
              icon={industry.icon}
              industry={industry.slug}
            >
              <a href={`/resources/${industry.slug}`} class="btn btn-secondary" style="margin-top: var(--space-lg);">
                Explore {industry.name}
              </a>
              
              {industry.topics.length > 0 && (
                <div class="topic-cards" style="margin-top: var(--space-lg);">
                  {industry.topics.map((topic) => (
                    <a href={`/resources/${industry.slug}/${topic.slug}`} class="topic-card">
                      <i class={topic.icon}></i>
                      <span>{topic.name}</span>
                    </a>
                  ))}
                </div>
              )}
            </Card>
          ))}
        </CardGrid>
      </div>
    </section>

    <InquiryForm locationField={true} />
    </MarketingPageBands>
</SiteShell>

<style>
  .resources-2032-bridge {
    margin-top: var(--space-md);
    max-width: 72ch;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .resources-2032-bridge a {
    font-weight: var(--font-weight-semibold);
    color: var(--primary-color);
  }
</style>

