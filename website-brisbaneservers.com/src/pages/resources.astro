---
import SiteShell from '../layouts/SiteShell.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import SearchBar from '../components/SearchBar.astro';
import IndustryFilters from '../components/IndustryFilters.astro';
import InquiryForm from '../components/InquiryForm.astro';
import SemanticText from '../components/SemanticText.astro';
import MarketingPageBands from '../components/MarketingPageBands.astro';
import { industries } from '../data/industries';
import { valueProposition } from '../data/value-proposition';
import { resourceVoiceInterconnection } from '../lib/portal-voice-framework';
import { getPublishedResourcesForPage } from '../lib/public-published-resources';

const publishedResources = await getPublishedResourcesForPage();

const currentPath = '/resources';
const featuredResources = publishedResources.slice(0, 6); // Show up to 6 most recent
const breadcrumbsTrail = [
  { label: 'Home', href: '/' },
  { label: 'Resources' },
];
---

<SiteShell 
  title="Resources - Brisbane Servers"
  description={valueProposition.resources.description}
  currentPath={currentPath}
  breadcrumbs={breadcrumbsTrail}
  pageId="resources"
  valueProfile="evidence"
  zoomProfile="focused"
  mainClass="main-phi-chassis"
>
    <Hero 
      eyebrow={valueProposition.brandEyebrow}
      title="Resources & insights"
      subtitle={valueProposition.resources.heroSubtitle}
    />
    <Breadcrumbs items={breadcrumbsTrail} />
    
    <MarketingPageBands>
    <section class="section section-tartan-accent section-home-band--surface" style="padding-top: 0;">
      <div class="container">
        <SearchBar />
      </div>
    </section>

    <!-- What Are Resources Section -->
    <section class="section section-tartan-accent section-home-band--primary-light phi-line-symmetrical">
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-line-vertical"></div>
      <div class="container">
        <div class="section-intro-phi">
          <h2 class="section-title">
            <SemanticText text="How these resources help you decide" semanticLevel="high" isParent={true} />
          </h2>
          <p class="section-description">
            <SemanticText text="Industry-specific guides reviewed for voice consistency, practical relevance, and evidence quality — aligned with how Brisbane Servers consults in the field." semanticLevel="normal" isChild={true} />
          </p>
          <p class="section-description" style="margin-top: var(--space-md); max-width: 62ch;">
            <SemanticText text={resourceVoiceInterconnection.headline} semanticLevel="normal" isChild={true} />
          </p>
        </div>
        
        <CardGrid columns={3} style="margin-top: var(--space-2xl);">
          <Card
            title="Voice Validated"
            description="Every published resource is checked against our voice profile so guidance stays clear, grounded, and consistent."
            icon="fas fa-check-circle"
          />
          <Card
            title="Industry Specific"
            description="Resources are tailored to specific industries—retail, healthcare, hospitality, professional services, and more. Each addresses unique challenges and opportunities."
            icon="fas fa-industry"
          />
          <Card
            title="Evidence Based"
            description="Resources include documented proof points, field examples, and implementable guidance rather than abstract theory."
            icon="fas fa-book"
          />
        </CardGrid>
      </div>
    </section>

    {featuredResources.length > 0 && (
      <!-- Featured Resources Section -->
      <section class="section section-tartan-accent section-home-band--surface">
        <div class="bg-pattern-phi-grid bg-pattern-soft"></div>
        <div class="phi-line-vertical phi-line-vertical-inv"></div>
        <div class="container">
          <div class="section-intro-phi">
            <h2 class="section-title">
              <SemanticText text="Featured Resources" semanticLevel="high" isParent={true} />
            </h2>
            <p class="section-description">
              <SemanticText text="Recently published resources with validated voice consistency and practical recommendations for specific industries and topics." semanticLevel="normal" isChild={true} />
            </p>
          </div>
          <CardGrid columns={3}>
            {featuredResources.map((resource) => (
              <Card
                title={resource.title}
                description={resource.description}
                href={`/resources/${resource.industry}/${resource.topic}#resource-${resource.id}`}
                actionLabel="Read resource"
              >
                <div style="margin-top: var(--space-md); display: flex; gap: var(--space-sm); flex-wrap: wrap; align-items: center; font-size: var(--text-sm);">
                  <span style="color: var(--text-secondary);">
                    {resource.industry} • {resource.topic}
                  </span>
                  {resource.metadata?.voiceScore && (
                    <span style="padding: var(--space-xs) var(--space-sm); background: var(--primary-light); color: var(--primary-dark); border-radius: var(--border-radius-sm);">
                      {Math.round(resource.metadata.voiceScore * 100)}% match
                    </span>
                  )}
                </div>
              </Card>
            ))}
          </CardGrid>
        </div>
      </section>
    )}

    <!-- How Resources Are Created Section -->
    <section class="section section-tartan-accent section-home-band--primary-light">
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-lateral-angular-2"></div>
      <div class="container">
        <h2 class="section-title">
          <SemanticText text="How resources are produced" semanticLevel="high" isParent={true} />
        </h2>
        <div class="section-description" style="line-height: 1.8;">
          <p>
            <SemanticText text="Resources follow a consistent production and review flow:" semanticLevel="normal" isChild={true} />
          </p>
          <p style="margin-top: var(--space-md);">
            <strong>1. Drafting:</strong> <SemanticText text="We generate a focused first draft for the target industry and topic using controlled prompts and source constraints." semanticLevel="normal" isChild={true} />
          </p>
          <p style="margin-top: var(--space-md);">
            <strong>2. Voice Validation:</strong> <SemanticText text="Each draft is scored against our communication profile to keep language practical, evidence-led, and implementation-ready." semanticLevel="normal" isChild={true} />
          </p>
          <p style="margin-top: var(--space-md);">
            <strong>3. Quality Assurance:</strong> <SemanticText text="Resources with high voice scores (typically 80%+) are published. Lower-scoring content is refined or regenerated to meet our standards." semanticLevel="normal" isChild={true} />
          </p>
          <p style="margin-top: var(--space-md);">
            <strong>4. Continuous Improvement:</strong> <SemanticText text="Published resources can be improved using our voice framework, ensuring they remain accurate and aligned with our approach." semanticLevel="normal" isChild={true} />
          </p>
          <p style="margin-top: var(--space-md);">
            <SemanticText text="This flow keeps each resource consistent in voice quality while staying specific to grants, automation opportunities, and implementation decisions." semanticLevel="normal" isChild={true} />
          </p>
        </div>
        
        <div style="margin-top: var(--space-2xl); padding: var(--space-lg); background: var(--primary-light); border-radius: var(--border-radius); border-left: 4px solid var(--primary-color);">
          <h3 style="margin-bottom: var(--space-md);">Voice Score Explained</h3>
          <p style="margin: 0; line-height: 1.8;">
            <SemanticText text="Each resource displays a voice score percentage indicating how well it matches Brisbane Servers' voice profile. Scores of 80%+ indicate strong alignment with our practical, evidence-based approach. Resources are validated before publication to ensure quality and consistency." semanticLevel="normal" isChild={true} />
          </p>
        </div>
      </div>
    </section>

    <!-- Layout A: Masonry-style grid with phi proportions -->
    <!-- Comprehensive block usage: phi-line-vertical, phi-line-vertical-inv, phi-lateral-angular-2, bg-pattern-phi-grid -->
    <section class="section section-tartan-accent section-home-band--surface">
      <div class="bg-pattern-phi-grid bg-pattern-soft"></div>
      <div class="phi-line-vertical phi-line-vertical-inv"></div>
      <div class="phi-lateral-angular-2"></div>
      <div class="container">
        <div class="section-intro-phi">
          <h2 class="section-title">
            <SemanticText text="Browse by industry" semanticLevel="high" isParent={true} />
          </h2>
          <p class="section-description">
            <SemanticText text="Retail, healthcare, hospitality, professional services, and more — each hub collects what actually changes decisions in that sector across Brisbane and Australia." semanticLevel="normal" isChild={true} />
          </p>
        </div>
        
        <IndustryFilters />
        
        <CardGrid>
          {industries.map((industry) => (
            <Card
              title={industry.name}
              description={industry.description}
              icon={industry.icon}
              industry={industry.slug}
            >
              <a href={`/resources/${industry.slug}`} class="btn btn-secondary" style="margin-top: var(--space-lg);">
                Explore {industry.name}
              </a>
              
              {industry.topics.length > 0 && (
                <div class="topic-cards" style="margin-top: var(--space-lg);">
                  {industry.topics.map((topic) => (
                    <a href={`/resources/${industry.slug}/${topic.slug}`} class="topic-card">
                      <i class={topic.icon}></i>
                      <span>{topic.name}</span>
                    </a>
                  ))}
                </div>
              )}
            </Card>
          ))}
        </CardGrid>
      </div>
    </section>

    <InquiryForm 
      title="Questions about your industry or an idea you are exploring?"
      subtitle="Share context and goals, even as rough notes—we map options to practical next steps and plain-spoken feasibility."
      locationField={true}
    />
    </MarketingPageBands>
</SiteShell>

