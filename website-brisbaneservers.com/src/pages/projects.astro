---
import SiteShell from '../layouts/SiteShell.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import IndustryFilters from '../components/IndustryFilters.astro';
import SemanticText from '../components/SemanticText.astro';
import SectionIntro from '../components/SectionIntro.astro';
import MarketingPageBands from '../components/MarketingPageBands.astro';
import ClientSitesShowcase from '../components/ClientSitesShowcase.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import { caseStudies } from '../data/case-studies';
import { industryHubStatus } from '../data/site-completeness';
import { valueProposition } from '../data/value-proposition';
import { sitePath } from '../lib/site-path';

const currentPath = '/projects';
---

<SiteShell 
  title="Projects"
  description={valueProposition.projects.description}
  currentPath={currentPath}
  pageId="projects"
  valueProfile="evidence"
  zoomProfile="balanced"
  mainClass="main-phi-chassis"
>
    <Hero 
      eyebrow={valueProposition.brandEyebrow}
      title={valueProposition.projects.heroTitle}
      subtitle={valueProposition.projects.heroSubtitle}
    />

    <MarketingPageBands class="marketing-page-bands--projects">
    <section id="client-sites" class="section section-tartan-accent section-home-band--surface projects-page-lead">
      <div class="bg-pattern-phi-grid bg-pattern-subtle"></div>
      <div class="container">
        <div class="projects-page-lead__grid">
          <div class="projects-page-lead__copy">
            <SectionIntro
              eyebrow="Proof you can open today"
              title="Public web presences"
              byline="Sites and apps you can open in the browser today. The list is short on purpose; we expand it when new work is live and clients approve a public link."
            />
          </div>
          <div class="projects-page-lead__showcase">
            <ClientSitesShowcase showFootnote={false} layout="featured" />
          </div>
        </div>
      </div>
    </section>

    <!-- Our Approach Section -->
    <section class="section section-tartan-accent section-home-band--primary-light phi-line-symmetrical">
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-line-vertical"></div>
      <div class="container">
        <SectionIntro
          eyebrow="How we deliver"
          title="Our project approach"
          byline="Every project follows our value framework: understanding your business context, identifying what's feasible given your constraints, and delivering solutions that actually work. We don't sell one-size-fits-all—we assess your reality and recommend what makes sense."
        />

        <CardGrid columns={2} style="margin-top: var(--space-2xl);">
          <Card
            title="Assessment Phase"
            description="We start by understanding your business size, budget constraints, available grants, industry requirements, and strategic objectives. No assumptions—we gather facts."
            icon="fas fa-search"
          />
          <Card
            title="Solution Design"
            description="Based on your reality, we design solutions that fit your constraints. This might mean phased implementation, grant-assisted projects, or cost-effective alternatives."
            icon="fas fa-drafting-compass"
          />
          <Card
            title="Implementation"
            description="We work with you through implementation, ensuring solutions are properly configured, staff are trained, and systems are integrated with your existing processes."
            icon="fas fa-cogs"
          />
          <Card
            title="Results & Documentation"
            description="Every project is documented with real results, lessons learned, and measurable outcomes. This documentation becomes part of our knowledge base."
            icon="fas fa-chart-bar"
          />
        </CardGrid>
      </div>
    </section>

    <!-- Value Framework Section -->
    <section class="section section-tartan-accent section-home-band--surface">
      <div class="bg-pattern-phi-radial bg-pattern-subtle"></div>
      <div class="phi-tangent"></div>
      <div class="container">
        <SectionIntro
          eyebrow="Decision lens"
          title="Value framework"
          byline="Our value framework guides every project decision:"
        />
        <div class="projects-value-list">
          <p>
            <strong>Business Context:</strong>{' '}
            <SemanticText text="Understanding your industry, size, location, and specific challenges. What works for a large enterprise doesn't work for a small Brisbane business." semanticLevel="normal" isChild={true} />
          </p>
          <p>
            <strong>Reality Assessment:</strong>{' '}
            <SemanticText text="Honest evaluation of what's feasible given your budget, resources, and constraints. We identify grant opportunities, cost-effective alternatives, and phased approaches." semanticLevel="normal" isChild={true} />
          </p>
          <p>
            <strong>Evidence-Based Recommendations:</strong>{' '}
            <SemanticText text="Every recommendation is backed by documented proof—case studies, implementation details, and real results from similar businesses." semanticLevel="normal" isChild={true} />
          </p>
          <p>
            <strong>Practical Implementation:</strong>{' '}
            <SemanticText text="Solutions designed to be implemented, not just conceptualized. We consider staff training, integration requirements, and ongoing maintenance." semanticLevel="normal" isChild={true} />
          </p>
          <p>
            <strong>Measurable Outcomes:</strong>{' '}
            <SemanticText text="Every project includes clear success metrics and documentation of actual results. This transparency helps you make informed decisions." semanticLevel="normal" isChild={true} />
          </p>
        </div>

        <aside class="projects-highlight-band" aria-labelledby="projects-case-studies-heading">
          <h3 id="projects-case-studies-heading">Why case studies matter</h3>
          <p>
            <SemanticText text="Each case study documents a real project with actual results. You can see how we assessed the business context, what solutions we recommended, and what outcomes were achieved. This transparency helps you understand our approach and evaluate whether it's right for your business." semanticLevel="normal" isChild={true} />
          </p>
        </aside>
      </div>
    </section>

    <!-- Layout A: Showcase grid with varied card sizes -->
    <!-- Comprehensive block usage: phi-tangent, phi-lateral-angular-4, bg-pattern-phi-radial -->
    <section class="section section-tartan-accent section-home-band--primary-light projects-section">
      <div class="bg-pattern-phi-radial bg-pattern-subtle"></div>
      <div class="phi-tangent"></div>
      <div class="phi-lateral-angular-4"></div>
      <div class="container">
        <SectionIntro
          eyebrow="Case studies and patterns"
          title="Projects by industry"
          byline="Each project demonstrates our value framework in action: understanding your business context, identifying what's feasible, and delivering tailored solutions for Brisbane and Australian businesses."
        />
        
        <IndustryFilters />
        
        <CardGrid>
          {caseStudies.map((study) => (
            <CaseStudyCard study={study} />
          ))}
        </CardGrid>

        {
          industryHubStatus.some((h) => h.status === 'overview-only') && (
            <p class="projects-completeness-note">
              Industry hubs for{' '}
              {industryHubStatus
                .filter((h) => h.status === 'overview-only')
                .map((h) => h.label)
                .join(', ')}{' '}
              include overview guides today; topic libraries are expanding — see{' '}
              <a href={sitePath('/case-studies')}>case studies</a> and{' '}
              <a href={sitePath('/resources')}>resources</a> for what is live now.
            </p>
          )
        }
      </div>
    </section>

    <!-- Project Types Section -->
    <section class="section section-tartan-accent section-home-band--surface">
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-lateral-angular-2"></div>
      <div class="container">
        <SectionIntro
          eyebrow="Engagement shapes"
          title="Types of projects we handle"
          byline="We deliver projects from targeted automation to full system implementation. These are common engagement types:"
        />

        <CardGrid columns={2} style="margin-top: var(--space-xl);">
          <Card
            title="Database & Data Management"
            description="Moving from spreadsheets to proper databases, implementing data management systems, and setting up automated reporting."
            icon="fas fa-database"
          />
          <Card
            title="E-commerce Integration"
            description="Connecting physical stores with online platforms, inventory synchronization, and unified customer experiences."
            icon="fas fa-shopping-cart"
          />
          <Card
            title="Process Automation"
            description="Identifying repetitive tasks that can be automated, implementing workflow systems, and reducing manual effort."
            icon="fas fa-robot"
          />
          <Card
            title="Compliance & Security"
            description="Implementing systems that meet industry compliance requirements (APP, healthcare regulations, etc.) with proper security."
            icon="fas fa-shield-alt"
          />
          <Card
            title="Grant-Assisted Projects"
            description="Identifying and applying for digital transformation grants, then implementing solutions that qualify for funding."
            icon="fas fa-hand-holding-usd"
          />
          <Card
            title="System Integration"
            description="Connecting existing systems, APIs, and platforms to create unified workflows and eliminate data silos."
            icon="fas fa-plug"
          />
        </CardGrid>
      </div>
    </section>

    <!-- Getting Started Section -->
    <section class="section section-tartan-accent section-home-band--primary-light">
      <div class="bg-pattern-phi-grid bg-pattern-soft"></div>
      <div class="container">
        <SectionIntro
          eyebrow="Next step"
          title="Getting started"
          byline="Review case studies and public sites, then book a consultation — we will map feasibility, grants where relevant, and a sensible first slice of work."
        />

        <div class="projects-cta-row">
          <a href={sitePath('/case-studies')} class="btn btn-primary">View case studies</a>
          <a href={sitePath('/resources')} class="btn btn-secondary">Explore Resources</a>
          <a href={sitePath('/services')} class="btn btn-secondary">Our Services</a>
        </div>
      </div>
    </section>
    </MarketingPageBands>
</SiteShell>

<style>
  .projects-completeness-note {
    margin-top: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-secondary);
    border-radius: var(--border-radius);
    border: 1px dashed rgba(var(--primary-color-rgb), 0.2);
    background: rgba(255, 255, 255, 0.85);
    max-width: 72ch;
  }

  .projects-completeness-note a {
    color: var(--primary-color);
    font-weight: var(--font-weight-semibold);
  }
</style>

