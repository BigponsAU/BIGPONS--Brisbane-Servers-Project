---
import SiteShell from '../layouts/SiteShell.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import IndustryFilters from '../components/IndustryFilters.astro';
import SemanticText from '../components/SemanticText.astro';
import SectionIntro from '../components/SectionIntro.astro';
import MarketingPageBands from '../components/MarketingPageBands.astro';
import ClientSitesShowcase from '../components/ClientSitesShowcase.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import { caseStudies } from '../data/case-studies';
import { industryHubStatus } from '../data/site-completeness';
import { valueProposition } from '../data/value-proposition';
import { sitePath } from '../lib/site-path';

const currentPath = '/projects';
---

<SiteShell 
  title="Projects"
  description={valueProposition.projects.description}
  currentPath={currentPath}
  pageId="projects"
  valueProfile="evidence"
  zoomProfile="balanced"
  mainClass="main-phi-chassis"
>
    <Hero 
      eyebrow={valueProposition.brandEyebrow}
      title={valueProposition.projects.heroTitle}
      subtitle={valueProposition.projects.heroSubtitle}
    />

    <MarketingPageBands class="marketing-page-bands--projects">
    <section id="client-sites" class="section section-tartan-accent section-home-band--surface projects-page-lead">
      <div class="bg-pattern-phi-grid bg-pattern-subtle"></div>
      <div class="container">
        <div class="projects-page-lead__grid">
          <div class="projects-page-lead__copy">
            <SectionIntro
              eyebrow="Proof you can open today"
              title="Public web presences"
              byline="Sites and apps you can open in the browser today. The list is short on purpose; we expand it when new work is live and clients approve a public link."
            />
          </div>
          <div class="projects-page-lead__showcase">
            <ClientSitesShowcase showFootnote={false} layout="featured" />
          </div>
        </div>
      </div>
    </section>

    <!-- Our Approach Section -->
    <section class="section section-tartan-accent section-home-band--primary-light phi-line-symmetrical">
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-line-vertical"></div>
      <div class="container">
        <SectionIntro
          eyebrow="How we deliver"
          title="Our project approach"
          byline="Every engagement follows a clear value framework: understand your operating context, test what is feasible within constraints, and deliver solutions that perform in practice."
        />

        <CardGrid columns={2} style="margin-top: var(--space-2xl);">
          <Card
            title="Assessment phase"
            description="We start with facts: business scale, budget limits, available incentives, industry obligations, and strategic priorities."
            icon="fas fa-search"
          />
          <Card
            title="Solution design"
            description="Recommendations are designed around your operating reality, including phased delivery, grant-aligned options, and cost-effective alternatives."
            icon="fas fa-drafting-compass"
          />
          <Card
            title="Implementation"
            description="We deliver with your team, ensuring systems are configured correctly, staff are supported, and workflows integrate with existing operations."
            icon="fas fa-cogs"
          />
          <Card
            title="Results and documentation"
            description="Each project records measurable outcomes, lessons learned, and implementation detail to support future decision-making."
            icon="fas fa-chart-bar"
          />
        </CardGrid>
      </div>
    </section>

    <!-- Value Framework Section -->
    <section class="section section-tartan-accent section-home-band--surface">
      <div class="bg-pattern-phi-radial bg-pattern-subtle"></div>
      <div class="phi-tangent"></div>
      <div class="container">
        <SectionIntro
          eyebrow="Decision lens"
          title="Value framework"
          byline="Our value framework guides every material project decision:"
        />
        <div class="projects-value-list">
          <p>
            <strong>Business context:</strong>{' '}
            <SemanticText text="Recommendations reflect your industry, scale, and operating conditions. What suits a large enterprise rarely suits a smaller Australian business without adjustment." semanticLevel="normal" isChild={true} />
          </p>
          <p>
            <strong>Reality assessment:</strong>{' '}
            <SemanticText text="Feasibility is tested against budget, team capacity, and constraints, including grant pathways, alternatives, and phased rollout options." semanticLevel="normal" isChild={true} />
          </p>
          <p>
            <strong>Evidence-based recommendations:</strong>{' '}
            <SemanticText text="Recommendations are supported by documented delivery patterns, implementation detail, and measurable outcomes from comparable scenarios." semanticLevel="normal" isChild={true} />
          </p>
          <p>
            <strong>Practical implementation:</strong>{' '}
            <SemanticText text="Solutions are designed to be deployed, adopted, and maintained, with training, integration requirements, and support obligations considered early." semanticLevel="normal" isChild={true} />
          </p>
          <p>
            <strong>Measurable outcomes:</strong>{' '}
            <SemanticText text="Success criteria are defined upfront and results are documented transparently so stakeholders can make informed decisions." semanticLevel="normal" isChild={true} />
          </p>
        </div>

        <aside class="projects-highlight-band" aria-labelledby="projects-case-studies-heading">
          <h3 id="projects-case-studies-heading">Why case studies matter</h3>
          <p>
            <SemanticText text="Each case study documents a real engagement and outcome. You can review context, options considered, and delivery results to evaluate fit before committing." semanticLevel="normal" isChild={true} />
          </p>
        </aside>
      </div>
    </section>

    <!-- Layout A: Showcase grid with varied card sizes -->
    <!-- Comprehensive block usage: phi-tangent, phi-lateral-angular-4, bg-pattern-phi-radial -->
    <section class="section section-tartan-accent section-home-band--primary-light projects-section">
      <div class="bg-pattern-phi-radial bg-pattern-subtle"></div>
      <div class="phi-tangent"></div>
      <div class="phi-lateral-angular-4"></div>
      <div class="container">
        <SectionIntro
          eyebrow="Case studies and patterns"
          title="Projects by industry"
          byline="Each project demonstrates the framework in action: context first, feasibility second, then tailored delivery for Brisbane and Australian businesses."
        />
        
        <IndustryFilters />
        
        <CardGrid>
          {caseStudies.map((study) => (
            <CaseStudyCard study={study} />
          ))}
        </CardGrid>

        {
          industryHubStatus.some((h) => h.status === 'overview-only') && (
            <p class="projects-completeness-note">
              Industry hubs for{' '}
              {industryHubStatus
                .filter((h) => h.status === 'overview-only')
                .map((h) => h.label)
                .join(', ')}{' '}
              currently include overview guides while topic libraries expand — see{' '}
              <a href={sitePath('/case-studies')}>case studies</a> and{' '}
              <a href={sitePath('/resources')}>resources</a> for what is live now.
            </p>
          )
        }
      </div>
    </section>

    <!-- Project Types Section -->
    <section class="section section-tartan-accent section-home-band--surface">
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-lateral-angular-2"></div>
      <div class="container">
        <SectionIntro
          eyebrow="Engagement shapes"
          title="Types of projects we handle"
          byline="We deliver work ranging from targeted automation to broader system implementation. Common engagement types include:"
        />

        <CardGrid columns={2} style="margin-top: var(--space-xl);">
          <Card
            title="Database and data management"
            description="Transitioning from spreadsheets to structured data platforms, with governance and automated reporting where appropriate."
            icon="fas fa-database"
          />
          <Card
            title="E-commerce integration"
            description="Connecting physical operations with online channels, including inventory synchronisation and unified customer workflows."
            icon="fas fa-shopping-cart"
          />
          <Card
            title="Process automation"
            description="Identifying repetitive tasks suitable for automation, implementing workflow systems, and reducing manual overhead."
            icon="fas fa-robot"
          />
          <Card
            title="Compliance and security"
            description="Implementing systems that meet relevant compliance obligations, including APP and sector-specific requirements, with appropriate controls."
            icon="fas fa-shield-alt"
          />
          <Card
            title="Grant-assisted projects"
            description="Identifying suitable digital transformation grants, supporting applications, and delivering projects aligned with funding criteria."
            icon="fas fa-hand-holding-usd"
          />
          <Card
            title="System integration"
            description="Connecting existing systems, APIs, and platforms to create unified workflows and reduce data silos."
            icon="fas fa-plug"
          />
        </CardGrid>
      </div>
    </section>

    <!-- Getting Started Section -->
    <section class="section section-tartan-accent section-home-band--primary-light">
      <div class="bg-pattern-phi-grid bg-pattern-soft"></div>
      <div class="container">
        <SectionIntro
          eyebrow="Next step"
          title="Getting started"
          byline="Review case studies and public sites, then book a consultation. We will map feasibility, relevant incentives, and a practical first phase of work."
        />

        <div class="projects-cta-row">
          <a href={sitePath('/case-studies')} class="btn btn-primary">View case studies</a>
          <a href={sitePath('/resources')} class="btn btn-secondary">Explore resources</a>
          <a href={sitePath('/services')} class="btn btn-secondary">Our services</a>
        </div>
      </div>
    </section>
    </MarketingPageBands>
</SiteShell>

<style>
  .projects-completeness-note {
    margin-top: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-secondary);
    border-radius: var(--border-radius);
    border: 1px dashed rgba(var(--primary-color-rgb), 0.2);
    background: rgba(255, 255, 255, 0.85);
    max-width: 72ch;
  }

  .projects-completeness-note a {
    color: var(--primary-color);
    font-weight: var(--font-weight-semibold);
  }
</style>

