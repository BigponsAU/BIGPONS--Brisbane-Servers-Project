---
export const prerender = true;

import SiteShell from '../layouts/SiteShell.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import InquiryForm from '../components/InquiryForm.astro';
import SectionIntro from '../components/SectionIntro.astro';
import SectionConstellationLayer from '../components/SectionConstellationLayer.astro';
import MarketingPageBands from '../components/MarketingPageBands.astro';
import { valueProposition } from '../data/value-proposition';

const currentPath = '/services';
const { sections } = valueProposition.services;
---

<SiteShell
  title="Services"
  description={valueProposition.services.description}
  currentPath={currentPath}
  pageId="services"
  valueProfile="utility"
  zoomProfile="focused"
  mainClass="main-phi-chassis"
>
  <Hero
    eyebrow={valueProposition.brandEyebrow}
    title={valueProposition.services.heroTitle}
    subtitle={valueProposition.services.heroSubtitle}
    ctaText="Request a consultation"
    ctaHref="/services#consultation"
    scrollTargetId="#consultation"
    scrollLabel="Continue to contact"
  />

  <MarketingPageBands class="marketing-page-bands--constellation-spine">
    <section class="section section-tartan-accent section-home-band--surface phi-line-symmetrical">
      <SectionConstellationLayer variant="solutions" semanticKey="services-delivery" tier="whisper" placement="top-right" />
      <div class="bg-pattern-phi-radial bg-pattern-subtle"></div>
      <div class="phi-lateral-horizontal"></div>
      <div class="phi-tangent"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.delivery.eyebrow}
          title={sections.delivery.title}
          byline={sections.delivery.byline}
        />
        <CardGrid columns={2} style="margin-top: var(--space-2xl);">
          <Card
            title="Consultation"
            description="Structured in-person or online sessions to map operating context, constraints, and objectives, with scope and trade-offs documented before delivery."
            featureGlyph="evidence"
          />
          <Card
            title="Analysis"
            description="We handle technology research, information filtering, and feasibility checks. You stay focused on operations while we identify practical options."
            featureGlyph="semantic-search"
          />
          <Card
            title="Implementation"
            description="We build and deploy solutions aligned to your value framework, using phased delivery and grant support where available."
            featureGlyph="automation"
          />
          <Card
            title="Ongoing support"
            description="Access to expertise when you need it, including updates, adjustments, and guidance as your business evolves."
            featureGlyph="integration"
          />
        </CardGrid>
      </div>
    </section>

    <section class="section section-tartan-accent section-home-band--primary-light">
      <SectionConstellationLayer variant="solutions" semanticKey="services-value" tier="whisper" placement="bottom-left" />
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-line-vertical"></div>
      <div class="phi-lateral-angular-1"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.valueProfile.eyebrow}
          title={sections.valueProfile.title}
          byline={sections.valueProfile.byline}
        />
        <CardGrid columns={2} style="margin-top: var(--space-2xl);">
          <Card
            title="Business size and standing"
            description="Recommendations reflect current capability, foundational gaps, and existing strengths, then scale from your present position."
          />
          <Card
            title="Cost reasonableness"
            description="Recommendations are tested against your financial position, prioritising sensible investment and measurable return."
          />
          <Card
            title="Grants and incentives"
            description="We identify grants and tax incentives relevant to your industry and goals, then help you act on viable opportunities."
          />
          <Card
            title="Industry specifics"
            description="Recommendations account for field-specific requirements, compliance obligations, and what consistently works in your industry."
          />
          <Card
            title="Time savings"
            description="Automation is applied to repetitive, low-value tasks so your team can focus on higher-value work."
          />
        </CardGrid>
      </div>
    </section>

    <InquiryForm
      id="consultation"
      title="Request a consultation"
      subtitle="Book a physical or online consultation by appointment. We align recommendations to your industry, scope, and agreed budget."
      industryField={true}
      preferenceField={true}
    />
  </MarketingPageBands>
</SiteShell>
