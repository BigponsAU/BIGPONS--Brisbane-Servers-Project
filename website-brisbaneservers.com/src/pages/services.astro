---
import SiteShell from '../layouts/SiteShell.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import InquiryForm from '../components/InquiryForm.astro';
import SectionIntro from '../components/SectionIntro.astro';
import SectionConstellationLayer from '../components/SectionConstellationLayer.astro';
import MarketingPageBands from '../components/MarketingPageBands.astro';
import { valueProposition } from '../data/value-proposition';

const currentPath = '/services';
const { sections } = valueProposition.services;
---

<SiteShell
  title="Services"
  description={valueProposition.services.description}
  currentPath={currentPath}
  pageId="services"
  valueProfile="utility"
  zoomProfile="focused"
  mainClass="main-phi-chassis"
>
  <Hero
    eyebrow={valueProposition.brandEyebrow}
    title={valueProposition.services.heroTitle}
    subtitle={valueProposition.services.heroSubtitle}
    ctaText="Request a consultation"
    ctaHref="/services#consultation"
    scrollTargetId="#consultation"
    scrollLabel="Continue to contact"
  />

  <MarketingPageBands class="marketing-page-bands--constellation-spine">
    <section class="section section-tartan-accent section-home-band--surface phi-line-symmetrical">
      <SectionConstellationLayer variant="solutions" semanticKey="services-delivery" tier="whisper" placement="top-right" />
      <div class="bg-pattern-phi-radial bg-pattern-subtle"></div>
      <div class="phi-lateral-horizontal"></div>
      <div class="phi-tangent"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.delivery.eyebrow}
          title={sections.delivery.title}
          byline={sections.delivery.byline}
        />
        <CardGrid columns={2} style="margin-top: var(--space-2xl);">
          <Card
            title="Consultation"
            description="Structured physical or online sessions to map operating context, constraints, and objectives — scope and trade-offs documented before delivery."
            icon="fas fa-comments"
          />
          <Card
            title="Analysis"
            description="We do the tech learning, information sifting, and reality checking. You focus on your business; we identify feasible solutions."
            icon="fas fa-search"
          />
          <Card
            title="Implementation"
            description="Building and deploying solutions tailored to your value framework. Phased approach, grant-assisted when available."
            icon="fas fa-rocket"
          />
          <Card
            title="Ongoing support"
            description="Access to expertise when you need it. Updates, adjustments, and guidance as your business evolves."
            icon="fas fa-headset"
          />
        </CardGrid>
      </div>
    </section>

    <section class="section section-tartan-accent section-home-band--primary-light">
      <SectionConstellationLayer variant="solutions" semanticKey="services-value" tier="whisper" placement="bottom-left" />
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="phi-line-vertical"></div>
      <div class="phi-lateral-angular-1"></div>
      <div class="container">
        <SectionIntro
          eyebrow={sections.valueProfile.eyebrow}
          title={sections.valueProfile.title}
          byline={sections.valueProfile.byline}
        />
        <CardGrid columns={2} style="margin-top: var(--space-2xl);">
          <Card
            title="Business size and standing"
            description="Current capabilities, basics missing, unique advantages. Solutions scaled to where you are today."
          />
          <Card
            title="Cost reasonableness"
            description="What is feasible for your financial position. Smart investments, not overspending. ROI-focused recommendations."
          />
          <Card
            title="Grants and incentives"
            description="What is available for your industry and purpose. We help you access grants and tax incentives."
          />
          <Card
            title="Industry specifics"
            description="Field-relevant requirements, compliance needs, and what actually works in your industry."
          />
          <Card
            title="Time savings"
            description="Automation for tedious, menial tasks — freeing your time for high-value work."
          />
        </CardGrid>
      </div>
    </section>

    <InquiryForm
      id="consultation"
      title="Request a consultation"
      subtitle="Book a physical or online consultation by appointment. We align recommendations to your industry, scope, and agreed budget."
      industryField={true}
      preferenceField={true}
    />
  </MarketingPageBands>
</SiteShell>
