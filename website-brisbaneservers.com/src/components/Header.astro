---
import { navigation, navDropdownToggleIsActive } from '../data/navigation';
import { inquiryNavHref } from '../lib/inquiry-nav-href';
import { sitePath } from '../lib/site-path';
import logo from '../logo.png';
import MobileNavMenu from './MobileNavMenu.astro';
import NavMegaMenu from './NavMegaMenu.astro';
import NavSimpleMenu from './NavSimpleMenu.astro';
import SemanticText from './SemanticText.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const navItems = navigation.filter(
  (item) =>
    !(item.href === '/' && currentPath === '/') &&
    item.href !== '/account',
);

const inquireHref = inquiryNavHref(currentPath, sitePath);

function isActive(href: string): boolean {
  const pathOnly = href.split('#')[0] || href;
  if (pathOnly === '/' && currentPath === '/') return true;
  if (pathOnly !== '/' && currentPath.startsWith(pathOnly)) return true;
  return false;
}

function dropdownSlug(label: string): string {
  return label.toLowerCase().replace(/\s+/g, '-');
}
---

<header data-state-aware="true" class="header-state-aware" role="banner">
  <div class="phi-lateral-angular-1 header-angular" aria-hidden="true"></div>
  <nav role="navigation" aria-label="Main navigation">
    <a href={sitePath('/')} class="nav-brand" aria-label="Brisbane Servers - Home">
      <img src={logo.src} alt="Brisbane Servers Logo" width={logo.width} height={logo.height} />
      <span class="nav-brand-text">
        <SemanticText text="Brisbane Servers" semanticLevel="high" preserveCase />
      </span>
      <span class="nav-tagline">
        <SemanticText text="Access to truth in technology" semanticLevel="normal" />
      </span>
    </a>

    <ul class="nav-menu" role="menubar">
      {
        navItems.map((item, index) => {
          const hasPanel = Boolean(item.groups?.length || item.children?.length);
          const active = navDropdownToggleIsActive(item, currentPath);
          const slug = dropdownSlug(item.label);
          const menuId = `dropdown-menu-${index}`;
          const toggleId = `dropdown-toggle-${index}`;

          return hasPanel ? (
            <li
              class:list={['nav-dropdown', `nav-dropdown--${slug}`]}
              role="none"
            >
              <a
                href={sitePath(item.href)}
                class:list={['nav-dropdown-toggle', active && 'active']}
                role="menuitem"
                aria-haspopup="true"
                aria-expanded="false"
                aria-controls={menuId}
                id={toggleId}
              >
                <SemanticText text={item.label} semanticLevel="normal" />
                <span class="sr-only"> submenu</span>
              </a>
              {item.groups ? (
                <NavMegaMenu
                  groups={item.groups}
                  menuId={menuId}
                  toggleId={toggleId}
                  currentPath={currentPath}
                />
              ) : (
                <NavSimpleMenu
                  children={item.children!}
                  menuId={menuId}
                  toggleId={toggleId}
                  currentPath={currentPath}
                />
              )}
            </li>
          ) : (
            <li role="none">
              <a
                href={sitePath(item.href)}
                class:list={[
                  isActive(item.href) && 'active',
                  item.href === '/account' && 'nav-account-cta',
                ]}
                data-account-link={item.href === '/account' ? 'true' : undefined}
                role="menuitem"
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                <SemanticText text={item.label} semanticLevel="normal" />
              </a>
            </li>
          );
        })
      }
      <li class="nav-menu__cta" role="none">
        <a
          href={sitePath('/account')}
          class="nav-account-cta"
          data-account-link="true"
          role="menuitem"
        >
          <SemanticText text="Sign in" semanticLevel="normal" />
        </a>
      </li>
      <li class="nav-menu__cta" role="none">
        <a href={inquireHref} class="nav-inquire-cta" role="menuitem">
          <SemanticText text="Inquire" semanticLevel="normal" />
        </a>
      </li>
    </ul>

    <button
      class="hamburger"
      aria-label="Toggle mobile menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

    <MobileNavMenu navItems={navItems} currentPath={currentPath} />
  </nav>
</header>
