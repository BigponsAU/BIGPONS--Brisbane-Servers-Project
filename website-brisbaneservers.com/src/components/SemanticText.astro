---
import { formatHeadingCopy } from '../lib/copy-style';

interface Props {
  text: string;
  class?: string;
  semanticLevel?: 'high' | 'medium' | 'normal';
  isParent?: boolean;
  isChild?: boolean;
  parentClass?: string;
  /** Keep source casing (brand names, legal copy) */
  preserveCase?: boolean;
}

const {
  text,
  class: className = '',
  semanticLevel = 'normal',
  isParent = false,
  isChild = false,
  parentClass = '',
  preserveCase = false,
} = Astro.props;

const displayText =
  !preserveCase && (isParent || semanticLevel === 'high') ? formatHeadingCopy(text) : text;

// Simplified typography component - removed wave function cipher system
// Semantic levels map to standard typography variants for hierarchy
const semanticClasses = [
  `semantic-text`,
  `semantic-${semanticLevel}`,
  isParent ? 'semantic-parent' : '',
  isChild ? 'semantic-child' : '',
  parentClass,
  className
].filter(Boolean).join(' ');
---

<span class={semanticClasses} data-semantic-level={semanticLevel}>
  {displayText}
</span>

<style>
  .semantic-text {
    display: inline;
    color: inherit;
    line-height: 1.6;
  }

  /* Semantic level typography variants - standardized for site-level Gestalt */
  .semantic-high {
    font-weight: 600;
    font-size: inherit;
    color: inherit;
  }

  .semantic-medium {
    font-weight: 500;
    font-size: inherit;
    color: inherit;
  }

  .semantic-normal {
    font-weight: 400;
    font-size: inherit;
    color: inherit;
  }

  /* Parent/Child relationships for hierarchy */
  .semantic-parent {
    font-weight: 600;
    color: var(--primary-dark);
  }

  .semantic-child {
    font-weight: 400;
    color: var(--text-secondary);
  }
</style>
