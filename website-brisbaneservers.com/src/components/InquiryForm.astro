---
import SemanticText from './SemanticText.astro';
import { valueProposition } from '../data/value-proposition';

interface Props {
  title?: string;
  subtitle?: string;
  industryField?: boolean;
  locationField?: boolean;
  preferenceField?: boolean;
  defaultIndustry?: string;
  id?: string;
}

const {
  title = valueProposition.inquiry.title,
  subtitle = valueProposition.inquiry.subtitle,
  industryField = true,
  locationField = false,
  preferenceField = false,
  defaultIndustry = '',
  id = 'inquiry-section',
} = Astro.props;

const { inquiry } = valueProposition;
---

<section class="inquiry-section" id={id}>
  <div class="container">
    <div class="inquiry-form">
      <h2 class="inquiry-form-title">
        <SemanticText text={title} semanticLevel="high" isParent={true} />
      </h2>
      {subtitle && (
        <p class="inquiry-form-subtitle">
          <SemanticText text={subtitle} semanticLevel="medium" isChild={true} />
        </p>
      )}

      <form
        action="javascript:void(0)"
        aria-label="Enquiry form"
        autocomplete="on"
        novalidate
      >
        <div class="form-group">
          <label for="name">{inquiry.nameLabel}</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder={inquiry.namePlaceholder}
            aria-describedby="name-hint"
            autocomplete="name"
          />
          <span id="name-hint" class="sr-only">Your name for our reply</span>
        </div>

        <div class="form-group">
          <label for="email">
            {inquiry.emailLabel} <span class="required-indicator" aria-label="required">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder={inquiry.emailPlaceholder}
            required
            aria-required="true"
            aria-describedby="email-error email-hint"
            autocomplete="email"
          />
          <span id="email-hint" class="sr-only">A valid email address for our response</span>
          <span id="email-error" class="form-error" role="alert" aria-live="polite"></span>
        </div>

        {industryField && (
          <div class="form-group">
            <label for="industry">{inquiry.industryLabel}</label>
            {defaultIndustry ? (
              <input
                type="text"
                id="industry"
                name="industry"
                value={defaultIndustry}
                readonly
                class="form-input--readonly"
                aria-readonly="true"
              />
            ) : (
              <select id="industry" name="industry" aria-describedby="industry-hint">
                <option value="">{inquiry.industryPlaceholder}</option>
                <option value="Professional Services">Professional Services</option>
                <option value="Retail & E-commerce">Retail & E-commerce</option>
                <option value="Healthcare">Healthcare</option>
                <option value="Hospitality">Hospitality</option>
                <option value="Construction & Trades">Construction & Trades</option>
                <option value="Finance & Accounting">Finance & Accounting</option>
                <option value="Manufacturing">Manufacturing</option>
                <option value="Other">Other</option>
              </select>
            )}
            <span id="industry-hint" class="sr-only">Industry that best describes your business</span>
          </div>
        )}

        {locationField && (
          <div class="form-group">
            <label for="location">Business location (optional)</label>
            <input
              type="text"
              id="location"
              name="location"
              placeholder="e.g. Brisbane, QLD"
              autocomplete="address-level2"
            />
          </div>
        )}

        {preferenceField && (
          <div class="form-group">
            <label for="preference">Consultation preference</label>
            <select id="preference" name="preference" aria-describedby="preference-hint">
              <option value="online">Online consultation</option>
              <option value="physical">In person (Brisbane)</option>
              <option value="no-preference">No preference</option>
            </select>
            <span id="preference-hint" class="sr-only">Preferred consultation format</span>
          </div>
        )}

        <div class="form-group">
          <label for="message">{inquiry.messageLabel}</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            placeholder={inquiry.messagePlaceholder}
            aria-describedby="message-hint"
          ></textarea>
          <span id="message-hint" class="sr-only">Describe your enquiry or initiative</span>
        </div>

        <button type="submit" class="btn btn-primary btn-block" aria-describedby="submit-hint">
          <i class="fas fa-paper-plane" aria-hidden="true"></i>
          <span>{preferenceField ? 'Request consultation' : inquiry.submitLabel}</span>
        </button>
        <span id="submit-hint" class="sr-only">Submit your enquiry</span>

        <p class="form-disclaimer" role="note">
          {inquiry.disclaimer}
        </p>
      </form>
    </div>
  </div>
</section>
