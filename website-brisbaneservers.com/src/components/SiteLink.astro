---
import { sitePath } from '../lib/site-path';

interface Props {
  href: string;
  class?: string;
  [key: string]: unknown;
}

const { href, class: className, ...rest } = Astro.props;
const resolvedHref = /^(?:https?:|mailto:|tel:|#)/i.test(href) ? href : sitePath(href);
---

<a href={resolvedHref} class={className} {...rest}><slot /></a>
