---
import type { InfographicNode, InfographicSpec } from '../data/topic-guides/infographic-types';

interface Props {
  spec: InfographicSpec;
  /** feature = full-width guide band; aside = legacy compact sidebar */
  variant?: 'default' | 'aside' | 'feature';
}

const { spec, variant = 'feature' } = Astro.props;
const isAside = variant === 'aside';
const isFeature = variant === 'feature';
const nodeById = Object.fromEntries(spec.nodes.map((n) => [n.id, n])) as Record<string, InfographicNode>;
const badgeNote = spec.badges?.map((b) => b.text).join(' · ');

function edgePath(from: InfographicNode, to: InfographicNode): string {
  const dx = to.x - from.x;
  const dy = to.y - from.y;
  const dist = Math.hypot(dx, dy) || 1;
  const padFrom = from.kind === 'hub' ? 36 : from.kind === 'outcome' ? 28 : 22;
  const padTo = to.kind === 'hub' ? 36 : to.kind === 'outcome' ? 28 : 22;
  const x1 = from.x + (dx / dist) * padFrom;
  const y1 = from.y + (dy / dist) * padFrom;
  const x2 = to.x - (dx / dist) * padTo;
  const y2 = to.y - (dy / dist) * padTo;
  const cx = (x1 + x2) / 2 + (dy / dist) * 14;
  const cy = (y1 + y2) / 2 - (dx / dist) * 14;
  return `M ${x1} ${y1} Q ${cx} ${cy} ${x2} ${y2}`;
}
---

<figure
  class:list={[
    'guide-infographic',
    isAside && 'guide-infographic--aside',
    isFeature && 'guide-infographic--feature',
  ]}
  role="group"
  aria-labelledby={`ig-title-${spec.id}`}
>
  <header class="guide-infographic__header">
    <p class="guide-infographic__eyebrow">Positioning model</p>
    <h3 class="guide-infographic__title" id={`ig-title-${spec.id}`}>{spec.title}</h3>
    <p class="guide-infographic__caption">{spec.caption}</p>
    {badgeNote && (isAside || isFeature) && <p class="guide-infographic__note">{badgeNote}</p>}
  </header>

  <div class="guide-infographic__frame">
    <div class="guide-infographic__canvas">
      <svg
        class="guide-infographic__svg"
        viewBox={spec.viewBox}
        preserveAspectRatio="xMidYMid meet"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label={spec.description}
      >
        <defs>
          <linearGradient id={`ig-grad-${spec.id}`} x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#0A74DA" stop-opacity="0.92" />
            <stop offset="100%" stop-color="#5B6FD6" stop-opacity="0.88" />
          </linearGradient>
          <linearGradient id={`ig-edge-${spec.id}`} x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#0A74DA" stop-opacity="0.28" />
            <stop offset="100%" stop-color="#0A74DA" stop-opacity="0.4" />
          </linearGradient>
          <pattern id={`ig-grid-${spec.id}`} width="20" height="20" patternUnits="userSpaceOnUse">
            <circle cx="1" cy="1" r="0.5" fill="#0A74DA" opacity="0.06" />
          </pattern>
          <filter id={`ig-shadow-${spec.id}`} x="-20%" y="-20%" width="140%" height="140%">
            <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="#0A74DA" flood-opacity="0.1" />
          </filter>
          <marker
            id={`ig-arrow-${spec.id}`}
            markerWidth="6"
            markerHeight="6"
            refX="5"
            refY="3"
            orient="auto"
          >
            <path d="M0,0 L6,3 L0,6 Z" fill="#0A74DA" opacity="0.45" />
          </marker>
        </defs>

        <rect x="0" y="0" width="800" height="300" fill="#fafbfd" />
        <rect x="0" y="0" width="800" height="300" fill={`url(#ig-grid-${spec.id})`} />
        <rect
          x="20"
          y="20"
          width="760"
          height="260"
          rx="14"
          fill="#ffffff"
          stroke="#e2e8f0"
          stroke-width="1"
        />

        {
          spec.edges.map((edge) => {
            const from = nodeById[edge.from];
            const to = nodeById[edge.to];
            if (!from || !to) return null;
            return (
              <path
                d={edgePath(from, to)}
                fill="none"
                stroke={`url(#ig-edge-${spec.id})`}
                stroke-width={edge.dashed ? 1.1 : 1.4}
                stroke-dasharray={edge.dashed ? '4 5' : undefined}
                stroke-linecap="round"
                marker-end={edge.dashed ? undefined : `url(#ig-arrow-${spec.id})`}
              />
            );
          })
        }

        {
          spec.nodes.map((node) => {
            const lines = node.label.split('\n');
            if (node.kind === 'risk') {
              const s = 18;
              return (
                <g filter={`url(#ig-shadow-${spec.id})`}>
                  <polygon
                    points={`${node.x},${node.y - s} ${node.x + s},${node.y} ${node.x},${node.y + s} ${node.x - s},${node.y}`}
                    fill="#fff8fa"
                    stroke="#e879a9"
                    stroke-width="1.25"
                  />
                  <text x={node.x} y={node.y + 4} text-anchor="middle" class="guide-infographic__node-label guide-infographic__node-label--risk">
                    {lines[0]}
                  </text>
                </g>
              );
            }
            if (node.kind === 'outcome') {
              return (
                <g filter={`url(#ig-shadow-${spec.id})`}>
                  <rect
                    x={node.x - 48}
                    y={node.y - 22}
                    width="96"
                    height="44"
                    rx="8"
                    fill="#ffffff"
                    stroke="#0A74DA"
                    stroke-width="1.25"
                    opacity="0.98"
                  />
                  <text x={node.x} y={node.y + 1} text-anchor="middle" class="guide-infographic__node-label">
                    {lines[0]}
                  </text>
                </g>
              );
            }
            if (node.kind === 'phase') {
              return (
                <g filter={`url(#ig-shadow-${spec.id})`}>
                  <rect
                    x={node.x - 42}
                    y={node.y - 13}
                    width="84"
                    height="26"
                    rx="13"
                    fill="#f0f6fc"
                    stroke="#0A74DA"
                    stroke-width="1"
                    opacity="0.98"
                  />
                  <text x={node.x} y={node.y + 4} text-anchor="middle" class="guide-infographic__node-label">
                    {lines[0]}
                  </text>
                </g>
              );
            }
            const r = node.kind === 'hub' ? 30 : 24;
            return (
              <g filter={`url(#ig-shadow-${spec.id})`}>
                <circle
                  cx={node.x}
                  cy={node.y}
                  r={r}
                  fill={node.kind === 'hub' ? `url(#ig-grad-${spec.id})` : '#ffffff'}
                  stroke={node.kind === 'hub' ? 'none' : '#c7d7eb'}
                  stroke-width="1.5"
                />
                <text
                  x={node.x}
                  y={node.y + (lines[1] ? -2 : 4)}
                  text-anchor="middle"
                  class:list={[
                    'guide-infographic__node-label',
                    node.kind === 'hub' && 'guide-infographic__node-label--hub',
                  ]}
                >
                  {lines[0]}
                </text>
                {lines[1] && (
                  <text
                    x={node.x}
                    y={node.y + 12}
                    text-anchor="middle"
                    class="guide-infographic__node-label guide-infographic__node-label--hub"
                  >
                    {lines[1]}
                  </text>
                )}
              </g>
            );
          })
        }

        {
          spec.edges.map((edge) => {
            const from = nodeById[edge.from];
            const to = nodeById[edge.to];
            if (!from || !to || !edge.label) return null;
            const midX = (from.x + to.x) / 2;
            const midY = (from.y + to.y) / 2 - 12;
            return (
              <g>
                <rect
                  x={midX - 28}
                  y={midY - 9}
                  width="56"
                  height="16"
                  rx="4"
                  fill="#ffffff"
                  opacity="0.92"
                />
                <text x={midX} y={midY + 3} text-anchor="middle" class="guide-infographic__edge-label">
                  {edge.label}
                </text>
              </g>
            );
          })
        }

        {
          !isAside &&
            spec.badges?.map((badge) => (
              <g>
                <rect
                  x={badge.x - 72}
                  y={badge.y - 13}
                  width="144"
                  height="26"
                  rx="13"
                  fill="#ffffff"
                  stroke="#0A74DA"
                  stroke-width="1"
                />
                <text x={badge.x} y={badge.y + 4} text-anchor="middle" class="guide-infographic__badge-text">
                  {badge.text}
                </text>
              </g>
            ))
        }
      </svg>
    </div>
  </div>

  <p class="sr-only">{spec.description}</p>
</figure>

<style>
  .guide-infographic {
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .guide-infographic__header {
    padding: 0;
  }

  .guide-infographic__eyebrow {
    margin: 0 0 0.2rem;
    font-size: 0.625rem;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .guide-infographic--aside .guide-infographic__eyebrow {
    color: var(--primary-color);
  }

  .guide-infographic__title {
    margin: 0 0 var(--space-xs);
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    line-height: 1.35;
  }

  .guide-infographic__caption {
    margin: 0;
    font-size: var(--text-xs);
    line-height: 1.55;
    color: var(--text-secondary);
  }

  .guide-infographic__note {
    margin: var(--space-xs) 0 0;
    font-size: 0.6875rem;
    font-weight: var(--font-weight-medium);
    color: var(--primary-color);
    letter-spacing: 0.02em;
  }

  .guide-infographic__frame {
    padding: var(--space-sm);
    background: rgba(255, 255, 255, 0.75);
    border-radius: var(--border-radius);
    border: 1px solid rgba(var(--primary-color-rgb), 0.12);
  }

  .guide-infographic__canvas {
    position: relative;
    width: 100%;
    aspect-ratio: 8 / 3;
    border-radius: calc(var(--border-radius-sm));
    overflow: hidden;
    background: #fff;
  }

  .guide-infographic__svg {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    max-height: none;
    aspect-ratio: unset;
  }

  /* Aside: sized by parent column; legible labels at column width */
  .guide-infographic--aside .guide-infographic__frame {
    padding: var(--space-md);
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .guide-infographic--aside .guide-infographic__canvas {
    min-height: clamp(10rem, 22vw, 14rem);
  }

  .guide-infographic--aside .guide-infographic__title {
    font-size: var(--text-lg);
    line-height: 1.3;
  }

  .guide-infographic--aside .guide-infographic__caption {
    font-size: var(--text-sm);
  }

  .guide-infographic :global(.guide-infographic__edge-label) {
    font-family: var(--font-family);
    font-size: 9px;
    font-weight: 500;
    fill: #64748b;
  }

  .guide-infographic :global(.guide-infographic__node-label) {
    font-family: var(--font-family);
    font-size: 10.5px;
    font-weight: 600;
    fill: #1e293b;
  }

  .guide-infographic--aside :global(.guide-infographic__edge-label) {
    font-size: 10px;
  }

  .guide-infographic--aside :global(.guide-infographic__node-label) {
    font-size: 12px;
  }

  .guide-infographic :global(.guide-infographic__node-label--hub) {
    fill: #ffffff;
    font-size: 10px;
  }

  .guide-infographic--aside :global(.guide-infographic__node-label--hub) {
    font-size: 11px;
  }

  .guide-infographic :global(.guide-infographic__node-label--risk) {
    fill: #9d174d;
    font-size: 9.5px;
  }

  .guide-infographic--aside :global(.guide-infographic__node-label--risk) {
    font-size: 10.5px;
  }

  /* Featured band — primary visual for all guide pages */
  .guide-infographic--feature {
    width: 100%;
    max-width: 100%;
    margin-inline: auto;
  }

  .guide-infographic--feature .guide-infographic__header {
    text-align: center;
    max-width: none;
    margin-inline: auto;
  }

  .guide-infographic--feature .guide-infographic__frame {
    padding: var(--space-md);
    background: rgba(255, 255, 255, 0.96);
    border-color: rgba(var(--primary-color-rgb), 0.14);
    box-shadow: 0 6px 24px rgba(var(--primary-color-rgb), 0.08);
  }

  .guide-infographic--feature .guide-infographic__canvas {
    min-height: clamp(11rem, 24vw, 16rem);
  }

  .guide-infographic--feature .guide-infographic__title {
    font-size: clamp(1.05rem, 1rem + 0.35vw, 1.25rem);
  }

  .guide-infographic--feature .guide-infographic__caption {
    font-size: var(--text-sm);
  }

  .guide-infographic--feature :global(.guide-infographic__node-label) {
    font-size: 12.5px;
  }

  .guide-infographic--feature :global(.guide-infographic__edge-label) {
    font-size: 10.5px;
  }
</style>
