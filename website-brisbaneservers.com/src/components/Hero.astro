---
import { sitePath } from '../lib/site-path';
import SemanticText from './SemanticText.astro';
import SierpinskiSatellite from './SierpinskiSatellite.astro';

/**
 * Hero Component Props
 * 
 * @interface Props
 * @property {string} title - The main hero title text (required)
 * @property {string} [subtitle] - Optional subtitle text displayed below title
 * @property {string} [ctaText] - Call-to-action button text
 * @property {string} [ctaHref] - Call-to-action button link URL
 */
interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  highlights?: string[];
  /** Anchor for the bottom scroll CTA (e.g. #services-overview) */
  scrollTargetId?: string;
  /** Visible label — makes the control a deliberate “next step”, not decoration */
  scrollLabel?: string;
}

const { 
  title = 'Welcome', 
  subtitle, 
  eyebrow,
  ctaText, 
  ctaHref,
  secondaryCtaText,
  secondaryCtaHref,
  highlights = [],
  scrollTargetId = '#inquiry-section',
  scrollLabel = 'Continue to contact',
} = Astro.props;

const scrollHref = scrollTargetId.startsWith('#') ? scrollTargetId : `#${scrollTargetId}`;
const resolvedCtaHref = ctaHref && !ctaHref.startsWith('#') ? sitePath(ctaHref) : ctaHref;
const resolvedSecondaryCtaHref =
  secondaryCtaHref && !secondaryCtaHref.startsWith('#') ? sitePath(secondaryCtaHref) : secondaryCtaHref;
---

<section class="hero hero-original">
  <div class="hero-background-gradient"></div>
  <!-- Light tartan mesh — stays behind copy + visual -->
  <div class="hero-tartan-overlay" aria-hidden="true"></div>
  
  <!-- φ split: both columns in layout (no absolute-only gap); stacks on small viewports -->
  <div class="hero-inner">
    <div class="hero-text-wrapper">
      <div class="hero-text-content">
        {eyebrow && (
          <p class="hero-eyebrow">
            {eyebrow}
          </p>
        )}
        <h1 class="hero-title">
          {title || 'Welcome'}
        </h1>
        {subtitle && (
          <p class="hero-subtitle">
            {subtitle}
          </p>
        )}
        {(ctaText && ctaHref) || (secondaryCtaText && secondaryCtaHref) ? (
          <div class="hero-cta">
            {ctaText && resolvedCtaHref && (
              <a href={resolvedCtaHref} class="btn btn-primary">
                {ctaText}
              </a>
            )}
            {secondaryCtaText && resolvedSecondaryCtaHref && (
              <a href={resolvedSecondaryCtaHref} class="btn btn-secondary">
                {secondaryCtaText}
              </a>
            )}
          </div>
        ) : null}
        {highlights.length > 0 && (
          <ul class="hero-highlights" aria-label="Key value points">
            {highlights.map((highlight) => (
              <li>{highlight}</li>
            ))}
          </ul>
        )}
        <!-- Same column as CTAs: avoids wrapper/grid stretch isolating this from the buttons -->
        <a
          href={scrollHref}
          class="hero-scroll-cta"
          aria-label={`${scrollLabel} — jump to section below`}
        >
          <span class="hero-scroll-cta__text">{scrollLabel}</span>
          <svg class="hero-scroll-cta__chevron" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M12 15.5 6.7 10.2l1.4-1.4 4 4 4-4 1.4 1.4-6.5 6.3Z"
            />
          </svg>
        </a>
      </div>
    </div>
    <div class="hero-visual">
      <SierpinskiSatellite />
    </div>
  </div>
</section>

