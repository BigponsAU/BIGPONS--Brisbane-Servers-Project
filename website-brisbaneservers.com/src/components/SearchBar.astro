---
import { industries } from '../data/industries';
import { valueProposition } from '../data/value-proposition';
import { getPublicApiBaseUrl } from '../lib/api-config';
import MarketingCapabilityRow from './marketing/MarketingCapabilityRow.astro';
import { sitePath } from '../lib/site-path';

const { searchLabel, searchPlaceholder } = valueProposition.resources;
const publicApiBaseUrl = getPublicApiBaseUrl();
const searchIndexPath = sitePath('/search-index.json');
const inputId = 'site-search-input';
---

<link rel="preload" href={searchIndexPath} as="fetch" crossorigin="anonymous" />

<div
  class="search-bar search-bar-panel"
  aria-label={searchLabel}
  data-public-api-url={publicApiBaseUrl}
  data-search-index-path={searchIndexPath}
>
  <form class="search-input-group" role="search" autocomplete="off" action="javascript:void(0)">
    <div class="search-input-wrapper">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="M21 21l-4.35-4.35"></path>
      </svg>
      <label for={inputId} class="sr-only">{searchLabel}</label>
      <input
        type="search"
        id={inputId}
        class="search-input"
        placeholder={searchPlaceholder}
        aria-label={searchLabel}
        aria-autocomplete="list"
        aria-controls="search-results"
        aria-expanded="false"
        enterkeyhint="search"
        autocomplete="off"
      />
      <button type="submit" class="search-submit-btn" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
          <path d="M5 12h14"></path>
          <path d="M13 6l6 6-6 6"></path>
        </svg>
      </button>
    </div>
    <div
      class="search-results"
      id="search-results"
      role="listbox"
      aria-label="Search results"
    >
    </div>
  </form>
  <div class="search-scope-hint">
    <MarketingCapabilityRow
      class="search-capabilities"
      compact={true}
      items={[
        { glyph: 'semantic-search', label: 'Semantic suggestions', detail: 'Ranked from three characters' },
        { glyph: 'spelling-tolerant', label: 'Spelling-tolerant', detail: 'Close variants still match' },
        { glyph: 'industry-index', label: 'Industry index', detail: 'Browse sectors below' },
      ]}
    />
    <p class="search-scope-hint__lead">
      Search industry hubs, topic guides, case studies, and published resources. Press Enter to open the best match.
    </p>
  </div>
  <nav class="search-browse-chips" aria-label="Browse by industry">
    {industries.map((industry) => (
      <a
        href={sitePath(`/resources/${industry.slug}/`)}
        class="search-browse-chip"
      >
        <span>{industry.name}</span>
        <svg class="search-browse-chip__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14"></path>
          <path d="M13 6l6 6-6 6"></path>
        </svg>
      </a>
    ))}
  </nav>
</div>
