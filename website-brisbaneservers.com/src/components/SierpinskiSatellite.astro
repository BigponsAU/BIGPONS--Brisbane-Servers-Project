---
import { buildSierpinskiSatelliteMarkup } from '../lib/sierpinski-satellite';

const { connections, nodes, viewBox } = buildSierpinskiSatelliteMarkup();
---

<div class="sierpinski-satellite" aria-hidden="true">
  <svg
    class="satellite-svg"
    viewBox={viewBox}
    preserveAspectRatio="xMaxYMid meet"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g class="connections-layer" set:html={connections} />
    <g class="nodes-layer" set:html={nodes} />
  </svg>
</div>

<style>
  .sierpinski-satellite {
    position: absolute;
    inset: 0;
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    min-height: 100%;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: normal;
    overflow: visible;
    display: block;
  }

  .satellite-svg {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 100%;
    overflow: visible;
    background: transparent;
  }

  .satellite-connection-base {
    pointer-events: none;
  }

  .satellite-connection-pulse {
    --satellite-pulse-delay: 0s;
    pointer-events: none;
    animation: satellite-line-pulse 5.25s ease-in-out infinite;
    animation-delay: var(--satellite-pulse-delay);
    filter: drop-shadow(0 0 5px rgba(var(--original-purple-glow-rgb), 0.28));
  }

  .satellite-node {
    --satellite-node-delay: 0s;
    cursor: default;
  }

  .satellite-neuron-halo {
    pointer-events: none;
    opacity: 1;
  }

  .satellite-node-ring,
  .satellite-node-core {
    transition: filter 0.25s ease, opacity 0.35s ease;
  }

  .satellite-node-core {
    animation: satellite-node-synapse 4.5s ease-in-out infinite;
    animation-delay: var(--satellite-node-delay);
  }

  .satellite-node:hover .satellite-node-ring {
    filter: brightness(1.05);
  }

  .satellite-node:hover .satellite-node-core {
    filter: brightness(1.08) drop-shadow(0 0 4px rgba(59, 130, 246, 0.4));
  }

  @keyframes satellite-line-pulse {
    to {
      stroke-dashoffset: -100;
    }
  }

  @keyframes satellite-node-synapse {
    0%,
    88%,
    100% {
      opacity: 1;
    }
    94% {
      opacity: 0.88;
    }
  }
</style>
