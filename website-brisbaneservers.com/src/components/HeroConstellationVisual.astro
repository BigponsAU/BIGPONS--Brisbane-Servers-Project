---
/**
 * Hero visual — static SSR constellation (no client JS, no resize observers).
 * Replaces the interactive Sierpinski satellite that caused jank on the home fold.
 */
import SectionSatelliteConstellation from './SectionSatelliteConstellation.astro';
---

<div class="hero-constellation-visual" aria-hidden="true">
  <SectionSatelliteConstellation variant="strategy" semanticKey="home-hero" scale="rim" />
</div>

<style>
  .hero-constellation-visual {
    position: absolute;
    inset: clamp(0.6rem, 1.4vw, 1.15rem);
    width: auto;
    height: auto;
    pointer-events: none;
  }

  .hero-constellation-visual :global(.section-satellite) {
    width: 100%;
    height: 100%;
    opacity: 0.88;
  }

  .hero-constellation-visual :global(.section-satellite__edge) {
    stroke: rgba(10, 116, 218, 0.32);
    stroke-width: 1.15;
  }

  .hero-constellation-visual :global(.section-satellite__node) {
    fill: rgba(59, 130, 246, 0.24);
    stroke: rgba(139, 92, 246, 0.62);
    stroke-width: 1.1;
  }

  .hero-constellation-visual :global(.section-satellite__node--hub) {
    fill: rgba(236, 72, 153, 0.32);
    stroke: rgba(10, 116, 218, 0.78);
  }
</style>
