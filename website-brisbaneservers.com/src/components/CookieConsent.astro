---
/**
 * Cookie consent — styles in `cookie-consent.css` (viewport-capped bar; native browser zoom).
 */
import '../styles/cookie-consent.css';

interface Props {
  message?: string;
  acceptText?: string;
  declineText?: string;
  policyLink?: string;
}

const {
  message = "We use cookies to enhance your browsing experience and analyze site traffic. By continuing to use this site, you consent to our use of cookies.",
  acceptText = "Accept All",
  declineText = "Decline",
  policyLink = "/privacy-policy"
} = Astro.props;
---

<div id="cookie-consent" class="cookie-consent" role="dialog" aria-label="Cookie consent" aria-live="polite" data-zoom-aware="true" aria-hidden="true">
  <div class="cookie-consent-content">
    <div class="cookie-consent-message">
      <p class="cookie-text">
        {message}
        {policyLink && (
          <a href={policyLink} class="cookie-policy-link">Learn more</a>
        )}
      </p>
    </div>
    <div class="cookie-consent-actions">
      <button type="button" class="btn btn-primary cookie-btn cookie-btn-accept" data-action="accept" aria-label="Accept all cookies">
        {acceptText}
      </button>
      <button type="button" class="cookie-btn cookie-btn-decline" data-action="decline" aria-label="Decline cookies">
        {declineText}
      </button>
    </div>
  </div>
</div>

<script>
  /**
   * Cookie Consent Management
   * Handles showing/hiding cookie banner and storing user preference
   * Works seamlessly with zoom compensation system
   */
  
  (function() {
    const COOKIE_CONSENT_KEY = 'cookie-consent';
    const STORAGE_CONSENT_KEY = 'cookie-consent-preference';
    const COOKIE_EXPIRY_DAYS = 365;
    
    // Try to get consent from cookie first, then localStorage as fallback
    function getCookieConsent(): string | null {
      if (typeof document === 'undefined') return null;
      
      // Try cookie first
      if (document.cookie) {
        const cookies = document.cookie.split(';');
        for (let cookie of cookies) {
          const trimmed = cookie.trim();
          if (!trimmed) continue;
          
          const equalIndex = trimmed.indexOf('=');
          if (equalIndex === -1) continue;
          
          const name = trimmed.substring(0, equalIndex).trim();
          const value = trimmed.substring(equalIndex + 1).trim();
          
          if (name === COOKIE_CONSENT_KEY && value) {
            try {
              const decoded = decodeURIComponent(value);
              // Also sync to localStorage for reliability
              if (typeof localStorage !== 'undefined') {
                localStorage.setItem(STORAGE_CONSENT_KEY, decoded);
              }
              return decoded;
            } catch (e) {
              console.warn('[Cookie Consent] Error decoding cookie value:', e);
            }
          }
        }
      }
      
      // Fallback to localStorage if cookie not available
      if (typeof localStorage !== 'undefined') {
        const stored = localStorage.getItem(STORAGE_CONSENT_KEY);
        if (stored === 'accepted' || stored === 'declined') {
          return stored;
        }
      }
      
      return null;
    }
    
    function setCookieConsent(value: string): void {
      if (typeof document === 'undefined') return;
      
      // Set in both cookie and localStorage for reliability
      const expiryDate = new Date();
      expiryDate.setDate(expiryDate.getDate() + COOKIE_EXPIRY_DAYS);
      
      // Try to set cookie (may fail in some browsers/contexts)
      try {
        const cookieValue = `${COOKIE_CONSENT_KEY}=${encodeURIComponent(value)}; expires=${expiryDate.toUTCString()}; path=/; SameSite=Lax`;
        document.cookie = cookieValue;
      } catch (e) {
        console.warn('[Cookie Consent] Could not set cookie:', e);
      }
      
      // Always set in localStorage as fallback
      if (typeof localStorage !== 'undefined') {
        try {
          localStorage.setItem(STORAGE_CONSENT_KEY, value);
        } catch (e) {
          console.warn('[Cookie Consent] Could not set localStorage:', e);
        }
      }
      
      // Verify preference was saved
      const verify = getCookieConsent();
      if (verify === value) {
        console.log('[Cookie Consent] Preference saved successfully:', value);
      } else {
        console.warn('[Cookie Consent] Preference may not have been saved correctly. Expected:', value, 'Got:', verify);
      }
    }
    
    function showCookieBanner(): void {
      const banner = document.getElementById('cookie-consent');
      if (banner) {
        banner.style.removeProperty('display');
        banner.classList.add('show');
        banner.setAttribute('aria-hidden', 'false');
      }
    }
    
    function hideCookieBanner(): void {
      const banner = document.getElementById('cookie-consent');
      if (banner) {
        banner.classList.remove('show');
        window.setTimeout(() => {
          banner.style.removeProperty('display');
          banner.setAttribute('aria-hidden', 'true');
        }, 280);
      }
    }
    
    function handleAccept(): void {
      setCookieConsent('accepted');
      hideCookieBanner();
    }
    
    function handleDecline(): void {
      setCookieConsent('declined');
      hideCookieBanner();
    }
    
    // Initialize on DOM ready - ensure banner element exists
    if (typeof document !== 'undefined') {
      function tryInit() {
        const banner = document.getElementById('cookie-consent');
        if (banner) {
          init();
        } else if (document.readyState === 'loading') {
          // Wait for DOM to be ready
          document.addEventListener('DOMContentLoaded', () => {
            setTimeout(tryInit, 10); // Small delay to ensure element is rendered
          });
        } else {
          // DOM is ready but element not found yet, try again
          setTimeout(tryInit, 50);
        }
      }
      
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', tryInit);
      } else {
        tryInit();
      }
    }
    
    function init(): void {
      // Check for existing consent first
      const consent = getCookieConsent();
      
      const banner = document.getElementById('cookie-consent');
      if (!banner) {
        console.warn('[Cookie Consent] Banner element not found');
        return;
      }
      
      // If user has already made a choice, ensure banner stays hidden
      if (consent === 'accepted' || consent === 'declined') {
        banner.classList.remove('show');
        banner.style.removeProperty('display');
        banner.setAttribute('aria-hidden', 'true');
        return;
      }
      
      // Only show banner if user hasn't made a choice
      if (!consent) {
        showCookieBanner();
      }
      
      // Attach event listeners
      const acceptBtn = document.querySelector('.cookie-btn-accept');
      const declineBtn = document.querySelector('.cookie-btn-decline');
      
      if (acceptBtn) {
        acceptBtn.addEventListener('click', handleAccept);
      }
      
      if (declineBtn) {
        declineBtn.addEventListener('click', handleDecline);
      }
    }
  })();
</script>

