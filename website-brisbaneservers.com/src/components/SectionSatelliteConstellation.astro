---
import { buildSectionSatelliteGraph, type SectionSatelliteVariant } from '../lib/section-satellite-graph';

interface Props {
  variant?: SectionSatelliteVariant;
  /** Short slice of section copy — perturbs topology without mirroring the system layer. */
  semanticKey?: string;
  /** Gutter echo: same graph/seed as section, styled for margin stack (library “growth”). */
  mode?: 'section' | 'gutter-echo';
  /** Graduated scale: whisper → default → accent → rim (same language, not two unrelated sizes). */
  scale?: 'whisper' | 'default' | 'accent' | 'rim';
}

const SCALE_PRESETS = {
  whisper: { w: 320, h: 210, level: 2, nodeScale: 0.2, nodeMin: 2 },
  default: { w: 440, h: 300, level: 3, nodeScale: 0.22, nodeMin: 2.2 },
  accent: { w: 560, h: 360, level: 3, nodeScale: 0.26, nodeMin: 2.8 },
  rim: { w: 720, h: 460, level: 4, nodeScale: 0.3, nodeMin: 3.2 },
} as const;

const { variant = 'strategy', semanticKey = '', mode = 'section', scale = 'default' } = Astro.props;

const seedKey = `${variant}|${semanticKey.slice(0, 120)}`;
const rotationDeg =
  ({ strategy: -6, industry: 9, proof: -11, contact: 5, about: 14, challenge: -9, solutions: 7, partnership: -4 } as const)[variant] ?? 0;

const preset = SCALE_PRESETS[scale] ?? SCALE_PRESETS.default;
const { nodes, edges, viewWidth, viewHeight } = buildSectionSatelliteGraph({
  seedKey,
  viewWidth: preset.w,
  viewHeight: preset.h,
  maxLevel: preset.level,
  rotationDeg,
});

const nodeRadiusScale = preset.nodeScale;
const nodeRadiusMin = preset.nodeMin;
const scaleClass = `section-satellite--scale-${scale}`;
---

<div
  class:list={[
    'section-satellite',
    `section-satellite--${variant}`,
    mode === 'gutter-echo' && 'section-satellite--gutter-echo',
    scaleClass,
  ]}
  aria-hidden="true"
>
  <svg
    class="section-satellite__svg"
    viewBox={`0 0 ${viewWidth} ${viewHeight}`}
    role="presentation"
    focusable="false"
    preserveAspectRatio="xMidYMid meet"
  >
    <g class="section-satellite__edges">
      {
        edges.map(({ i, j }) => {
          const a = nodes[i];
          const b = nodes[j];
          if (!a || !b) return null;
          return <line class="section-satellite__edge" x1={a.x} y1={a.y} x2={b.x} y2={b.y} />;
        })
      }
    </g>
    <g class="section-satellite__nodes">
      {
        nodes.map((n, idx) => (
          <circle
            class={idx === 0 ? 'section-satellite__node section-satellite__node--hub' : 'section-satellite__node'}
            cx={n.x}
            cy={n.y}
            r={Math.max(nodeRadiusMin, n.size * nodeRadiusScale)}
          />
        ))
      }
    </g>
  </svg>
</div>
