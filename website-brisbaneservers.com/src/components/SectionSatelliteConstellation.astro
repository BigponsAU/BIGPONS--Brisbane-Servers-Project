---
import { buildSectionSatelliteGraph, hashSeedKey, type SectionSatelliteVariant } from '../lib/section-satellite-graph';

interface Props {
  variant?: SectionSatelliteVariant;
  /** Short slice of section copy — perturbs topology without mirroring the system layer. */
  semanticKey?: string;
  /** Gutter echo: same graph/seed as section, styled for margin stack (library “growth”). */
  mode?: 'section' | 'gutter-echo';
  /** Graduated scale: whisper → default → accent → rim (same language, not two unrelated sizes). */
  scale?: 'whisper' | 'default' | 'accent' | 'rim';
}

const SCALE_PRESETS = {
  whisper: { w: 320, h: 210, level: 1, nodeScale: 0.12, nodeMin: 1.1 },
  default: { w: 440, h: 300, level: 2, nodeScale: 0.18, nodeMin: 1.6 },
  accent: { w: 560, h: 360, level: 2, nodeScale: 0.22, nodeMin: 2 },
  rim: { w: 720, h: 460, level: 3, nodeScale: 0.26, nodeMin: 2.4 },
} as const;

const { variant = 'strategy', semanticKey = '', mode = 'section', scale = 'default' } = Astro.props;

const seedKey = `${variant}|${semanticKey.slice(0, 120)}`;
const rotationDeg =
  ({ strategy: -6, industry: 9, proof: -11, contact: 5, about: 14, challenge: -9, solutions: 7, partnership: -4 } as const)[variant] ?? 0;

const preset = SCALE_PRESETS[scale] ?? SCALE_PRESETS.default;
const { nodes, edges, viewWidth, viewHeight } = buildSectionSatelliteGraph({
  seedKey,
  viewWidth: preset.w,
  viewHeight: preset.h,
  maxLevel: preset.level,
  rotationDeg,
});

const nodeRadiusScale = preset.nodeScale;
const nodeRadiusMin = preset.nodeMin;
const scaleClass = `section-satellite--scale-${scale}`;
const clipId = `section-satellite-clip-${hashSeedKey([seedKey, scale]).toString(36)}`;
---

<div
  class:list={[
    'section-satellite',
    `section-satellite--${variant}`,
    mode === 'gutter-echo' && 'section-satellite--gutter-echo',
    scaleClass,
  ]}
  aria-hidden="true"
>
  <svg
    class="section-satellite__svg"
    viewBox={`0 0 ${viewWidth} ${viewHeight}`}
    overflow="hidden"
    role="presentation"
    focusable="false"
    preserveAspectRatio="xMidYMid meet"
  >
    <defs>
      <clipPath id={clipId}>
        <rect x="0" y="0" width={viewWidth} height={viewHeight} />
      </clipPath>
    </defs>
    <g clip-path={`url(#${clipId})`}>
    <g class="section-satellite__edges">
      {
        edges.map(({ i, j }) => {
          const a = nodes[i];
          const b = nodes[j];
          if (!a || !b) return null;
          return <line class="section-satellite__edge" x1={a.x} y1={a.y} x2={b.x} y2={b.y} />;
        })
      }
    </g>
    <g class="section-satellite__nodes">
      {
        nodes.map((n, idx) => (
          <circle
            class={idx === 0 ? 'section-satellite__node section-satellite__node--hub' : 'section-satellite__node'}
            cx={n.x}
            cy={n.y}
            r={Math.max(nodeRadiusMin, n.size * nodeRadiusScale)}
          />
        ))
      }
    </g>
    </g>
  </svg>
</div>

<style is:global>
  .section-satellite {
    overflow: hidden;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* Always clip + tint nodes — prevents default black SVG circles in page flow */
  .section-satellite__edge {
    stroke: rgba(10, 116, 218, 0.28);
    stroke-width: 1;
    stroke-linecap: round;
  }

  .section-satellite__node {
    fill: rgba(139, 92, 246, 0.22);
    stroke: rgba(10, 116, 218, 0.55);
    stroke-width: 1;
  }

  .section-satellite__node--hub {
    fill: rgba(236, 72, 153, 0.28);
    stroke: rgba(10, 116, 218, 0.75);
  }

  .section-satellite__svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
</style>
