---
import { sitePath } from '../lib/site-path';
import logo from '../logo.png';
import SemanticText from './SemanticText.astro';
---

<footer class="footer" role="contentinfo">
  <div class="bg-pattern-phi-grid footer-pattern" aria-hidden="true"></div>
  <div class="phi-lateral-angular-2 footer-angular" aria-hidden="true"></div>
  <div class="footer-content">
      <div class="footer-main">
        <div class="footer-section footer-brand-section">
          <div class="footer-brand">
            <img src={logo.src} alt="Brisbane Servers Logo" class="footer-logo" width={logo.width} height={logo.height} />
            <span class="footer-brand-text">
              <SemanticText text="Brisbane Servers" semanticLevel="high" preserveCase />
            </span>
          </div>
          <p class="footer-description">
            <SemanticText text="Professional technology consulting for Australian businesses, delivering practical digital solutions with clear scope and dependable support. A BIGPONS project." semanticLevel="normal" />
          </p>
          <div class="footer-credentials">
            <div class="credential-badge">
              <span class="footer-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="5" />
                  <line x1="12" y1="1" x2="12" y2="3" />
                  <line x1="12" y1="21" x2="12" y2="23" />
                  <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                  <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                  <line x1="1" y1="12" x2="3" y2="12" />
                  <line x1="21" y1="12" x2="23" y2="12" />
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                  <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                </svg>
              </span>
              <span>BIGPONS ABN: 93 297 393 962</span>
            </div>
            <div class="credential-badge">
              <span class="footer-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              </span>
              <span>Brisbane, QLD</span>
            </div>
          </div>
        </div>

        <div class="footer-section">
          <h4 class="footer-title">Services</h4>
          <ul class="footer-links">
            <li><a href={sitePath('/services')}>Web Development</a></li>
            <li><a href={sitePath('/services')}>Application Scaling</a></li>
            <li><a href={sitePath('/services')}>Automation Solutions</a></li>
            <li><a href={sitePath('/services')}>IT Consulting</a></li>
            <li><a href={sitePath('/services')}>Enterprise Support</a></li>
            <li><a href={sitePath('/services')}>Security Services</a></li>
          </ul>
        </div>

        <div class="footer-section footer-right-section">
          <div class="footer-subsection">
            <h4 class="footer-title">Company</h4>
            <ul class="footer-links">
              <li><a href={sitePath('/about')}>About Us</a></li>
              <li><a href={sitePath('/brisbane-2032#project-purpose')}>Project purpose · Brisbane 2032</a></li>
              <li><a href={sitePath('/resources#resources-project-objective')}>Inference on Resources</a></li>
              <li><a href={sitePath('/about#additive-semantics')}>Design philosophy</a></li>
              <li><a href={sitePath('/about')}>Why Choose Us</a></li>
              <li><a href={sitePath('/account')}>Account workspace <span class="footer-link-hint">(sign in)</span></a></li>
              <li><a href={sitePath('/services#consultation')}>Consultation</a></li>
              <li><a href={sitePath('/services')}>Business Solutions</a></li>
              <li><a href={sitePath('/services')}>Support</a></li>
            </ul>
          </div>
          
          <div class="footer-subsection">
            <h4 class="footer-title">Contact Info</h4>
            <div class="footer-contact">
              <div class="footer-contact-item">
                <span class="footer-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                </span>
                <span>+61 490 478 864</span>
              </div>
              <div class="footer-contact-item">
                <span class="footer-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                  </svg>
                </span>
                <span>support@brisbaneservers.com</span>
              </div>
              <div class="footer-contact-item">
                <span class="footer-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                    <path d="m9 16 2 2 4-4" />
                  </svg>
                </span>
                <span>Consultations by Appointment</span>
              </div>
            </div>
          </div>
          
          <div class="footer-subsection">
            <h5 class="social-title">Connect with us</h5>
            <div class="social-links">
              <a href="https://www.linkedin.com/company/bigpons/" class="social-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
                <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>
              <a href="https://facebook.com/brisbaneservers" class="social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
                <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                </svg>
              </a>
              <a href="mailto:connect@brisbaneservers.com" class="social-link" aria-label="Email">
                <svg class="social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                  <polyline points="22,6 12,13 2,6" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <div class="footer-bottom-content">
          <div class="footer-copyright">
            <p>© 2026 Brisbane Servers. All rights reserved.</p>
            <p class="footer-subtitle">A BIGPONS Technology Project</p>
          </div>
          <div class="footer-legal">
            <a href={sitePath('/privacy-policy')} class="footer-legal-link">Privacy Policy</a>
            <a href={sitePath('/terms-of-service')} class="footer-legal-link">Terms of Service</a>
          </div>
        </div>
      </div>
    </div>
</footer>

