---
import { clientSites } from '../data/client-sites';
import { clientSitePreviewSrc } from '../lib/client-site-preview';
import { sitePath } from '../lib/site-path';

interface Props {
  /** Optional anchor id for in-page links */
  id?: string;
  /** Set false when the parent section already explains the growing list */
  showFootnote?: boolean;
  /** `featured` uses a wide horizontal card when the list is short; defaults from list length */
  layout?: 'grid' | 'featured';
}

const { id, showFootnote = true, layout: layoutProp } = Astro.props;
const layout = layoutProp ?? (clientSites.length <= 2 ? 'featured' : 'grid');
---

<div
  class:list={['client-sites-showcase', layout === 'featured' && 'client-sites-showcase--featured']}
  id={id}
  data-layout={layout}
>
  <ul class="client-sites-showcase__grid" role="list">
    {
      clientSites.map((site) => {
        let host = '';
        try {
          host = new URL(site.url).hostname.replace(/^www\./, '');
        } catch {
          host = site.url;
        }
        const faviconSrc = `https://www.google.com/s2/favicons?domain=${encodeURIComponent(host)}&sz=64`;
        const previewSrc = site.previewImage
          ? site.previewImage.startsWith('/')
            ? sitePath(site.previewImage)
            : site.previewImage
          : clientSitePreviewSrc(site.url);
        return (
          <li class="client-sites-showcase__item" role="listitem">
            <a
              class="client-site-card"
              href={site.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="client-site-card__preview">
                <img
                  class="client-site-card__shot"
                  src={previewSrc}
                  alt={`Live preview of ${site.name}`}
                  width={1280}
                  height={800}
                  loading="lazy"
                  decoding="async"
                  {...(clientSites.indexOf(site) === 0 ? { fetchpriority: 'high' as const } : {})}
                  data-client-preview
                />
                <div class="client-site-card__placeholder" aria-hidden="true" hidden>
                  <span class="client-site-card__placeholder-label">Preview loading…</span>
                </div>
                <div class="client-site-card__chrome" aria-hidden="true">
                  <span class="client-site-card__dot" />
                  <span class="client-site-card__dot" />
                  <span class="client-site-card__dot" />
                </div>
              </div>
              <div class="client-site-card__body">
                <div class="client-site-card__row">
                  <img
                    class="client-site-card__favicon"
                    src={faviconSrc}
                    alt=""
                    width={28}
                    height={28}
                    loading="lazy"
                  />
                  <div class="client-site-card__text">
                    <span class="client-site-card__name">{site.name}</span>
                    <span class="client-site-card__host">{host}</span>
                    <span class="client-site-card__tagline">{site.tagline}</span>
                  </div>
                </div>
                <span class="client-site-card__cta">Visit live site</span>
              </div>
            </a>
          </li>
        );
      })
    }
  </ul>
  {showFootnote && (
    <p class="client-sites-showcase__note">
      We keep this list short on purpose. It grows when new launches go live and clients are glad
      to have them shown here.
    </p>
  )}
</div>

<script>
  document.querySelectorAll('[data-client-preview]').forEach((img) => {
    if (!(img instanceof HTMLImageElement)) return;
    img.addEventListener('error', () => {
      img.style.display = 'none';
      const placeholder = img.parentElement?.querySelector('.client-site-card__placeholder');
      if (placeholder instanceof HTMLElement) placeholder.hidden = false;
    });
  });
</script>
