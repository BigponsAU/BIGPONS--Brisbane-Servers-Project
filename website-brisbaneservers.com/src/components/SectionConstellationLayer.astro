---
import SectionSatelliteConstellation from './SectionSatelliteConstellation.astro';
import type { SectionSatelliteVariant } from '../lib/section-satellite-graph';

export type ConstellationTier = 'whisper' | 'default' | 'accent' | 'rim';
export type ConstellationPlacement = 'field' | 'top-right' | 'top-left' | 'bottom-right' | 'bottom-left';

interface Props {
  variant?: SectionSatelliteVariant;
  /** Stable key — use page + section id so graphs relate across a page. */
  semanticKey: string;
  tier?: ConstellationTier;
  placement?: ConstellationPlacement;
  /** When false, omit gutter constellation (e.g. dense content sections). */
  showConstellation?: boolean;
}

const {
  variant = 'about',
  semanticKey,
  tier = 'default',
  placement = 'field',
  showConstellation = true,
} = Astro.props;
---

{showConstellation && (
<div
  class:list={[
    'section-constellation-layer',
    `section-constellation-layer--${tier}`,
    `section-constellation-layer--${placement}`,
  ]}
  aria-hidden="true"
>
  <SectionSatelliteConstellation
    variant={variant}
    semanticKey={semanticKey}
    scale={tier}
    mode={tier === 'whisper' ? 'gutter-echo' : 'section'}
  />
</div>
)}

<style is:global>
  /* Fallback if marketing-constellation.css fails to load — prevents in-flow black SVG nodes */
  .section-constellation-layer {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .section-constellation-layer .section-satellite {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-height: none;
  }

  .section-constellation-layer--whisper {
    width: clamp(6.5rem, 14vw, 10.5rem);
    aspect-ratio: 320 / 210;
    opacity: 0.48;
  }

  .section-constellation-layer--whisper.section-constellation-layer--top-right {
    top: clamp(0.75rem, 3vw, 1.75rem);
    right: max(0.35rem, calc((100% - min(var(--site-frame-wide, 72rem), 100%)) / 2));
    left: auto;
  }

  .section-constellation-layer--whisper.section-constellation-layer--top-left {
    top: clamp(0.75rem, 3vw, 1.75rem);
    left: max(0.35rem, calc((100% - min(var(--site-frame-wide, 72rem), 100%)) / 2));
    right: auto;
  }

  .section-constellation-layer--whisper.section-constellation-layer--bottom-right {
    bottom: clamp(0.75rem, 3vw, 1.5rem);
    right: max(0.35rem, calc((100% - min(var(--site-frame-wide, 72rem), 100%)) / 2));
    left: auto;
  }

  .section-constellation-layer--whisper.section-constellation-layer--bottom-left {
    bottom: clamp(0.75rem, 3vw, 1.5rem);
    left: max(0.35rem, calc((100% - min(var(--site-frame-wide, 72rem), 100%)) / 2));
    right: auto;
  }

  .marketing-page-bands--constellation-spine > .section.section-tartan-accent {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
</style>