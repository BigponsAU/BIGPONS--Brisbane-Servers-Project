---
import { sitePath } from '../lib/site-path';
import SemanticText from './SemanticText.astro';

/**
 * Card Component Props
 * 
 * @interface Props
 * @property {string} title - The card title text (required)
 * @property {string} description - The card description text (required)
 * @property {string} [icon] - Font Awesome icon class (e.g., 'fas fa-check')
 * @property {string} [href] - Optional link URL. If provided, card becomes a link
 * @property {string} [actionLabel] - Visible CTA on link cards (default: "View details")
 * @property {string} [industry] - Industry filter category for filtering
 * @property {'high' | 'medium' | 'normal'} [semanticLevel='medium'] - Semantic text emphasis level
 * @property {'small' | 'medium' | 'large' | 'featured'} [size='medium'] - Card size variant
 * @property {'standard' | 'wide' | 'tall' | 'asymmetric'} [layout='standard'] - Card layout variant
 * @property {boolean} [emphasis=false] - Whether to apply emphasis styling
 */
interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
  /** Shown on link cards as a button-like affordance (default: View details) */
  actionLabel?: string;
  industry?: string;
  semanticLevel?: 'high' | 'medium' | 'normal';
  size?: 'small' | 'medium' | 'large' | 'featured';
  layout?: 'standard' | 'wide' | 'tall' | 'asymmetric';
  emphasis?: boolean;
}

const { 
  title = 'Card Title', 
  description = '', 
  icon, 
  href,
  actionLabel = 'View details',
  industry,
  semanticLevel = 'medium',
  size = 'medium',
  layout = 'standard',
  emphasis = false
} = Astro.props;

const Tag = href ? 'a' : 'div';
const cardClass = [
  'card',
  href ? 'card--link' : '',
  industry ? 'resource-item' : '',
  `card-${size}`,
  `card-${layout}`,
  emphasis ? 'card-emphasis' : ''
].filter(Boolean).join(' ');

const dataAttr = industry ? { 'data-industry': industry } : {};
const resolvedHref =
  href && !/^(?:https?:|mailto:|tel:)/i.test(href) ? sitePath(href) : href;
---

<Tag 
  class={cardClass} 
  href={resolvedHref} 
  {...dataAttr}
  role={href ? undefined : 'article'}
  aria-label={href ? `${title}. ${description}` : undefined}
>
  {icon && (
    <div class="card-icon" aria-hidden="true">
      <i class={icon}></i>
    </div>
  )}
  <h3 class="card-title">
    <SemanticText text={title || 'Card Title'} semanticLevel={semanticLevel} isParent={true} />
  </h3>
  {description && (
    <p class="card-description" set:html={description} />
  )}
  <slot />
  {href && (
    <span class="card-link-cta">
      <span class="card-link-cta__label">{actionLabel}</span>
      <span class="card-link-cta__icon" aria-hidden="true">→</span>
    </span>
  )}
</Tag>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--surface-elevated);
    border-radius: var(--card-border-radius);
    padding: var(--card-padding);
    transition: var(--transition);
    text-decoration: none;
    color: inherit;
    border: var(--phi-line-width) solid var(--site-panel-border, var(--border-light));
    box-shadow: var(--card-shadow);
  }

  .card--link {
    min-height: 100%;
  }

  .card:hover {
    box-shadow: var(--shadow-additive-strong, var(--card-shadow-hover));
    transform: translateY(calc(var(--space-xs) * var(--phi-inv) * -1));
    border-color: var(--border-accent);
  }

  .card:focus {
    outline: none;
  }

  .card:focus-visible {
    outline: 2px solid var(--primary-color);
    outline-offset: 3px;
    border-color: var(--primary-color);
  }

  .card-link-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    margin-top: auto;
    padding: 0.5rem 0.75rem;
    border-radius: var(--border-radius, 0.5rem);
    background: rgba(var(--primary-color-rgb), 0.08);
    border: 1px solid rgba(var(--primary-color-rgb), 0.2);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--primary-color);
    line-height: 1.25;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .card--link:hover .card-link-cta,
  .card--link:focus-visible .card-link-cta {
    background: rgba(var(--primary-color-rgb), 0.14);
    border-color: var(--primary-color);
    color: var(--primary-dark);
  }

  .card-link-cta__icon {
    flex-shrink: 0;
    font-size: 1.1em;
    line-height: 1;
    opacity: 0.9;
  }

  /* Typography standardized across all card variations */
  .card-title {
    font-size: calc(var(--text-lg) * var(--size-card-title));
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
    line-height: calc(1em * var(--phi));
  }

  .card-description {
    font-size: var(--text-base);
    font-weight: var(--font-weight-normal);
    color: var(--text-secondary);
    line-height: calc(1em * var(--phi));
    margin: 0;
  }

  .card-icon {
    font-size: var(--icon-lg);
    color: var(--primary-dark);
    margin-bottom: var(--space-md);
    background: rgba(var(--primary-color-rgb), 0.08);
    border: 1px solid rgba(var(--primary-color-rgb), 0.14);
    width: fit-content;
    padding: var(--space-sm);
    border-radius: var(--phi-radius-atypical-a);
  }

  /* Size variations - use component tokens */
  .card-small {
    padding: var(--card-padding-sm);
  }

  .card-medium {
    padding: var(--card-padding);
  }

  .card-large {
    padding: var(--card-padding-lg);
  }

  .card-featured {
    padding: var(--card-padding-xl);
    border: calc(var(--phi-line-width) * var(--importance-medium)) solid var(--primary-color);
  }

  /* Layout variations - positions can vary for Gestalt cohesion */
  .card-standard {
    /* Default vertical layout */
  }

  .card-wide {
    grid-column: span 2;
  }

  .card-tall {
    grid-row: span 2;
  }

  .card-asymmetric {
    /* Can be positioned differently in grid */
  }

  /* Emphasis variation for hierarchy */
  .card-emphasis {
    background: var(--surface-additive);
    border-color: var(--primary-color);
    box-shadow: var(--shadow-primary-lg);
    border-radius: var(--phi-radius-atypical-b);
  }

  .card-emphasis .card-title {
    color: var(--primary-dark);
  }

  /* Card gap for grids - uses Sierpinski pattern */
  .card + .card {
    margin-top: 0;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .card-wide {
      grid-column: span 1;
    }

    .card-tall {
      grid-row: span 1;
    }
  }
</style>
