---
/** Subtle spine accent at the top of public marketing main content. */
---

<div class="marketing-main-rail" aria-hidden="true">
  <svg class="marketing-main-rail__svg" viewBox="0 0 1440 28" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="marketing-rail-grad" x1="0" y1="0" x2="1440" y2="0" gradientUnits="userSpaceOnUse">
        <stop stop-color="var(--primary-color)" stop-opacity="0" />
        <stop offset="0.35" stop-color="var(--primary-color)" stop-opacity="0.35" />
        <stop offset="0.5" stop-color="var(--primary-color)" stop-opacity="0.65" />
        <stop offset="0.65" stop-color="var(--primary-color)" stop-opacity="0.35" />
        <stop offset="1" stop-color="var(--primary-color)" stop-opacity="0" />
      </linearGradient>
    </defs>
    <path d="M0 14h520" stroke="url(#marketing-rail-grad)" stroke-width="1" />
    <circle cx="720" cy="14" r="3" fill="var(--primary-color)" opacity="0.45" />
    <circle cx="720" cy="14" r="6" stroke="var(--primary-color)" stroke-width="1" opacity="0.2" />
    <path d="M920 14h520" stroke="url(#marketing-rail-grad)" stroke-width="1" />
  </svg>
</div>
