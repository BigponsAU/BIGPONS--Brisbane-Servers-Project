---
/** Inline SVG glyphs — professional geometric marks for marketing surfaces. */
import type { FeatureGlyphName } from '../../lib/marketing/feature-glyphs';

interface Props {
  name: FeatureGlyphName;
  class?: string;
  size?: number;
}

const { name, class: className = '', size = 20 } = Astro.props;
const cls = ['feature-glyph', `feature-glyph--${name}`, className].filter(Boolean).join(' ');
---

{ name === 'semantic-search' && (
  <svg class={cls} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="10.5" cy="10.5" r="6.5" />
    <path d="M15.5 15.5L21 21" />
    <circle cx="8" cy="9" r="1" fill="currentColor" stroke="none" />
    <circle cx="12" cy="11" r="1" fill="currentColor" stroke="none" />
    <path d="M8 13.5c1.2 1 2.8 1 4 0" />
  </svg>
) }
{ name === 'spelling-tolerant' && (
  <svg class={cls} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M4 7h12" />
    <path d="M4 12h9" />
    <path d="M4 17h6" />
    <path d="M17 14l2 2 4-4" />
    <path d="M16 7c.5-1 1.5-1.5 2.5-1" opacity="0.55" />
  </svg>
) }
{ name === 'industry-index' && (
  <svg class={cls} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="3" width="7" height="7" rx="1.5" />
    <rect x="14" y="3" width="7" height="7" rx="1.5" />
    <rect x="3" y="14" width="7" height="7" rx="1.5" />
    <rect x="14" y="14" width="7" height="7" rx="1.5" />
    <circle cx="6.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
    <circle cx="17.5" cy="17.5" r="1" fill="currentColor" stroke="none" />
  </svg>
) }
{ name === 'web-presence' && (
  <svg class={cls} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="9" />
    <path d="M3 12h18" />
    <path d="M12 3c2.5 3 2.5 15 0 18" />
    <path d="M12 3c-2.5 3-2.5 15 0 18" />
  </svg>
) }
{ name === 'automation' && (
  <svg class={cls} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="4" y="8" width="16" height="10" rx="2" />
    <path d="M9 8V6a3 3 0 0 1 6 0v2" />
    <circle cx="9" cy="13" r="1" fill="currentColor" stroke="none" />
    <circle cx="15" cy="13" r="1" fill="currentColor" stroke="none" />
    <path d="M8 17h8" />
  </svg>
) }
{ name === 'data-systems' && (
  <svg class={cls} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <ellipse cx="12" cy="6" rx="8" ry="3" />
    <path d="M4 6v6c0 1.7 3.6 3 8 3s8-1.3 8-3V6" />
    <path d="M4 12v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6" />
  </svg>
) }
{ name === 'integration' && (
  <svg class={cls} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="6" cy="12" r="3" />
    <circle cx="18" cy="6" r="3" />
    <circle cx="18" cy="18" r="3" />
    <path d="M8.7 10.8L15.3 7.2" />
    <path d="M8.7 13.2l6.6 3.6" />
  </svg>
) }
{ name === 'evidence' && (
  <svg class={cls} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M6 4h9l3 3v13H6z" />
    <path d="M15 4v3h3" />
    <path d="M9 12h6" />
    <path d="M9 16h4" />
    <circle cx="9" cy="8" r="1" fill="currentColor" stroke="none" />
  </svg>
) }
{ name === 'phi-node' && (
  <svg class={cls} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
    <circle cx="5" cy="12" r="2" />
    <circle cx="12" cy="12" r="2" />
    <circle cx="19" cy="12" r="2" />
    <path d="M7 12h3" />
    <path d="M14 12h3" />
  </svg>
) }
