---
/** Full-width φ-node rail above marketing section intros. */
import SectionAccentRail from './SectionAccentRail.astro';

interface Props {
  class?: string;
  tone?: 'default' | 'on-dark';
}

const { class: className = '', tone = 'default' } = Astro.props;
---

<div class:list={['section-intro-flourish', className]}>
  <SectionAccentRail tone={tone} />
</div>
