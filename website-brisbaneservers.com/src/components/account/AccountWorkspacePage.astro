---
import SiteShell from '../../layouts/SiteShell.astro';
import AccountSignIn from './AccountSignIn.astro';
import AccountBasicHome from './AccountBasicHome.astro';
import AccountWorkspaceShell from './AccountWorkspaceShell.astro';
import AccountOverviewPanel from './AccountOverviewPanel.astro';
import AccountResourcesPanel from './AccountResourcesPanel.astro';
import AccountProfilesPanel from './AccountProfilesPanel.astro';
import AccountAnalyticsPanel from './AccountAnalyticsPanel.astro';
import AccountGrowthPanel from './AccountGrowthPanel.astro';
import AccountModerationPanel from './AccountModerationPanel.astro';
import AccountSiteReviewPanel from './AccountSiteReviewPanel.astro';
import AccountAdminUsersPanel from './AccountAdminUsersPanel.astro';
import AccountResourceModals from './AccountResourceModals.astro';
import { accountWorkspace } from '../../data/account-workspace';
import { resolvePublicApiUrl, resolvePublicSitePath } from '../../lib/api-config';
import '../../styles/portal-workspace.css';
import '../../styles/portal-dashboard.css';

interface Props {
  initialVerifyToken?: string;
  initialResetToken?: string;
}

const { initialVerifyToken = '', initialResetToken = '' } = Astro.props;

const publicApiBaseUrl = resolvePublicApiUrl('');
const accountPath = resolvePublicSitePath('/account/');
const pageTitleSignedOut = `Sign in · ${accountWorkspace.productName}`;
const pageTitleSignedIn = `${accountWorkspace.productNameShort} · ${accountWorkspace.productName}`;
---

<SiteShell
  title={pageTitleSignedOut}
  description="Secure account workspace for contributions, resources, and voice profile management"
  noindex={true}
  currentPath="/account"
  pageId="account"
  shellVariant="marketing"
  valueProfile="utility"
  zoomProfile="focused"
  density="comfortable"
  showFooter={true}
  mainClass="main-phi-chassis account-workspace-shell"
>
  <div
    id="admin-portal"
    class="admin-portal account-workspace-root"
    data-public-api-base-url={publicApiBaseUrl}
    data-account-path={accountPath}
    data-page-title-signed-out={pageTitleSignedOut}
    data-page-title-signed-in={pageTitleSignedIn}
    data-verify-token={initialVerifyToken}
    data-reset-token={initialResetToken}
  >
    <AccountSignIn />
    <div id="account-auth-boot" class="account-auth-boot" aria-live="polite" aria-busy="true">
      <p class="account-auth-boot__text">Checking your session…</p>
    </div>
    <AccountBasicHome />
    <AccountWorkspaceShell>
      <AccountOverviewPanel />
      <AccountResourcesPanel />
      <AccountProfilesPanel />
      <AccountAnalyticsPanel />
      <AccountGrowthPanel />
      <AccountModerationPanel />
      <AccountSiteReviewPanel />
      <AccountAdminUsersPanel />
    </AccountWorkspaceShell>
    <AccountResourceModals />
    <div id="notification-container" class="notification-container" aria-live="polite" aria-atomic="true"></div>
  </div>

  <script>
    import { bootAccountPageFromDom } from '../../scripts/account-page-loader.ts';

    function boot() {
      bootAccountPageFromDom();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    } else {
      boot();
    }
  </script>
</SiteShell>
