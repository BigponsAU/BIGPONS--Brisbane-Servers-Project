---
import AccountWorkspacePanelBand from './AccountWorkspacePanelBand.astro';
---
<div id="moderation-panel" class="portal-panel panel-shell" data-min-role="admin" role="main" aria-label="Upload moderation" style="display: none;">
  <div class="admin-content moderation-panel-shell">
    <AccountWorkspacePanelBand
      semanticKey="account-moderation"
      eyebrow="Library"
      title="Upload moderation"
      byline="Review pending community uploads before they publish. Approved items appear in Resources; rejected items stay off the public library."
      titleId="moderation-heading"
      variant="primary-light"
    >
      <div slot="actions" class="section-actions admin-panel-quick-links" role="group" aria-label="Related panels">
        <button type="button" class="btn btn-secondary btn-sm" onclick="navigateToPanel('resources')">Resources</button>
        <button type="button" class="btn btn-secondary btn-sm" onclick="navigateToPanel('library-growth')">Library growth</button>
        <button id="refresh-moderation-btn" type="button" class="btn btn-secondary btn-sm">Refresh queue</button>
      </div>

    <section class="admin-section admin-section--in-band" aria-labelledby="moderation-heading">
      <details class="panel-guidance-details">
        <summary>Moderation workflow</summary>
        <div class="panel-guidance-details__body">
          <p><strong>Approve</strong> publishes the contribution and links it to the contributor&apos;s resource.</p>
          <p><strong>Reject</strong> removes it from the pending queue without publishing.</p>
          <p><strong>Open in Resources</strong> jumps to the draft tree when a resource ID is attached.</p>
        </div>
      </details>

      <p id="moderation-queue-summary" class="admin-queue-summary" role="status" aria-live="polite"></p>

      <div class="moderation-workspace">
        <aside class="moderation-queue-pane" aria-label="Pending uploads">
          <div id="moderation-queue" class="moderation-queue" aria-live="polite">
            <p class="loading-message">Loading moderation queue…</p>
          </div>
        </aside>
        <main class="moderation-detail-pane" aria-label="Upload preview">
          <div id="moderation-detail-empty" class="workspace-empty-state">
            <h3>Select an upload</h3>
            <p>Choose a pending item to preview content and approve or reject.</p>
          </div>
          <div id="moderation-detail-panel" class="moderation-detail-panel hidden" aria-live="polite"></div>
        </main>
      </div>
    </section>
    </AccountWorkspacePanelBand>
  </div>
</div>
