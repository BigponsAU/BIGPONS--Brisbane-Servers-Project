---
import SectionIntro from '../SectionIntro.astro';
import SectionConstellationLayer from '../SectionConstellationLayer.astro';
---

<div id="library-growth-panel" class="portal-panel" data-min-role="admin" role="main" aria-label="Library growth" style="display: none;">
  <div class="admin-content">
    <section class="section section-tartan-accent section-home-band--primary-light account-workspace-panel-section">
      <SectionConstellationLayer variant="partnership" semanticKey="account-library-growth" tier="whisper" placement="top-right" />
      <div class="bg-pattern-angular bg-pattern-light"></div>
      <div class="container account-workspace-panel-inner">
        <SectionIntro
          eyebrow="Growing library"
          title="Library growth"
          byline="Plans topic gaps from analytics, then generates voice-aligned draft guides. Nothing goes live until you publish from Resources. Check the budget estimate before activating the schedule."
          titleId="library-growth-heading"
        />

        <div class="library-growth-controls">
          <label class="library-growth-toggle">
            <input type="checkbox" id="growth-enabled" />
            Allow scheduled cycles (configure interval, then activate below)
          </label>
          <p id="growth-schedule-state" class="library-growth-schedule-state" role="status" aria-live="polite"></p>
          <div class="library-growth-fields">
            <label>
              Cycle every (hours)
              <input type="number" id="growth-interval-hours" min="0" step="1" value="168" />
            </label>
            <label>
              Max proposals per cycle
              <input type="number" id="growth-max-proposals" min="1" max="20" value="5" />
            </label>
            <label class="library-growth-toggle">
              <input type="checkbox" id="growth-case-studies" checked />
              Include case-study proposals
            </label>
            <label class="library-growth-toggle">
              <input type="checkbox" id="growth-auto-materialize" />
              Auto-generate draft resources after each cycle
            </label>
            <label>
              Daily growth budget (units)
              <input type="number" id="growth-daily-budget" min="1" max="100" value="20" />
            </label>
            <label>
              Max materialize per cycle
              <input type="number" id="growth-max-units-cycle" min="1" max="20" value="5" />
            </label>
          </div>
          <div id="growth-budget-panel" class="library-growth-budget" role="status" aria-live="polite">
            <p class="library-growth-budget-title">Budget &amp; next cycle estimate</p>
            <p id="growth-budget-summary" class="library-growth-meta">Loading estimate…</p>
            <p id="growth-budget-note" class="library-growth-budget-note"></p>
          </div>
          <div class="library-growth-actions">
            <button type="button" id="growth-save-config" class="btn btn-secondary btn-sm">Save settings</button>
            <button type="button" id="growth-arm-schedule" class="btn btn-primary btn-sm">Activate schedule</button>
            <button type="button" id="growth-pause-schedule" class="btn btn-secondary btn-sm">Pause schedule</button>
            <button type="button" id="growth-run-cycle" class="btn btn-secondary btn-sm">Run cycle now (manual)</button>
            <button type="button" id="growth-refresh-queue" class="btn btn-secondary btn-sm">Refresh queue</button>
          </div>
          <p id="growth-status" class="status-message" role="status" aria-live="polite"></p>
          <p id="growth-cycle-meta" class="library-growth-meta"></p>
        </div>

        <div id="growth-proposals-queue" class="growth-proposals-queue" aria-live="polite">
          <p class="status-message">Loading growth proposals…</p>
        </div>
      </div>
    </section>
  </div>
</div>
