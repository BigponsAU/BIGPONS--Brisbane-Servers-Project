---
import MarketingPageBands from '../MarketingPageBands.astro';
import AccountWorkspaceSidebar from './AccountWorkspaceSidebar.astro';
import AccountWorkspaceHeader from './AccountWorkspaceHeader.astro';
---

<div id="admin-dashboard" class="admin-dashboard account-workspace-app" style="display: none;">
  <div class="portal-layout">
    <AccountWorkspaceSidebar />
    <div class="portal-main">
      <AccountWorkspaceHeader />
      <MarketingPageBands class="marketing-page-bands--constellation-spine account-workspace-panels">
        <div class="portal-panels">
          <slot />
        </div>
      </MarketingPageBands>
    </div>
  </div>
</div>
