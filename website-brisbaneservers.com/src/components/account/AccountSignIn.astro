---
/** Sign-in / register — no page-level hero; card titles are the only headings. */
---

<script is:inline>
  (function () {
    try {
      var url = new URL(window.location.href);
      if (url.searchParams.has('password') || url.searchParams.has('email')) {
        url.searchParams.delete('password');
        url.searchParams.delete('email');
        history.replaceState({}, '', url.pathname + url.search + url.hash);
      }
    } catch (e) {}
  })();
</script>

<div id="login-screen" class="login-screen login-screen--classic">
  <div class="container login-container">
    <div
      id="auth-status-banner"
      class="auth-status-banner"
      style="display: none;"
      role="status"
      aria-live="polite"
    ></div>

    <div class="login-grid">
      <div class="login-card">
        <h2 class="login-card__title">Sign in</h2>
        <p class="login-subtitle">Manage contributions, saved work, resources, and voice settings.</p>
        <p class="login-note" id="login-remember-hint" hidden>
          You have a saved session on this device. Click Sign in to continue, or enter your password if prompted.
        </p>
        <form id="login-form" class="login-form" method="post" action="#" aria-label="Account sign-in form">
          <div class="form-group">
            <label for="email">Email <span class="sr-only">(required)</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              aria-required="true"
              aria-describedby="email-error"
            />
            <span id="email-error" class="sr-only">Enter your account email address</span>
          </div>
          <div class="form-group">
            <label for="password">Password <span class="sr-only">(required)</span></label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              aria-required="true"
              aria-describedby="password-error"
            />
            <span id="password-error" class="sr-only">Enter your account password</span>
          </div>
          <button type="submit" class="btn btn-primary btn-block" id="login-submit-btn" aria-describedby="login-submit-hint">
            Sign in
          </button>
          <button type="button" id="passkey-login-btn" class="btn btn-secondary btn-block" style="margin-top: var(--space-sm);">
            Sign in with passkey
          </button>
          <p
            class="login-oauth-divider"
            id="oauth-divider"
            style="display: none; margin: var(--space-md) 0 var(--space-sm); text-align: center; color: var(--portal-text-tertiary); font-size: var(--text-sm);"
          >
            or
          </p>
          <a
            id="google-oauth-btn"
            class="btn btn-secondary btn-block oauth-google-btn"
            href="#"
            style="display: none; text-align: center; text-decoration: none;"
          >
            Continue with Google
          </a>
          <p class="login-note" style="margin-top: var(--space-sm);">
            Passkeys use your device biometrics or security key. Register one after your first password or Google sign-in.
          </p>
          <span id="login-submit-hint" class="sr-only">Submit your credentials to access your account workspace</span>
          <div id="login-error" class="error-message" role="alert" aria-live="polite" aria-atomic="true"></div>
        </form>
        <form id="reset-password-form" class="login-form auth-help-form" method="post" action="#" aria-label="Reset password form" style="display: none;">
          <h3>Set a new password</h3>
          <div class="form-group">
            <label for="reset-password">New password</label>
            <input type="password" id="reset-password" name="password" required minlength="8" autocomplete="new-password" />
          </div>
          <button type="submit" class="btn btn-primary btn-block">Update password</button>
          <div id="reset-password-error" class="status-message" role="status" aria-live="polite"></div>
        </form>
      </div>

      <div class="login-card login-card--secondary">
        <h2>Create an account</h2>
        <p class="login-subtitle">Set up your workspace to contribute, track tokens, and keep your resources in one place.</p>
        <ul class="login-benefits">
          <li>Keep a history of submissions and accepted contributions.</li>
          <li>See your token balance and recent workspace activity.</li>
          <li>Return later to continue work without starting from scratch.</li>
        </ul>
        <form id="register-form" class="login-form" method="post" action="#" aria-label="Create account form">
          <div class="form-group">
            <label for="register-email">Email <span class="sr-only">(required)</span></label>
            <input
              type="email"
              id="register-email"
              name="email"
              required
              autocomplete="email"
              aria-required="true"
            />
          </div>
          <div class="form-group">
            <label for="register-password">Password <span class="sr-only">(required)</span></label>
            <input
              type="password"
              id="register-password"
              name="password"
              required
              minlength="8"
              autocomplete="new-password"
              aria-required="true"
            />
          </div>
          <button type="submit" class="btn btn-secondary btn-block" id="register-submit-btn">Create account</button>
          <div id="register-error" class="error-message" role="alert" aria-live="polite" aria-atomic="true"></div>
        </form>
        <div id="register-success-panel" class="auth-confirmation-panel" hidden>
          <h3 class="auth-confirmation-panel__title">Account created</h3>
          <p class="auth-confirmation-panel__lead">
            We sent a verification link to <strong id="register-success-email"></strong>.
          </p>
          <ol class="auth-confirmation-panel__steps">
            <li>Open the email from Brisbane Servers (check spam if needed).</li>
            <li>Click the verification link — you will return here with a confirmation message.</li>
            <li>Sign in with the email and password you just created.</li>
          </ol>
          <p class="auth-confirmation-panel__hint">
            No email after a few minutes? Use <strong>Resend verification email</strong> below with the same address.
          </p>
        </div>
        <div class="auth-help-stack">
          <form id="resend-verification-form" class="login-form auth-help-form" method="post" action="#" aria-label="Resend verification email form">
            <h3>Resend verification email</h3>
            <div class="form-group">
              <label for="resend-email">Email</label>
              <input type="email" id="resend-email" name="email" required autocomplete="email" />
            </div>
            <button type="submit" class="btn btn-secondary btn-block">Send verification email</button>
            <div id="resend-verification-error" class="status-message" role="status" aria-live="polite"></div>
          </form>
          <form id="forgot-password-form" class="login-form auth-help-form" method="post" action="#" aria-label="Forgot password form">
            <h3>Forgot your password?</h3>
            <div class="form-group">
              <label for="forgot-email">Email</label>
              <input type="email" id="forgot-email" name="email" required autocomplete="email" />
            </div>
            <button type="submit" class="btn btn-secondary btn-block">Send reset link</button>
            <div id="forgot-password-error" class="status-message" role="status" aria-live="polite"></div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
