              <div id="analytics-panel" class="portal-panel panel-shell" data-min-role="editor" role="main" aria-label="Analytics" style="display: none;">
                <div class="admin-content">
            <section class="admin-section" aria-labelledby="analytics-heading">
              <div class="section-header section-header--workspace">
                <div>
                  <h2 id="analytics-heading">Insights</h2>
                  <p class="section-subtitle">Corpus performance, voice alignment, and pipeline suggestions — separate from day-to-day create tools.</p>
                </div>
                <button id="refresh-analytics" class="btn btn-secondary btn-sm" onclick="loadAnalytics()" aria-label="Refresh analytics">
                  <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="23 4 23 10 17 10"></polyline>
                    <polyline points="1 20 1 14 7 14"></polyline>
                    <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                  </svg>
                  Refresh
                </button>
              </div>
              
              <!-- Analytics Guidance -->
              <details class="panel-guidance-details">
                <summary>Understanding your metrics</summary>
                <div class="panel-guidance-details__body">
                  <p><strong>Total resources:</strong> Starter curriculum, case studies, and your own content.</p>
                  <p><strong>Published / drafts:</strong> Live vs in-progress items.</p>
                  <p><strong>Avg voice score:</strong> Alignment with your active voice profile (0–100%).</p>
                </div>
              </details>
              
              <div id="analytics-content" class="analytics-content">
                <div class="stats-grid">
                  <div class="stat-card" title="Total number of resources in your system">
                    <h3>Total Resources</h3>
                    <p class="stat-value" id="stat-total-resources">-</p>
                    <p class="stat-description">All content items</p>
                  </div>
                  <div class="stat-card" title="Published resources available to users">
                    <h3>Published</h3>
                    <p class="stat-value" id="stat-published">-</p>
                    <p class="stat-description">Live content</p>
                  </div>
                  <div class="stat-card" title="Resources in development">
                    <h3>Drafts</h3>
                    <p class="stat-value" id="stat-drafts">-</p>
                    <p class="stat-description">In progress</p>
                  </div>
                  <div class="stat-card" title="Average voice alignment score">
                    <h3>Avg Voice Score</h3>
                    <p class="stat-value" id="stat-avg-score">-</p>
                    <p class="stat-description">Quality metric</p>
                  </div>
                </div>
                <div class="quick-links" style="margin-top: var(--space-2xl);">
                  <h3>Quick Actions</h3>
                  <div class="quick-links-grid">
                    <a href="/resources" class="quick-link-card" target="_blank">
                      <svg class="quick-link-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="2" y1="12" x2="22" y2="12"></line>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                      </svg>
                      <span class="quick-link-text">View Public Resources</span>
                    </a>
                    <button class="quick-link-card" onclick="exportResources()">
                      <svg class="quick-link-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                      </svg>
                      <span class="quick-link-text">Export Resources</span>
                    </button>
                    <button class="quick-link-card" onclick="bulkImproveResources()">
                      <svg class="quick-link-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                        <path d="M2 17l10 5 10-5"></path>
                        <path d="M2 12l10 5 10-5"></path>
                      </svg>
                      <span class="quick-link-text">Bulk Improve Resources</span>
                    </button>
                  </div>
                </div>
                <div id="analytics-suggestions-section" class="analytics-suggestions-section" style="margin-top: var(--space-2xl);">
                  <h3>Pipeline config &amp; suggestions</h3>
                  <p class="section-subtitle">Data-driven suggestions to tune auto-approval and quality. Apply changes below to update the pipeline.</p>
                  <div id="analytics-config-display" class="analytics-config-display"></div>
                  <div id="analytics-suggestions-list" class="analytics-suggestions-list"></div>
                </div>
                <div id="analytics-admin-meta" class="analytics-admin-meta" style="margin-top: var(--space-2xl);">
                  <h3>Admin: Users &amp; vectors</h3>
                  <div id="analytics-users-vectors" class="analytics-users-vectors"></div>
                </div>
              </div>
            </section>
                </div>
              </div>

