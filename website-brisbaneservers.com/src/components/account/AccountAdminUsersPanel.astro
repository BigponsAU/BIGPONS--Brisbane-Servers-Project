---
import { accountWorkspace } from '../../data/account-workspace';
---

<div id="admin-users-panel" class="portal-panel panel-shell" data-min-role="admin" role="main" aria-label="Registered users" style="display: none;">
  <div class="admin-content admin-users-panel-shell">
    <section class="admin-section" aria-labelledby="admin-users-heading">
      <div class="section-header section-header--workspace">
        <div>
          <h2 id="admin-users-heading">Users &amp; sign-in audit</h2>
          <p class="section-subtitle">
            Registered accounts from Neon auth. Verification emails send from
            <code>support@brisbaneservers.com</code> (Resend root domain).
          </p>
        </div>
        <div class="section-actions admin-panel-quick-links admin-users-toolbar">
          <button type="button" class="btn btn-secondary btn-sm" onclick="navigateToPanel('admin-ops')">Ops &amp; billing</button>
          <label class="sr-only" for="admin-users-search">Filter users</label>
          <input
            id="admin-users-search"
            type="search"
            class="form-input admin-users-search"
            placeholder="Filter by email or role…"
            autocomplete="off"
          />
          <button id="admin-users-export-btn" type="button" class="btn btn-secondary btn-sm">Export CSV</button>
          <button id="admin-users-refresh-btn" type="button" class="btn btn-secondary btn-sm">Refresh</button>
        </div>
      </div>

      <details class="panel-guidance-details">
        <summary>Roles &amp; workspace access</summary>
        <div class="panel-guidance-details__body">
          <p><strong>Client / viewer:</strong> Account home and contributor tools; editors get Create panels.</p>
          <p><strong>Admin:</strong> Library growth, moderation, site review, and ops panels.</p>
          <p><strong>Auth audit</strong> below lists recent sign-ins, registrations, and OAuth events.</p>
        </div>
      </details>

      <p id="admin-users-summary" class="admin-queue-summary" role="status" aria-live="polite">Loading users…</p>

      <div class="admin-users-table-wrap" role="region" aria-label="Registered users table" tabindex="0">
        <table class="admin-users-table">
          <thead>
            <tr>
              <th scope="col">Email</th>
              <th scope="col">Role</th>
              <th scope="col">Verified</th>
              <th scope="col">Joined</th>
              <th scope="col">Workspace access</th>
            </tr>
          </thead>
          <tbody id="admin-users-tbody">
            <tr><td colspan="5">Loading…</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="admin-section admin-section--nested" aria-labelledby="admin-auth-audit-heading">
      <div class="section-header">
        <div>
          <h3 id="admin-auth-audit-heading">Recent auth events</h3>
          <p class="section-subtitle">Logins, registrations, password resets, and OAuth (last 100).</p>
        </div>
      </div>
      <div class="admin-users-table-wrap" role="region" aria-label="Auth audit log" tabindex="0">
        <table class="admin-users-table admin-auth-audit-table">
          <thead>
            <tr>
              <th scope="col">When</th>
              <th scope="col">Event</th>
              <th scope="col">Email</th>
              <th scope="col">User ID</th>
            </tr>
          </thead>
          <tbody id="admin-auth-audit-tbody">
            <tr><td colspan="4">Loading…</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</div>
