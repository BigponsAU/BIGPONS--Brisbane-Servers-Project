---
import { industries } from '../../data/industries';
import AccountWorkspacePanelBand from './AccountWorkspacePanelBand.astro';
---

<div id="profiles-panel" class="portal-panel panel-shell" data-min-role="editor" role="main" aria-label="Voice profiles management" style="display: none;">
  <div class="admin-content profiles-panel-shell">
    <AccountWorkspacePanelBand
      semanticKey="account-profiles"
      eyebrow="Voice studio"
      title="Voice profiles"
      byline="Select a profile in the library to see rings, matrix, corpus, and actions. Use Generate with to jump to Create content with that voice."
      titleId="profiles-heading"
      constellationVariant="partnership"
    >
      <div slot="actions" class="section-actions profiles-toolbar-actions">
        <div class="quick-filters profile-filter-chips" role="group" aria-label="Filter profiles">
          <button id="filter-profiles-all" class="btn btn-sm active" type="button" onclick="filterProfiles('all')">All</button>
          <button id="filter-profiles-active" class="btn btn-sm" type="button" onclick="filterProfiles('active')">Active</button>
          <button id="filter-profiles-archived" class="btn btn-sm" type="button" onclick="filterProfiles('archived')">Archived</button>
        </div>
        <button id="refresh-profiles" class="btn btn-secondary btn-sm" type="button" aria-label="Refresh profiles list">
          <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="23 4 23 10 17 10"></polyline>
            <polyline points="1 20 1 14 7 14"></polyline>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
          </svg>
          Refresh
        </button>
      </div>

      <section class="admin-section admin-section--in-band" aria-labelledby="profiles-heading">

      <details class="panel-guidance-details">
        <summary>How voice profiles work</summary>
        <div class="panel-guidance-details__body">
          <p><strong>Active profiles</strong> are available for generation. Set one as default for Auto resolution in Create content.</p>
          <p><strong>Archived profiles</strong> are preserved but hidden from active use. Unarchive from the detail pane.</p>
          <p><strong>Analyze / Sculpt</strong> find and merge duplicate profiles while keeping unique characteristics.</p>
        </div>
      </details>

      <details class="panel-guidance-details panel-guidance-details--accent" open>
        <summary>BIGPONS — site voice profile</summary>
        <div class="panel-guidance-details__body profile-create-base-card">
          <p>Synthesises voice from the <strong>public website resource library</strong>. Narrow by industry for one vertical; leave &quot;All&quot; for the full corpus. Sets the storage default when the build succeeds.</p>
          <div class="form-group bigpons-industry-field">
            <label for="bigpons-industry-filter">Industry slice (optional)</label>
            <select id="bigpons-industry-filter" aria-label="Limit BIGPONS corpus to one industry">
              <option value="">All industries (public website library)</option>
              {industries.map((industry) => (
                <option value={industry.slug}>{industry.name}</option>
              ))}
            </select>
          </div>
          <button id="create-base-profile-btn" class="btn btn-primary btn-sm" type="button" onclick="createBaseProfile()" aria-label="Build or refresh BIGPONS profile from resources">
            Build / refresh BIGPONS from resources
          </button>
        </div>
      </details>

      <div class="profiles-workspace" id="profile-detail-workspace">
        <aside class="profiles-library" aria-label="Profile library">
          <div class="profile-actions-bar profile-actions-bar--compact" role="toolbar" aria-label="Profile actions">
            <button id="view-default-profile" class="btn btn-primary btn-sm" type="button" aria-label="View default profile" title="The default profile is used automatically for content generation">
              Default profile
            </button>
            <button id="analyze-duplicates-btn" class="btn btn-secondary btn-sm" type="button" aria-label="Analyze duplicate profiles" onclick="analyzeProfileDuplicates()">Analyze</button>
            <button id="deduplicate-profiles-btn" class="btn btn-warning btn-sm" type="button" aria-label="Remove duplicate profiles" onclick="deduplicateProfiles()">Sculpt</button>
            <button id="export-profiles" class="btn btn-secondary btn-sm" type="button" aria-label="Export profiles" onclick="exportProfiles()">Export</button>
          </div>
          <div id="profiles-list" class="profiles-list profiles-list-sidebar" role="region" aria-live="polite" aria-label="Voice profiles list">
            <p class="loading-message" role="status">Loading profiles…</p>
          </div>
        </aside>

        <main class="profiles-detail" aria-label="Profile detail">
          <div id="profile-workspace-empty" class="workspace-empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" />
            </svg>
            <h3>Select a profile</h3>
            <p>Choose a card from the library to view voice rings, matrix, corpus references, and profile actions.</p>
          </div>

          <div id="profile-detail-panel" class="profiles-detail-panel hidden" aria-live="polite">
            <header class="profiles-detail-header">
              <div>
                <h3 id="profile-detail-title" class="profiles-detail-title">—</h3>
                <p id="profile-detail-subtitle" class="profiles-detail-subtitle"></p>
              </div>
              <span id="profile-detail-badge" class="profile-item-badge badge-draft" hidden></span>
            </header>
            <div id="profile-detail-meta" class="profiles-detail-meta"></div>
            <div id="profile-detail-stats" class="profiles-detail-stats"></div>
            <div id="profile-detail-corpus" class="profiles-detail-corpus"></div>
            <div id="profile-detail-viz" class="profile-visualizations-full profiles-detail-viz"></div>
            <footer id="profile-detail-actions" class="profiles-detail-actions"></footer>
          </div>
        </main>
      </div>
    </section>
    </AccountWorkspacePanelBand>
  </div>
</div>
