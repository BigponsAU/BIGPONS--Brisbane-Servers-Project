---
import SectionConstellationLayer from '../SectionConstellationLayer.astro';
import { accountWorkspace } from '../../data/account-workspace';
---

<div id="voice-lab-panel" class="portal-panel" data-min-role="editor" role="main" aria-label="Voice lab" style="display: none;">
  <div class="admin-content">
    <section class="admin-section" aria-labelledby="voice-lab-heading">
      <SectionConstellationLayer variant="partnership" semanticKey="account-voice-lab" tier="whisper" placement="top-right" />
      <div class="section-header">
        <div>
          <h2 id="voice-lab-heading">{accountWorkspace.voiceLabLabel}</h2>
          <p class="section-subtitle">
            Tone analysis, pattern extraction, and voice match — integrated from the voice-framework workspace (no separate dashboard host).
          </p>
        </div>
      </div>

      <div class="voice-lab-grid">
        <div class="voice-lab-input card">
          <label for="voice-lab-text" class="form-label">Text to analyze</label>
          <textarea id="voice-lab-text" class="form-textarea" rows="8" placeholder="Paste sample copy (min 10 characters)…"></textarea>
          <div class="voice-lab-actions">
            <button type="button" id="voice-lab-analyze-btn" class="btn btn-primary btn-sm">Analyze voice</button>
            <button type="button" id="voice-lab-patterns-btn" class="btn btn-secondary btn-sm">Extract patterns</button>
          </div>
        </div>
        <div class="voice-lab-output card">
          <h3 class="card-title">Results</h3>
          <pre id="voice-lab-output" class="voice-lab-output-pre" aria-live="polite">Run analysis to see tone scores and voice match.</pre>
        </div>
      </div>
    </section>
  </div>
</div>
