---
import AccountWorkspacePanelBand from './AccountWorkspacePanelBand.astro';
import { accountWorkspace } from '../../data/account-workspace';
---

<div id="voice-lab-panel" class="portal-panel panel-shell" data-min-role="editor" role="main" aria-label="Voice lab" style="display: none;">
  <div class="admin-content">
    <AccountWorkspacePanelBand
      semanticKey="account-voice-lab"
      eyebrow="Voice studio"
      title={accountWorkspace.voiceLabLabel}
      byline="Tone analysis and pattern extraction. Pair with Voice profiles and Create content for end-to-end voice control."
      titleId="voice-lab-heading"
      constellationVariant="partnership"
    >
      <div slot="actions" class="section-actions">
        <button type="button" class="btn btn-secondary btn-sm" onclick="navigateToPanel('profiles')">Profiles</button>
        <button type="button" class="btn btn-secondary btn-sm" onclick="navigateToPanel('resources')">Create content</button>
      </div>

    <section class="admin-section admin-section--in-band" aria-labelledby="voice-lab-heading">
      <div class="voice-lab-grid voice-lab-grid--primary">
        <div class="voice-lab-input card">
          <label for="voice-lab-text" class="form-label">Text to analyze</label>
          <textarea id="voice-lab-text" class="form-textarea" rows="8" placeholder="Paste sample copy (min 10 characters)…"></textarea>
          <div class="voice-lab-actions">
            <button type="button" id="voice-lab-analyze-btn" class="btn btn-primary btn-sm">Analyze voice</button>
            <button type="button" id="voice-lab-patterns-btn" class="btn btn-secondary btn-sm">Extract patterns</button>
          </div>
        </div>
        <div class="voice-lab-output card">
          <h3 class="card-title">Results</h3>
          <pre id="voice-lab-output" class="voice-lab-output-pre" aria-live="polite">Run analysis to see tone scores and voice match.</pre>
        </div>
      </div>

      <details class="panel-guidance-details voice-lab-markov-details">
        <summary>Portal flow (Markov) — optional</summary>
        <div class="panel-guidance-details__body">
          <p class="section-subtitle">Panel navigation patterns recorded as you move through the workspace (this browser only).</p>
          <div class="voice-lab-actions voice-lab-markov-actions">
            <button type="button" id="voice-lab-markov-refresh" class="btn btn-secondary btn-sm">Refresh</button>
            <button type="button" id="voice-lab-markov-debug" class="btn btn-secondary btn-sm">Debug insights</button>
            <button type="button" id="voice-lab-markov-extrapolate" class="btn btn-secondary btn-sm">Extrapolate issues</button>
            <button type="button" id="voice-lab-markov-export" class="btn btn-secondary btn-sm">Export JSON</button>
            <button type="button" id="voice-lab-markov-reset" class="btn btn-secondary btn-sm">Reset</button>
          </div>
          <pre id="voice-lab-markov-summary" class="voice-lab-output-pre" aria-live="polite">Navigate the workspace to collect flow data.</pre>
          <pre id="voice-lab-markov-debug" class="voice-lab-output-pre voice-lab-markov-debug" aria-live="polite">Click “Debug insights” to analyze function errors and unused registrations.</pre>
        </div>
      </details>
    </section>
    </AccountWorkspacePanelBand>
  </div>
</div>
