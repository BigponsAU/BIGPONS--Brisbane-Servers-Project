<!-- Workspace info overlay — lives outside portal panels so it works from any view -->
<div id="info-card" class="info-card" role="dialog" aria-labelledby="info-card-title" aria-hidden="true">
  <div class="info-card-rail" id="info-card-rail">
    <div class="rail-line rail-line-primary"></div>
    <div class="rail-line rail-line-secondary"></div>
    <div class="rail-line rail-line-tertiary"></div>
    <div class="rail-indicator"></div>
  </div>

  <div class="info-card-tartan-overlay" id="info-card-tartan-overlay"></div>

  <div class="info-card-content">
    <div class="info-card-header">
      <h2 id="info-card-title">Workspace guide</h2>
      <button class="info-card-close" onclick="toggleInfoCard()" aria-label="Close information card">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="info-card-body">
      <div class="info-section">
        <h3>Workspace mode</h3>
        <p>
          <strong>Overview, Content, Voice</strong> — resources, analytics, voice profiles, voice lab (tone analysis +
          Markov flow tracking), and voice map (2D, depth, 3D).
        </p>
      </div>
      <div class="info-section">
        <h3>Admin console</h3>
        <p>
          Admins can switch to <strong>Library</strong> (growth proposals, moderation, site review) and
          <strong>Platform</strong> (users, ops &amp; usage). Billing top-up UI is planned — usage caps and token
          redeem are live today.
        </p>
      </div>
      <div class="info-section">
        <h3>Search (Ctrl+K)</h3>
        <p>
          Default search filters resources. Use <code>profile:name</code> for voice profiles,
          <code>voice:text</code> to open voice lab with sample copy, or type a panel name (e.g. <code>moderation</code>).
        </p>
      </div>
      <div class="info-section">
        <h3>Voice lab — Markov flow</h3>
        <p>
          Panel transitions are recorded as you navigate. Open Voice lab to see the summary, export JSON, or reset.
          Deep function-level Markov (legacy Docker dashboard) is Phase 2.
        </p>
      </div>
      <div class="info-section">
        <h3>Feature matrix</h3>
        <p>
          Full completion status for every panel lives in
          <code>docs/portal/DASHBOARD_FEATURE_MATRIX.md</code> in the repo — use it when extending the dashboard so
          nothing is dropped during refactors.
        </p>
      </div>
    </div>
    <div class="info-card-footer">
      <button class="btn btn-primary btn-sm" onclick="toggleInfoCard()">Got it</button>
    </div>
  </div>

  <div class="info-card-trail">
    <div class="trail-element trail-element-1"></div>
    <div class="trail-element trail-element-2"></div>
    <div class="trail-element trail-element-3"></div>
  </div>
</div>
