---
import { accountWorkspace } from '../../data/account-workspace';
---

<header class="portal-header">
  <div class="header-left">
    <button id="mobile-menu-toggle" class="mobile-menu-toggle" aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <div class="header-title-mobile">
      <h1 class="workspace-toolbar-title">{accountWorkspace.productName}</h1>
    </div>
  </div>
  <div class="header-right">
    <div id="header-workspace-mode-switcher" class="header-workspace-mode-switcher" data-min-role="admin" hidden aria-hidden="true">
      <button type="button" id="header-workspace-mode-creator" class="workspace-mode-btn workspace-mode-btn--compact is-active" data-workspace-mode="creator" aria-pressed="true">Workspace</button>
      <button type="button" id="header-workspace-mode-admin" class="workspace-mode-btn workspace-mode-btn--compact" data-workspace-mode="admin" aria-pressed="false">Admin</button>
    </div>
    <button id="header-info-trigger" class="btn btn-secondary btn-sm header-info-btn" onclick="toggleInfoCard()" aria-label="Toggle information card">
      <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>
      <span class="header-info-btn__label">Info</span>
    </button>
    <span id="user-info" class="user-info header-user-info"></span>
    <button id="logout-btn" class="btn btn-secondary btn-sm header-logout-btn">Logout</button>
  </div>
</header>
