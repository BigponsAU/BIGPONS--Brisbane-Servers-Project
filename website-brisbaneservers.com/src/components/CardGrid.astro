---
interface Props {
  progressive?: boolean;
  layout?: 'grid' | 'masonry' | 'stacked' | 'asymmetric';
  columns?: number;
  class?: string;
  style?: string;
}

const { 
  progressive = false, 
  layout = 'grid',
  columns = 3,
  class: className = '',
  style: inlineStyle = '',
} = Astro.props;

const gridClass = [
  'card-grid',
  progressive ? 'progressive' : '',
  `card-grid-${layout}`,
  className
].filter(Boolean).join(' ');

const gridStyle = [
  layout === 'grid' ? `--grid-columns: ${columns}` : '',
  inlineStyle,
].filter(Boolean).join('; ');
---

<div class={gridClass} style={gridStyle}>
  <slot />
</div>

<style>
  .card-grid {
    display: grid;
    gap: var(--space-xl);
    width: 100%;
    justify-content: start;
    align-items: start;
  }

  /* Fluid tracks: enforce a minimum card width, let rows fill available space. */
  .card-grid-grid {
    grid-template-columns: repeat(
      var(--grid-columns, 3),
      minmax(
        min(100%, var(--info-panel-track-min)),
        1fr
      )
    );
  }

  @media (max-width: 1024px) {
    .card-grid-grid {
      grid-template-columns: repeat(
        2,
        minmax(
          min(100%, var(--info-panel-track-min)),
          1fr
        )
      );
      gap: var(--space-lg);
    }
  }

  @media (max-width: 768px) {
    .card-grid-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--space-lg);
    }
  }

  /* Masonry layout - allows card size variation */
  .card-grid-masonry {
    grid-template-columns: repeat(
      auto-fill,
      minmax(
        min(100%, var(--grid-min-column-masonry)),
        min(100%, var(--info-panel-track-max))
      )
    );
    grid-auto-rows: auto;
    gap: var(--space-xl);
  }

  /* Stacked layout - vertical flow */
  .card-grid-stacked {
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  /* Asymmetric layout - allows featured cards and variations */
  .card-grid-asymmetric {
    grid-template-columns: repeat(
      auto-fit,
      minmax(
        min(100%, var(--grid-min-column-asymmetric)),
        min(100%, var(--info-panel-track-max))
      )
    );
    grid-auto-flow: dense;
    gap: var(--space-xl);
  }

  /* Progressive loading support */
  .card-grid.progressive .card {
    opacity: 0;
    animation: fadeIn 0.5s ease-in forwards;
  }

  .card-grid.progressive .card:nth-child(1) { animation-delay: 0.1s; }
  .card-grid.progressive .card:nth-child(2) { animation-delay: 0.2s; }
  .card-grid.progressive .card:nth-child(3) { animation-delay: 0.3s; }
  .card-grid.progressive .card:nth-child(4) { animation-delay: 0.4s; }
  .card-grid.progressive .card:nth-child(5) { animation-delay: 0.5s; }
  .card-grid.progressive .card:nth-child(6) { animation-delay: 0.6s; }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }
</style>
