---
import BaseLayout from './BaseLayout.astro';
import SiteShellBody from './SiteShellBody.astro';
import type { PageDensity, PageShellVariant, PageValueProfile, PageZoomProfile } from '../lib/page-descriptors';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  structuredData?: Record<string, unknown>[];
  noindex?: boolean;
  immediateRedirectUrl?: string;
  currentPath?: string;
  pageId?: string;
  shellVariant?: PageShellVariant;
  valueProfile?: PageValueProfile;
  zoomProfile?: PageZoomProfile;
  density?: PageDensity;
  mainClass?: string;
  mainId?: string;
  showFooter?: boolean;
}

const {
  title,
  description,
  ogImage,
  ogType,
  structuredData,
  noindex = false,
  immediateRedirectUrl,
  currentPath = '',
  pageId = 'account',
  shellVariant = 'marketing',
  valueProfile,
  zoomProfile,
  density,
  mainClass = '',
  mainId = 'main-content',
  showFooter = true,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  ogType={ogType}
  structuredData={structuredData}
  noindex={noindex}
  immediateRedirectUrl={immediateRedirectUrl}
  pageId={pageId}
  shellVariant={shellVariant}
  valueProfile={valueProfile}
  zoomProfile={zoomProfile}
  density={density}
>
  <SiteShellBody
    currentPath={currentPath}
    pageId={pageId}
    shellVariant={shellVariant}
    mainClass={mainClass}
    mainId={mainId}
    showFooter={showFooter}
  >
    <slot />
  </SiteShellBody>
</BaseLayout>

<script>
  import '../scripts/account-nav.ts';
</script>
