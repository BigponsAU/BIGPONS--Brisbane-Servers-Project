---
import '../styles/global.css';
import '../styles/symmetry-harmony.css';
import '../styles/geometric-detailing.css';
import '../styles/floral-pattern.css';
import '../styles/tartan-pattern.css';
import '../styles/site-framework.css';
import '../styles/site-frame-shell.css';
import '../styles/brand-chroma.css';
import '../styles/nav-mega-menu.css';
import '../styles/marketing-constellation.css';
import CookieConsent from '../components/CookieConsent.astro';
import favicon from '../favicon.png';
import {
  getPageDescriptor,
  type PageDensity,
  type PageShellVariant,
  type PageValueProfile,
  type PageZoomProfile,
} from '../lib/page-descriptors';
import { valueProposition } from '../data/value-proposition';
import {
  buildCanonicalUrl,
  buildOrganizationJsonLd,
  buildWebSiteJsonLd,
  formatPageTitle,
  mergeJsonLdGraph,
  SEO_LOCALE,
} from '../lib/seo';

interface Props {
  title: string;
  description?: string;
  /** When set, emits an immediate HTTP meta refresh (e.g. legacy /portal → /account/). */
  immediateRedirectUrl?: string;
  /** Absolute image URL for Open Graph / Twitter (defaults to `/og-default.png` on site origin). */
  ogImage?: string;
  /** Open Graph type — defaults to `website`; use `article` for guides and resources. */
  ogType?: 'website' | 'article';
  /** Extra schema.org nodes appended to the default JSON-LD graph. */
  structuredData?: Record<string, unknown>[];
  /** When true, adds robots noindex and omits OG/Twitter images and JSON-LD for sensitive routes (e.g. portal). */
  noindex?: boolean;
  pageId?: string;
  shellVariant?: PageShellVariant;
  valueProfile?: PageValueProfile;
  zoomProfile?: PageZoomProfile;
  density?: PageDensity;
}

const {
  title,
  description = valueProposition.metaDefault,
  ogImage,
  ogType = 'website',
  structuredData = [],
  noindex = false,
  immediateRedirectUrl,
  pageId,
  shellVariant,
  valueProfile,
  zoomProfile,
  density,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://brisbaneservers.com');
const siteOrigin = siteUrl.origin;
const pageTitle = formatPageTitle(title);
const canonicalHref = buildCanonicalUrl(Astro.url.pathname, siteOrigin, import.meta.env.BASE_URL);
const descriptor = getPageDescriptor(Astro.url.pathname);
/** Default social preview: South Bank / riverfront in `public/og-default.png`. Alternate: `og-nature.png`. */
const OG_DEFAULT_PATH = '/og-default.png';
const OG_IMAGE_WIDTH = 1200;
const OG_IMAGE_HEIGHT = 630;
const defaultShareImage = buildCanonicalUrl(OG_DEFAULT_PATH, siteOrigin, import.meta.env.BASE_URL);
const shareImage = ogImage ?? defaultShareImage;
const useDefaultOgDimensions = !ogImage;

const jsonLd = mergeJsonLdGraph(
  buildWebSiteJsonLd(siteOrigin, description),
  buildOrganizationJsonLd(siteOrigin),
  ...structuredData,
);
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    {immediateRedirectUrl && (
      <meta http-equiv="refresh" content={`0;url=${immediateRedirectUrl}`} />
    )}
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover, interactive-widget=resizes-content" />
    <meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests" />
    <meta name="theme-color" content="#0A74DA" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalHref} />
    <meta property="og:locale" content={SEO_LOCALE} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Brisbane Servers" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalHref} />
    {!noindex && <meta property="og:image" content={shareImage} />}
    {!noindex && useDefaultOgDimensions && (
      <>
        <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
        <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
      </>
    )}
    {!noindex && (
      <meta
        property="og:image:alt"
        content="Brisbane Servers — Brisbane River & South Bank–inspired brand imagery."
      />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {!noindex && <meta name="twitter:image" content={shareImage} />}
    <title>{pageTitle}</title>
    {!noindex && <script type="application/ld+json" set:html={jsonLd} />}
    {/* Immediate cleanup script - runs before any cached scripts */}
    <script is:inline>
      // Force cleanup immediately - Chrome cache workaround
      (function() {
        'use strict';
        function cleanup() {
          try {
            if (document.body) {
              document.body.style.overflow = '';
              document.body.style.pointerEvents = '';
            }
            // Close modals
            var modals = document.querySelectorAll('.modal');
            for (var i = 0; i < modals.length; i++) {
              modals[i].setAttribute('aria-hidden', 'true');
              modals[i].style.display = 'none';
              modals[i].style.pointerEvents = 'none';
            }
            // Remove overlays
            var overlays = document.querySelectorAll('.modal-overlay');
            for (var i = 0; i < overlays.length; i++) {
              overlays[i].style.display = 'none';
              overlays[i].style.pointerEvents = 'none';
            }
            // Close info card
            var infoCard = document.getElementById('info-card');
            if (infoCard) {
              infoCard.classList.remove('active', 'railed');
              infoCard.setAttribute('aria-hidden', 'true');
              infoCard.style.pointerEvents = 'none';
            }
          } catch(e) {}
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', cleanup);
        } else {
          cleanup();
        }
        window.addEventListener('load', cleanup);
      })();
    </script>
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" />
    </noscript>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    </noscript>
  </head>
  <body
    data-page-id={pageId ?? descriptor.pageId}
    data-shell-variant={shellVariant ?? descriptor.shellVariant}
    data-value-profile={valueProfile ?? descriptor.valueProfile}
    data-page-density={density ?? descriptor.density}
    data-site-base={import.meta.env.BASE_URL}
  >
    <!-- Skip to main content link for screen readers -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
    <CookieConsent />
  </body>
</html>

<script>
  import '../scripts/main.ts';
</script>

