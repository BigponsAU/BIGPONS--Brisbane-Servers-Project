---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MarketingMainRail from '../components/marketing/MarketingMainRail.astro';
import type { PageDensity, PageShellVariant, PageValueProfile, PageZoomProfile } from '../lib/page-descriptors';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  structuredData?: Record<string, unknown>[];
  noindex?: boolean;
  immediateRedirectUrl?: string;
  currentPath?: string;
  pageId?: string;
  shellVariant?: PageShellVariant;
  valueProfile?: PageValueProfile;
  zoomProfile?: PageZoomProfile;
  density?: PageDensity;
  mainClass?: string;
  mainId?: string;
  showFooter?: boolean;
}

const {
  title,
  description,
  ogImage,
  ogType,
  structuredData,
  noindex = false,
  immediateRedirectUrl,
  currentPath = '',
  pageId,
  shellVariant = 'public',
  valueProfile,
  zoomProfile,
  density,
  mainClass = '',
  mainId = 'main-content',
  showFooter = true,
} = Astro.props;

/** Guide routes: header scrolls with the page (no fixed overlap / bleed). */
const headerInFlow =
  pageId === 'resource-topic' || pageId === 'resource-industry';

const shellClassName = [
  'site-shell',
  `site-shell--${shellVariant}`,
  headerInFlow && 'site-shell--header-in-flow',
]
  .filter(Boolean)
  .join(' ');
const mainClassName = [
  'site-main',
  shellVariant !== 'portal' ? 'site-main--public' : '',
  shellVariant === 'marketing' ? 'site-main--marketing' : '',
  shellVariant === 'public' ? 'site-main--marketing' : '',
  mainClass,
].filter(Boolean).join(' ');
const showMarketingRail = shellVariant !== 'portal' && pageId !== 'account';
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  ogType={ogType}
  structuredData={structuredData}
  noindex={noindex}
  immediateRedirectUrl={immediateRedirectUrl}
  pageId={pageId}
  shellVariant={shellVariant}
  valueProfile={valueProfile}
  zoomProfile={zoomProfile}
  density={density}
>
  <div class={shellClassName}>
    <Header currentPath={currentPath} />
    <main id={mainId} class={mainClassName} role="main">
      {showMarketingRail && <MarketingMainRail />}
      <slot />
    </main>
    {showFooter && <Footer />}
  </div>
</BaseLayout>
