---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { PageDensity, PageShellVariant, PageValueProfile, PageZoomProfile } from '../lib/page-descriptors';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  immediateRedirectUrl?: string;
  currentPath?: string;
  pageId?: string;
  shellVariant?: PageShellVariant;
  valueProfile?: PageValueProfile;
  zoomProfile?: PageZoomProfile;
  density?: PageDensity;
  mainClass?: string;
  mainId?: string;
  showFooter?: boolean;
}

const {
  title,
  description,
  ogImage,
  noindex = false,
  immediateRedirectUrl,
  currentPath = '',
  pageId,
  shellVariant = 'public',
  valueProfile,
  zoomProfile,
  density,
  mainClass = '',
  mainId = 'main-content',
  showFooter = true,
} = Astro.props;

const shellClassName = ['site-shell', `site-shell--${shellVariant}`].join(' ');
const mainClassName = [
  'site-main',
  shellVariant !== 'portal' ? 'site-main--public' : '',
  shellVariant === 'marketing' ? 'site-main--marketing' : '',
  shellVariant === 'public' ? 'site-main--marketing' : '',
  mainClass,
].filter(Boolean).join(' ');
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  noindex={noindex}
  immediateRedirectUrl={immediateRedirectUrl}
  pageId={pageId}
  shellVariant={shellVariant}
  valueProfile={valueProfile}
  zoomProfile={zoomProfile}
  density={density}
>
  <div class={shellClassName}>
    <Header currentPath={currentPath} />
    <main id={mainId} class={mainClassName} role="main">
      <slot />
    </main>
    {showFooter && <Footer />}
  </div>
</BaseLayout>
