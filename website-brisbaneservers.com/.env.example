# Copy to `.env` in this folder (website-brisbaneservers.com) for local dev / cPanel Node.
# Never commit real secrets.

# --- Bootstrap admin (optional) ---
# If BOTH are set, that email/password can sign in as admin/super-admin.
# Leave UNSET in production if you rely only on registered users persisted in auth storage.
# There are NO hardcoded defaults in code — you must set these explicitly.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# Public API base used by browser-side pages, account workspace, and contribute flows.
# Local hybrid (npm run start:hybrid): use /api — Vite proxies to the API on port 3002.
# API_LISTEN_HOST=127.0.0.1  (default in dev; production uses 0.0.0.0)
# Cloudflare Pages production: https://<api-host>/api
# See DEPLOYMENT.md in the monorepo root.
PUBLIC_API_BASE_URL=/api

# Server/build-time API base used by Astro prerender during static builds.
# If unset, falls back to PUBLIC_API_BASE_URL, then http://localhost:3002/api.
# Hosted build with live API: set to https://<api-host>/api
INTERNAL_API_BASE_URL=/api

# Canonical site origin used for metadata and sitemap generation.
PUBLIC_SITE_URL=https://brisbaneservers.com

# Base path at domain root (Cloudflare Pages + brisbaneservers.com).
PUBLIC_SITE_BASE=/

# Auth email delivery. In local development you can leave SMTP unset and links will be logged to the server console.
# In production, configure SMTP and sender identity so verification/reset emails can be delivered.
# AUTH_EMAIL_FROM=Brisbane Servers <support@brisbaneservers.com>
# AUTH_EMAIL_REPLY_TO=connect@brisbaneservers.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# CORS allow-list for the standalone API host (production example).
# ALLOWED_ORIGINS=https://brisbaneservers.com
ALLOWED_ORIGINS=http://localhost:3000

# Port for the standalone API host.
PORT=3002

# --- Production auth database (required for brisbaneservers.com signup) ---
# Managed Postgres with TLS — Neon, Supabase, Render, Railway, etc.
# Never use ephemeral SQLite on a production API host.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# --- Google OAuth (optional — API host only) ---
# Create credentials: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_OAUTH_REDIRECT_URI (or auto /api/auth/oauth/google/callback on API host).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://<api-host>/api/auth/oauth/google/callback

# JWT for session tokens (required in production when not using bootstrap ADMIN_* only).
# JWT_SECRET=

# Seed a bcrypt admin in Postgres (preferred over long-lived ADMIN_PASSWORD):
#   npm run seed:admin
# ADMIN_SEED_EMAIL=you@brisbaneservers.com
# ADMIN_SEED_PASSWORD=

# NODE_ENV=development

# Monorepo root (API host only — parent folder containing voice-framework/storage)
# MONOREPO_ROOT=/opt/render/project/src

# Render MCP in Cursor (local only — not for Pages): npm run configure:render-mcp
# RENDER_API_KEY=

# --- Library growth automation (API host) ---
# Secured cron: POST /api/cron/library-growth with Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=
# In-process scheduler on the API process (checks every 15m): LIBRARY_GROWTH_SCHEDULER=1
# LIBRARY_GROWTH_SCHEDULER=0

# --- Static site rebuild after publish (API host) ---
# Cloudflare Pages → Settings → Builds → Deploy hooks
# CLOUDFLARE_PAGES_DEPLOY_HOOK_URL=
