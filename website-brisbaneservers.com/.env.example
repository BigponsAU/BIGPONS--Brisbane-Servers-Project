# Copy to `.env` in this folder (website-brisbaneservers.com) for local dev / cPanel Node.
# Never commit real secrets.

# --- Bootstrap admin (optional) ---
# If BOTH are set, that email/password can sign in as admin/super-admin.
# Leave UNSET in production if you rely only on registered users in users.json.
# There are NO hardcoded defaults in code — you must set these explicitly.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# API base for the portal (same-origin recommended)
PUBLIC_VOICE_API_URL=/api

# Site URL for canonical links, sitemap (production)
# PUBLIC_SITE_URL=https://brisbaneservers.com

# NODE_ENV=development
