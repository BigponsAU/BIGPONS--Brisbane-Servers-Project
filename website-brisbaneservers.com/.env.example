# Copy to `.env` in website-brisbaneservers.com for build scripts / seeding only.
# Production secrets live on Cloudflare Worker + Pages — never commit real values.

# --- Browser / Astro build ---
# Production API (required for account workspace and contribute flows in dev preview):
PUBLIC_API_BASE_URL=https://api.brisbaneservers.com/api
INTERNAL_API_BASE_URL=https://api.brisbaneservers.com/api
PUBLIC_SITE_URL=https://brisbaneservers.com
PUBLIC_SITE_BASE=/

# --- One-off scripts (seed:admin, migrate:corpus) ---
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Bootstrap admin (optional break-glass; prefer npm run seed:admin) ---
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# --- Google OAuth (worker secrets in production) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Auth email (Resend via worker; see docs/operations/HOSTING_MCP_WORKSPACE.md) ---
# AUTH_EMAIL_FROM=Brisbane Servers <support@mail.brisbaneservers.com>

# --- Cron / Pages hook (worker secrets) ---
# CRON_SECRET=
# CLOUDFLARE_PAGES_DEPLOY_HOOK_URL=
