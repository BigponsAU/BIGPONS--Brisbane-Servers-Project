# Admin Portal Credentials
# ⚠️ WARNING: Default credentials are for development only!
# ⚠️ CRITICAL: Change these before deploying to production!
ADMIN_EMAIL=admin@brisbaneservers.com
ADMIN_PASSWORD=admin123

# API Configuration
# API endpoint URL (defaults to /api if not set)
VOICE_API_URL=/api
PUBLIC_VOICE_API_URL=/api

# Security
# Generate a secure secret: openssl rand -base64 32
# ⚠️ CRITICAL: Change this to a strong random string in production!
JWT_SECRET=your-secure-jwt-secret-change-in-production

# Environment
# Options: development, production, test
NODE_ENV=production
