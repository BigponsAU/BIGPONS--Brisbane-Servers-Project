# Copy to `.env` in this folder (website-brisbaneservers.com) for local dev / cPanel Node.
# Never commit real secrets.

# --- Bootstrap admin (optional) ---
# If BOTH are set, that email/password can sign in as admin/super-admin.
# Leave UNSET in production if you rely only on registered users in users.json.
# There are NO hardcoded defaults in code — you must set these explicitly.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# Public API base used by browser-side pages, portal, and contribute flows.
# Local same-origin dev can keep this as /api if you proxy through one host.
PUBLIC_API_BASE_URL=http://localhost:3002/api

# Server/build-time API base used by Astro prerender during static builds.
# If unset, it falls back to PUBLIC_API_BASE_URL, then http://localhost:3002/api.
INTERNAL_API_BASE_URL=http://localhost:3002/api

# Canonical site origin used for metadata and sitemap generation.
# PUBLIC_SITE_URL=https://brisbaneservers.com

# Base path for GitHub Pages project sites. Use "/" for custom domains or root hosting.
PUBLIC_SITE_BASE=/

# CORS allow-list for the standalone API host.
ALLOWED_ORIGINS=http://localhost:3000

# Port for the standalone API host.
PORT=3002

# NODE_ENV=development
