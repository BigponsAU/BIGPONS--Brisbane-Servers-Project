# Cloudflare Pages → Production environment variables (no secrets).
# Project: brisbaneservers (configured via Cloudflare API / dashboard)
# Paste into Workers & Pages → brisbaneservers → Settings → Environment variables → Production

PUBLIC_SITE_URL=https://brisbaneservers.com
PUBLIC_SITE_BASE=/
PUBLIC_API_BASE_URL=https://api.brisbaneservers.com/api
INTERNAL_API_BASE_URL=https://api.brisbaneservers.com/api

# Static build: export published corpus from API once in prebuild, then prerender from git file.
PAGES_BUILD_EXPORT_ON_BUILD=1
PAGES_BUILD_USE_GIT_CORPUS=1

# SSR catalog reads live API; prerender/static paths use exported git corpus.
PUBLIC_RESOURCES_LIVE=1
