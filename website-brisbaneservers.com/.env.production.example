# Production API host — copy to provider dashboard (Render/Railway/Fly). Never commit real values.
# Monorepo checkout required; set MONOREPO_ROOT to repo root (parent of voice-framework/).

NODE_ENV=production
PORT=3002
MONOREPO_ROOT=/opt/render/project/src

PUBLIC_SITE_URL=https://brisbaneservers.com
ALLOWED_ORIGINS=https://brisbaneservers.com
ALLOW_CLOUDFLARE_PAGES=1
TRUST_PROXY=1

# Postgres — auth + corpus (resources, vectors, library growth).
# Recommended: Neon free tier (no 30-day expiry). Do NOT rely on Render free Postgres long-term.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
JWT_SECRET=

# Cloudflare Pages rebuild when resources publish (SEO)
CLOUDFLARE_PAGES_DEPLOY_HOOK_URL=

# Library growth cron (optional)
CRON_SECRET=
# LIBRARY_GROWTH_SCHEDULER=1

# Email (signup verify, password reset, admin credentials)
AUTH_EMAIL_FROM=Brisbane Servers <support@brisbaneservers.com>
AUTH_EMAIL_REPLY_TO=connect@brisbaneservers.com
# Prefer Resend (verify domain brisbaneservers.com in Resend dashboard):
RESEND_API_KEY=
# Or classic SMTP:
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Bootstrap + provision target (scripts/configure-render-auth.ps1)
ADMIN_EMAIL=bigpons@brisbaneservers.com
ADMIN_PASSWORD=

# Embeddings (optional)
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=
