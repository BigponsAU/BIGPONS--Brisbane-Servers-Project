{
  "name": "brisbane-servers-website",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "bootstrap:storage": "npx tsx scripts/bootstrap-voice-storage.ts",
    "migrate:corpus": "npx tsx scripts/migrate-corpus-to-postgres.ts",
    "start:api": "npx tsx standalone-api/server.ts",
    "typecheck": "astro sync && npx tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "prebuild": "npx tsx scripts/pre-build-check.ts",
    "build": "astro build",
    "build:hosted": "npx tsx scripts/build-hosted.ts",
    "preview:hosted": "npx tsx scripts/build-hosted.ts && astro preview",
    "seed:admin": "npx tsx scripts/seed-admin-user.ts",
    "verify:production": "npx tsx scripts/verify-production-api.ts",
    "verify:go-live": "npx tsx scripts/verify-go-live-local.ts",
    "setup:cloudflare-email": "node scripts/setup-cloudflare-email-routing.mjs",
    "configure:cloudflare-mcp": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/configure-cloudflare-mcp.ps1",
    "configure:render-mcp": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/configure-render-mcp.ps1",
    "configure:render-auth": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/configure-render-auth.ps1",
    "build:cpanel": "npm run prebuild && astro build --config astro.config.cpanel.mjs && npm run postbuild",
    "postbuild": "npx tsx scripts/post-build-verify.ts",
    "preview": "astro preview",
    "validate-tokens": "npx tsx scripts/validate-tokens.ts",
    "check-scaling": "npx tsx scripts/check-token-scaling.ts",
    "audit:css-vars": "npx tsx scripts/audit-css-vars.ts",
    "verify": "npm run audit:css-vars && npm run build && npm run check-scaling"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.5",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "astro": "^5.18.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.13.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.10",
    "glob": "^10.3.10",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
